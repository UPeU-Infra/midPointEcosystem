            <cfg:searchScript>
import groovy.sql.Sql
import org.identityconnectors.framework.common.objects.*

def sql = new Sql(connection)
def result = []
def query = """
SELECT * FROM (
  SELECT
    e.COD_APS,
    e.NOMBRE,
    e.PATERNO,
    e.MATERNO,
    e.NUM_DOCUMENTO,
    e.FEC_INICIO,
    e.FEC_TERMINO,
    e.ESTADO,
    e.ID_CATEGORIAOCUPACIONAL,
    CASE WHEN cd.ID_DOCENTE IS NOT NULL
         THEN 'archetype-user-employee-faculty'
         ELSE 'archetype-user-employee-staff' END AS UPEU_ARCHETYPE_NAME,
    ROW_NUMBER() OVER (PARTITION BY e.COD_APS ORDER BY e.FEC_INICIO DESC NULLS LAST) AS RN
  FROM ELISEO.VW_APS_EMPLEADO e
  LEFT JOIN ENOC.CAT_DOCENTE cd
    ON cd.ID_PERSONA = e.ID_PERSONA AND cd.ID_ESTADO_DOCENTE = '02'
  WHERE e.ESTADO = 'A'
) WHERE RN = 1
"""
sql.eachRow(query) { row -&gt;
    def cob = new ConnectorObjectBuilder()
    cob.setObjectClass(ObjectClass.ACCOUNT)
    cob.setUid(row.COD_APS as String)
    cob.setName(row.COD_APS as String)
    cob.addAttribute("NOMBRE", row.NOMBRE as String)
    cob.addAttribute("PATERNO", row.PATERNO as String)
    cob.addAttribute("MATERNO", row.MATERNO as String)
    cob.addAttribute("NUM_DOCUMENTO", row.NUM_DOCUMENTO as String)
    cob.addAttribute("FEC_INICIO", row.FEC_INICIO?.toString())
    cob.addAttribute("FEC_TERMINO", row.FEC_TERMINO?.toString())
    cob.addAttribute("ESTADO", row.ESTADO as String)
    cob.addAttribute("UPEU_ARCHETYPE_NAME", row.UPEU_ARCHETYPE_NAME as String)
    handler.handle(cob.build())
}
return new SearchResult()
</cfg:searchScript>
