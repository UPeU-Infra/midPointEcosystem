def ro = { String attrName, boolean required -&gt;
    def aib = new AttributeInfoBuilder(attrName, String.class)
    aib.setRequired(required)
    aib.setCreateable(false)
    aib.setUpdateable(false)
    aib.setReadable(true)
    aib.build()
}

def ocib = new ObjectClassInfoBuilder()
ocib.setType(ObjectClass.ACCOUNT_NAME)

