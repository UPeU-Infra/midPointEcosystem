<?xml version="1.0" encoding="UTF-8"?>
<!--
    Application Role: AR-LDAP-Person
    OID: c9d8e7f6-a5b4-4c3d-8e2f-1a0b9c8d7e6f
    Versión: 1.0 (2026-05-15)

    PROPÓSITO:
    Proyectar usuarios activos (lifecycleState=active) al OpenLDAP Identity Cache.
    Este rol hace el "puente" entre el modelo de identidad MidPoint y el LDAP.

    ARQUITECTURA OPCIÓN A (canónica UPeU):
    - UserTemplate-Person-Base asigna este rol mediante <assignmentTargetSearch>
      cuando el usuario pasa al estado lifecycleState=active.
    - El inducement en este AR hace el construction al resource LDAP.
    - SoD: solo usuarios active reciben este rol (política de lifecycle).

    CÓMO INTEGRAR (Fase 5 — hacer cuando haya usuarios activos para probar):
    1. Importar este XML en MidPoint PROD.
    2. En UserTemplate-Person-Base, agregar en el Bloque D (assignmentTargetSearch):
       <assignmentTargetSearch>
           <targetType>RoleType</targetType>
           <filter>
               <q:equal>
                   <q:path>name</q:path>
                   <q:value>AR-LDAP-Person</q:value>
               </q:equal>
           </filter>
           <assignmentProperties>
               <lifecycleState>active</lifecycleState>
           </assignmentProperties>
       </assignmentTargetSearch>
    3. Alternativamente, agregar condition en el inducement del template:
       <condition>
           <script>
               <code>focus.lifecycleState == 'active'</code>
           </script>
       </condition>

    NOTA DE DISEÑO:
    Opción B alternativa: agregar el construction directamente en UserTemplate-Person-Base
    con condition. Se elige este AR separado (Opción A) por:
    - Auditabilidad: visible como assignment explícito
    - Reutilización: en futuras universidades SciBack solo cambia el resource OID
    - SoD: se puede restringir quién puede asignar/revocar este AR
-->
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      oid="c9d8e7f6-a5b4-4c3d-8e2f-1a0b9c8d7e6f">

    <name>AR-LDAP-Person</name>
    <description>Application Role: proyecta al usuario activo en el OpenLDAP Identity Cache UPeU. Solo usuarios con lifecycleState=active deben tener este rol.</description>

    <!-- Archetype: ApplicationRole (para aparecer en el catálogo de roles correctamente) -->
    <assignment>
        <targetRef oid="00000000-0000-0000-0000-000000000321" type="ArchetypeType"/>
    </assignment>

    <!-- Inducement: construction al resource LDAP -->
    <!-- El inducement se activa cuando el foco (usuario) tiene este rol asignado -->
    <inducement>
        <construction>
            <resourceRef oid="7b4e1c2d-3f8a-4d6b-9e5c-0a1b2c3d4e5f" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
        </construction>
    </inducement>

    <!-- Política de lifecycle: este rol solo tiene sentido para usuarios active -->
    <!-- La condición se aplica en el template que lo asigna, no aquí -->

</role>
