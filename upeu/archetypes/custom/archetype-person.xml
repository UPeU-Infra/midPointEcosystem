<?xml version="1.0" encoding="UTF-8"?>
<!--
  Archetype: Person (built-in Evolveum)
  OID: 00000000-0000-0000-0000-000000000702 (built-in Evolveum, PATCH over existing)

  DECISION 2026-05-16: Person NO se usa como archetype structural para usuarios
  operacionales UPeU. Cada tipo de usuario tiene su propio archetype structural:
    - archetype-user-student     (3037fbd2-db02-4ffd-8b1a-83fab5e686aa)
    - archetype-user-alumni      (87552943-9600-493b-88ca-74b7d3ba93e4)
    - archetype-user-employee-staff   (6460facf-3abf-4851-966e-0c95aa1a6c46)
    - archetype-user-employee-faculty (c93083ca-f4c5-4704-acf4-d53b97c9556e)
    - etc.

  Cada archetype especifico tiene su propio ObjectTemplate (UserTemplate-<Tipo>)
  que hace includeRef al UserTemplate-Person-Base (855caaca-...).
  Por eso el objectTemplateRef en este archetype Person queda INACTIVO
  (los usuarios no reciben Person como archetype structural).

  Person se mantiene en DB porque es un built-in de MidPoint 4.9 — no se puede
  eliminar. Sus policy rules de trazabilidad se mantienen para documentacion
  historica pero NO se evaluan en usuarios operacionales (ninguno tiene Person
  como archetype desde 2026-05-16).

  Raiz del problema que motivo este cambio:
    Cuando un usuario aparecia en multiples resources (ej. trabajador que tambien
    es egresado), cada resource intentaba forzar un archetype structural distinto
    (Person vs archetype-user-employee-staff) → PolicyViolationException.
    La solucion es que cada resource asigne el archetype especifico de su tipo.

  F2 - Refactor inicial de Archetypes UPeU 2026-05
  F5 - Policy Rules de trazabilidad UPeU 2026-05-14
  F6 - Migracion a archetypes especificos por tipo 2026-05-16 (esta decision)
-->
<archetype xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
           xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
           xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
           oid="00000000-0000-0000-0000-000000000702">
    <name>Person</name>
    <description>Toda persona fisica vinculada a UPeU. Unico archetype structural permitido para UserType. Las afiliaciones (student/faculty/staff/alum/affiliate) se expresan como R-Affiliation-* roles, NO como archetypes distintos. Spec §3.1 + §4.2. Policy rules de trazabilidad F5 en inducement (audit log). Script rejectionReasons en Bloque G del Object Template.</description>
    <archetypePolicy>
        <display>
            <label>Persona UPeU</label>
            <pluralLabel>Personas UPeU</pluralLabel>
            <icon>
                <cssClass>fa fa-user</cssClass>
                <color>#0072b5</color>
            </icon>
        </display>
        <conflictResolution>
            <action>recompute</action>
        </conflictResolution>
        <!-- objectTemplateRef DESACTIVADO 2026-05-16:
             Person ya no se asigna como archetype structural a usuarios operacionales.
             Cada archetype especifico (archetype-user-student, -alumni, -employee-staff, etc.)
             tiene su propio template que hace includeRef al UserTemplate-Person-Base.
             Mantener este objectTemplateRef activo causaria que si algun usuario tuviera
             Person como archetype, recibiria el template base sin las extensiones especificas.
        <objectTemplateRef oid="855caaca-68c4-4f7f-8ff8-b4e35dd7d390" type="c:ObjectTemplateType"/> -->
    </archetypePolicy>

    <!-- ============================================================
         INDUCEMENT: POLICY RULE PR-RECORD-REJECTION
         Registra en audit log cuando un Person esta en estado draft/proposed.
         Action: solo record (trazabilidad en audit log MidPoint).

         El script que escribe rejectionReasons + rejectedAt en extension/sciback:
         esta en el Bloque G del Object Template (855caaca-68c4-4f7f-8ff8-b4e35dd7d390).
         Razon tecnica: objectState en inducement evalua el estado del archetype,
         no el foco. El mapping script en el template tiene acceso directo al foco
         y puede setear extension fields. MidPoint 4.9 verified.

         NO tiene target/construction: no induce privilegios (libro §8.4 compatible).
         ============================================================ -->
    <inducement>
        <policyRule>
            <name>PR-RECORD-REJECTION</name>
            <documentation>Registra en audit log cuando un Person esta en draft/proposed. El script de rejectionReasons va en Bloque G del Object Template. Spec §4.3 Pilar 4 - Import estricto.</documentation>
            <policyConstraints>
                <objectState>
                    <name>perfil-en-draft-o-proposed</name>
                    <filter>
                        <q:or>
                            <q:equal>
                                <q:path>lifecycleState</q:path>
                                <q:value>draft</q:value>
                            </q:equal>
                            <q:equal>
                                <q:path>lifecycleState</q:path>
                                <q:value>proposed</q:value>
                            </q:equal>
                        </q:or>
                    </filter>
                </objectState>
            </policyConstraints>
            <policyActions>
                <record/>
            </policyActions>
        </policyRule>
    </inducement>

    <!-- ============================================================
         INDUCEMENT: POLICY RULE PR-AUDIT-ACTIVE-GATE
         Registra en audit log la transicion hacia lifecycleState=active.
         El gate real es el Bloque F del Object Template.
         NO tiene target/construction: no induce privilegios.
         ============================================================ -->
    <inducement>
        <policyRule>
            <name>PR-AUDIT-ACTIVE-GATE</name>
            <documentation>Registra en audit log la transicion hacia active de cualquier Person. Informativo: confirma que el Bloque F del Object Template permitio la transicion. No duplica enforcement.</documentation>
            <policyConstraints>
                <transition>
                    <stateAfter>active</stateAfter>
                </transition>
            </policyConstraints>
            <policyActions>
                <record/>
            </policyActions>
        </policyRule>
    </inducement>

</archetype>
