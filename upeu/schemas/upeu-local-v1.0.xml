<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        oid="64ed4155-147f-4081-89db-8d7e451d9c00">
    <name>UPeU — Schema local extensiones LAMB v1.0</name>
    <description>Schema de extensión específico UPeU. Namespace: urn:upeu:midpoint:local. Atributos del ERP LAMB (Oracle) y particularidades institucionales UPeU que no aplican a otras universidades instituciones IGA.</description>
    <lifecycleState>active</lifecycleState>
    <definition>
        <xsd:schema
            xmlns:xsd="http://www.w3.org/2001/XMLSchema"
            xmlns:a="http://prism.evolveum.com/xml/ns/public/annotation-3"
            xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
            xmlns:tns="urn:upeu:midpoint:local"
            targetNamespace="urn:upeu:midpoint:local"
            elementFormDefault="qualified">

            <xsd:import namespace="http://prism.evolveum.com/xml/ns/public/annotation-3"/>
            <xsd:import namespace="http://midpoint.evolveum.com/xml/ns/public/common/common-3"/>

            <!-- UserExtensionType — extensiones locales UPeU. Todos xsd:string. -->
            <xsd:complexType name="UserExtensionType">
                <xsd:annotation>
                    <xsd:appinfo>
                        <a:extension ref="c:UserType"/>
                        <a:displayName>Datos locales UPeU (LAMB)</a:displayName>
                        <a:help>Extensión local v1.0. Campos del ERP Oracle LAMB específicos de UPeU. No reutilizable entre universidades instituciones IGA.</a:help>
                    </xsd:appinfo>
                </xsd:annotation>
                <xsd:sequence>

                    <!-- L1 — IDENTIFICADORES LAMB -->
                    <xsd:element name="lambIdPersona" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>ID LAMB (ID_PERSONA)</a:displayName><a:indexed>true</a:indexed><a:displayOrder>10</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L1b — PUESTO LAMB (PBAC Pilar 3) -->
                    <xsd:element name="lambPositionId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>ID Puesto LAMB (ID_PUESTO)</a:displayName><a:help>ID numérico del puesto activo en ENOC.PLLA_PUESTO. IIA: MOISES.TRABAJADOR_PUESTO (HASTA IS NULL). Usado por Bloque G del UserTemplate para assignmentTargetSearch al ServiceType Position. Indexed para correlación eficiente.</a:help><a:indexed>true</a:indexed><a:displayOrder>15</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L2 — ORGANIZACIÓN LAMB -->
                    <xsd:element name="depto" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Departamento (ID LAMB)</a:displayName><a:indexed>true</a:indexed><a:displayOrder>20</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L3 — PREVISIÓN SOCIAL (LAMB / RRHH) -->
                    <xsd:element name="lambSNP" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Régimen pensiones (ONP/AFP)</a:displayName><a:help>ONP|AFP</a:help><a:displayOrder>30</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="lambCUSSP" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Código seguro social (CUSSP)</a:displayName><a:displayOrder>40</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L4 — PARTICULARIDADES INSTITUCIONALES UPeU ADVENTISTA -->
                    <xsd:element name="lambFecMisionero" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de ordenación/misión</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>50</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L5 — FOTO INSTITUCIONAL (LAMB MinIO) -->
                    <xsd:element name="photoUrl" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>URL foto institucional (LAMB)</a:displayName><a:help>URL completo de la foto en MinIO institucional. Formato: https://lamb-files.upeu.edu.pe/lamb-academic/{ruta-relativa}. IIA: columna FOTO de ENOC.VW_TRABAJADOR (Oracle LAMB). Solo disponible para trabajadores.</a:help><a:displayOrder>60</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L6 — TIPO DE DOCUMENTO LAMB (campo de transporte) -->
                    <xsd:element name="lambDocType" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Tipo de documento LAMB (ID_TIPODOCUMENTO)</a:displayName><a:help>Código numérico de tipo de documento en ELISEO.VW_APS_EMPLEADO.ID_TIPODOCUMENTO. Campo de transporte: el Bloque J del UserTemplate lo convierte junto con upeu:lambDocNum (número raw) al contenedor canónico sciback:identityDocuments. Valores: 1=DNI, 4=CE, 7=PASSPORT, 22=PTP, 23=CPP, 24=DNI-menor, 31=CE-visa, 9=PASSPORT-2, 6=CE-2. 0/97/98/99=sin documento válido.</a:help><a:indexed>true</a:indexed><a:displayOrder>70</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L7 — NÚMERO DE DOCUMENTO LAMB (campo de transporte canónico) -->
                    <xsd:element name="lambDocNum" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation>
                            <xsd:appinfo>
                                <a:displayName>Número documento LAMB (transporte)</a:displayName>
                                <a:displayOrder>75</a:displayOrder>
                                <a:help>Número de documento raw desde Oracle LAMB (campo de transporte para Bloque J del object template). IIA: ELISEO.VW_APS_EMPLEADO.NUM_DOCUMENTO. El Bloque J lo combina con upeu:lambDocType para construir sciback:identityDocuments. No usar directamente en UI.</a:help>
                            </xsd:appinfo>
                        </xsd:annotation>
                    </xsd:element>

                    <!-- L10b — RÉGIMEN DOCENTE LAMB (TC/TP/DE) -->
                    <!-- IIA: MOISES.PERSONA_ACAD_REGIMEN.REGIMEN.
                         Valores: TC (Tiempo Completo), TP (Tiempo Parcial), DE (Dedicación Exclusiva).
                         Solo presente para ~509 docentes con entrada en PERSONA_ACAD_REGIMEN ESTADO='1'.
                         NULL para staff y para docentes sin entrada en esa tabla (~7,600+).
                         Informativo; no determina accesos. Inbound weak en trabajadores.xml. -->
                    <xsd:element name="docenteRegimen" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Régimen docente (TC/TP/DE)</a:displayName>
                            <a:help>Régimen de dedicación docente desde MOISES.PERSONA_ACAD_REGIMEN.REGIMEN. Vocabulario: TC=Tiempo Completo, TP=Tiempo Parcial, DE=Dedicación Exclusiva. Solo presente para ~509 docentes. IIA: MOISES.PERSONA_ACAD_REGIMEN (ESTADO=1, MAX por persona).</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>92</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L10 — CATEGORÍA DOCENTE LAMB (específico UPeU) -->
                    <!-- IIA: ENOC.CAT_DOCENTE.ID_CATEGORIA_DOCENTE.
                         Valores numéricos internos del sistema docente LAMB (1-5).
                         Solo presente para usuarios con primaryAffiliation=faculty.
                         Campo informativo; no determina accesos. -->
                    <xsd:element name="lambCategoriaDocente" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Categoría docente LAMB</a:displayName>
                            <a:help>Categoría docente interna UPeU (1-5) desde ENOC.CAT_DOCENTE.ID_CATEGORIA_DOCENTE. Solo para faculty.</a:help>
                            <a:displayOrder>90</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L8b — VISITA SMART WIFI (hook, fuente futura) -->
                    <!-- IIA futura: producto SciBack "Smart WiFi" (gestión de visitas para
                         universidades). Poblará este item vía resource inbound strong (mismo
                         patrón IIA que liveAffiliationWorker/Student). Single string que marca
                         una visita activa con vigencia (p.ej. token/folio de visita).
                         Estado hoy: null en todos los focos (no hay fuente todavía). Se incluye
                         como <source> en los mappings de existence/administrativeStatus de Koha;
                         al ser siempre null no altera el comportamiento actual. Cuando Smart WiFi
                         entre, los patrones visita se crearán/archivarán automáticamente sin
                         tocar Koha manualmente. Categoría Koha asociada: affiliate (Diseño B). -->
                    <xsd:element name="smartwifiGuest" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Visita Smart WiFi (vigencia)</a:displayName>
                            <a:help>Marca de visita activa gobernada por el producto SciBack Smart WiFi (fuente futura). Single string con folio/token de visita vigente. Null mientras no exista la fuente. Hace elegible el patrón Koha categoría affiliate. IIA: Smart WiFi (inbound strong, pendiente).</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>82</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L9 — ROL ANTERIOR POST-JUBILACIÓN -->
                    <!-- IIA: derivado por Bloque K del UserTemplate-Person-Base cuando
                         motivoCese='jubilacion' y la persona venía de staff o faculty.
                         Vocabulario controlado: staff|faculty.
                         Permite que Koha exponga extended_attribute FORMER_ROLE.
                         Solo se popula para jubilados puros (sin affiliation activa de mayor prioridad). -->
                    <xsd:element name="formerRole" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Rol anterior (post-jubilación)</a:displayName>
                            <a:help>Vocabulario controlado: staff|faculty. Setado por Bloque K cuando motivoCese=jubilacion y la persona venía de staff o faculty. Permite que Koha exponga extended_attribute FORMER_ROLE.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>85</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L11 — ARCHETYPE HINT LAMB (campo de transporte DC-001) -->
                    <!-- IIA: ELISEO.VW_APS_EMPLEADO JOIN ENOC.CAT_DOCENTE → UPEU_ARCHETYPE_NAME.
                         Valores: archetype-user-employee-faculty | archetype-user-employee-staff.
                         Propósito: fallback en Bloque D7 de UserTemplate-Person-Base cuando
                         sb:affiliations está vacío (caso jubilados nuevos sin historia previa).
                         El inbound en trabajadores.xml lo setea con strength=weak (sin condición
                         sobre ESTADO), garantizando que incluso jubilados (ESTADO='I') lo tengan.
                         El archetype-to-affiliations sigue retornando null para ESTADO='I';
                         este campo es solo el fallback de último recurso para D7.
                         Ticket: DC-001 (Fix Decision C — jubilados nuevos sin archetype). -->
                    <xsd:element name="lambArchetypeHint" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Archetype hint LAMB (transporte)</a:displayName>
                            <a:help>Nombre interno del archetype estructural según Oracle LAMB (archetype-user-employee-faculty | archetype-user-employee-staff). Campo de transporte para D7 del UserTemplate: fallback cuando sb:affiliations está vacío (jubilados nuevos sin historia previa en MidPoint). Setado por inbound en trabajadores.xml con strength=weak. No usar directamente en UI.</a:help>
                            <a:indexed>false</a:indexed>
                            <a:displayOrder>95</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L8 — MOTIVO DE CESE LAMB -->
                    <!-- IIA: ENOC.PLLA_CESE.ID_MOTIVO_CESE (enlazado por PLLA_CESE.APS = VW_APS_EMPLEADO.COD_APS).
                         Campo de transporte canónico: el resource Oracle LAMB Trabajadores hace LEFT JOIN
                         con ENOC.PLLA_CESE para traer el motivo del último cese registrado.
                         Vocabulario controlado normalizado (ver inbound en trabajadores.xml):
                           jubilacion        — PLLA_CESE.ID_MOTIVO_CESE IN ('05','18')
                           fallecimiento     — ID_MOTIVO_CESE = '09'
                           renuncia          — ID_MOTIVO_CESE IN ('01','21')
                           despido           — ID_MOTIVO_CESE = '03'
                           termino_contrato  — ID_MOTIVO_CESE = '07'
                           otro              — cualquier otro valor no nulo
                         Solo se popula cuando ESTADO='I' (inactivo) con motivo registrado.
                         El object template usa este campo para asignar AR-Koha-Jubilado
                         vía assignmentTargetSearch cuando motivoCese='jubilacion'.
                         Específico UPeU/LAMB: no reutilizable directamente entre universidades
                         (los códigos de cese son del ERP LAMB). El concepto semántico
                         ('jubilacion') sí es canónico. -->
                    <xsd:element name="motivoCese" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation>
                            <xsd:appinfo>
                                <a:displayName>Motivo de cese</a:displayName>
                                <a:help>Motivo normalizado del cese del empleado. Vocabulario: jubilacion|fallecimiento|renuncia|despido|termino_contrato|otro. IIA: ENOC.PLLA_CESE.ID_MOTIVO_CESE (JOIN por COD_APS). Solo presente cuando el empleado cesó con motivo registrado en LAMB. Vacío para empleados activos o ceses sin registro.</a:help>
                                <a:indexed>true</a:indexed>
                                <a:displayOrder>80</a:displayOrder>
                            </xsd:appinfo>
                        </xsd:annotation>
                    </xsd:element>

                    <!-- L12 — CALIDAD DE DATOS / VALIDACIÓN RENIEC -->
                    <!-- IIA primaria: Oracle LAMB RENIEC Cache v1 (DAVID.CONSULTA_APIS_LOG).
                         IIA secundaria: apiperu.dev (100 consultas/mes, tarea programada mensual).
                         El resource reniec-cache.xml setea dataQualityStatus y reniecValidationDate
                         como inbound durante reconciliación. manual_override nunca es sobreescrito
                         por proceso automático.
                         Se replica a OpenLDAP vía atributos auxiliares upeuPerson (objectClass). -->
                    <xsd:element name="dataQualityStatus" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Estado calidad datos (RENIEC)</a:displayName>
                            <a:help>Estado de validación de datos personales contra RENIEC. Vocabulario controlado: reniec_validated (CONTENT parseado OK, nombres coinciden o fueron actualizados) | mismatch (CONTENT parseado OK pero nombres difieren significativamente) | pending (sin consulta RENIEC aún) | manual_override (seteado por admin, no sobreescribir automáticamente). IIA: reniec-cache.xml inbound + apiperu.dev task mensual.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>200</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <xsd:element name="reniecValidationDate" type="xsd:dateTime" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Fecha validación RENIEC</a:displayName>
                            <a:help>Fecha y hora de la última consulta exitosa a RENIEC para este usuario. IIA: DAVID.CONSULTA_APIS_LOG.FECHA_REGISTRO (Oracle LAMB cache) o timestamp de llamada a apiperu.dev. Permite detectar validaciones obsoletas (ej: > 1 año) para re-validar con cuota mensual apiperu.dev.</a:help>
                            <a:displayOrder>201</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L13 — MARCADOR EMAIL SIN ENTRA ID -->
                    <!-- IIA: derivado por Bloque B del UserTemplate-Person-Base.
                         true cuando el usuario no tiene emailAddress proveniente de Entra ID.
                         Política 2026-06-06: MidPoint no inventa correos — si no hay email
                         en Entra ID, este flag marca al usuario para revisión manual por DTI.
                         El mapping B-email-review-flag lo setea normal (no weak) para que
                         se actualice a false cuando Entra ID finalmente provea el email. -->
                    <xsd:element name="emailReviewNeeded" type="xsd:boolean" minOccurs="0">
                        <xsd:annotation>
                            <xsd:appinfo>
                                <a:displayName>Email requiere revisión</a:displayName>
                                <a:help>true cuando el usuario no tiene email en Entra ID y requiere estudio manual. Seteado por el mapping B-email-review-flag del UserTemplate-Person-Base. Se limpia (false) automáticamente cuando Entra ID provee el email real.</a:help>
                                <a:indexed>true</a:indexed>
                                <a:displayOrder>95</a:displayOrder>
                            </xsd:appinfo>
                        </xsd:annotation>
                    </xsd:element>

                    <!-- L14 — FOTO M365 / ENTRA ID (campo dedicado, precedencia sobre LAMB) -->
                    <!-- IIA: Entra ID / Microsoft 365 (GET /users/{id}/photo/$value).
                         Poblado por el inbound 'entra-photo-to-entraPhoto-ext' en entra-id-graph.xml
                         (ri:photo → extension/upeu:entraPhoto, fetchStrategy=explicit).
                         REDISEÑO 2026-06-10: campo DEDICADO para evitar el strong-null destructivo
                         (un inbound strong directo a jpegPhoto BORRABA la foto LAMB de usuarios sin
                         foto M365). El Bloque I del UserTemplate-Person-Base elige la precedencia en
                         un solo chokepoint: si entraPhoto != null → jpegPhoto = entraPhoto (M365 gana);
                         si null → fallback fetch foto LAMB MinIO desde upeu:photoUrl. Nunca hay borrado.
                         base64Binary single. jpegPhoto se proyecta a LDAP (normal) + Koha (weak). -->
                    <xsd:element name="entraPhoto" type="xsd:base64Binary" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Foto M365 / Entra ID</a:displayName>
                            <a:help>Foto de perfil desde Microsoft 365 / Entra ID (binario JPEG/PNG). Poblada por inbound ri:photo en entra-id-graph.xml. Tiene precedencia sobre la foto LAMB MinIO: el Bloque I del UserTemplate-Person-Base usa entraPhoto si existe, si no hace fallback a upeu:photoUrl (LAMB). IIA: Entra ID / M365.</a:help>
                            <a:indexed>false</a:indexed>
                            <a:displayOrder>62</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- L14b — HASH DE IDEMPOTENCIA DE LA FOTO ENTRA (anti-bloat audit) -->
                    <!-- IIA: derivado (no es dato de negocio) — SHA-256 del JPEG normalizado
                         que el inbound 'entra-photo-to-entraPhoto-ext' produjo la última vez.
                         PROPÓSITO: idempotencia. En cada pasada del inbound se calcula el hash
                         del JPEG normalizado; si coincide con este valor previo, el inbound
                         RETORNA el binario actual (focus.entraPhoto) en vez de uno nuevo →
                         MidPoint (modelo de cambio relativo) NO genera delta MODIFY de foto →
                         no se infla ma_audit_delta_default. Solo cuando el hash cambia se
                         emite el binario nuevo y se actualiza este campo. Búsqueda en core:
                         NO existe atributo nativo para "hash de binario externo" → extensión
                         local legítima. xsd:string (hex SHA-256), single, NO indexado
                         (no se filtra por él). NO es PII. Schema local OID
                         64ed4155-147f-4081-89db-8d7e451d9c00, namespace urn:upeu:midpoint:local. -->
                    <xsd:element name="entraPhotoHash" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Hash foto M365 (idempotencia)</a:displayName>
                            <a:help>SHA-256 (hex) del JPEG normalizado de la foto M365/Entra ID producido por el inbound entra-photo-to-entraPhoto-ext. Campo de control de idempotencia: si el hash recalculado coincide, el inbound no re-emite el binario y no se genera delta MODIFY (evita bloat de auditoría). No es dato de negocio ni PII. No indexado.</a:help>
                            <a:indexed>false</a:indexed>
                            <a:displayOrder>63</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                </xsd:sequence>
            </xsd:complexType>

            <!-- OrgExtensionType — extensiones para OrgType (áreas organizacionales LAMB)
                 Namespace: urn:upeu:midpoint:local
                 Aplicable: OrgType (árbol de áreas sincronizado desde ELISEO.ORG_AREA)
                 Ola 2: resource oracle-lamb-org.xml (2026-05-26) -->
            <xsd:complexType name="OrgExtensionType">
                <xsd:annotation>
                    <xsd:appinfo>
                        <a:extension ref="c:OrgType"/>
                        <a:displayName>Datos locales UPeU — Área LAMB</a:displayName>
                        <a:help>Extensión local para OrgType: áreas organizacionales sincronizadas desde Oracle LAMB (ELISEO.ORG_AREA). No reutilizable directamente entre universidades (IDs LAMB son internos).</a:help>
                    </xsd:appinfo>
                </xsd:annotation>
                <xsd:sequence>

                    <!-- O1 — ID_AREA (inmutable, no reutilizable entre releases LAMB) -->
                    <xsd:element name="areaId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>ID Área LAMB</a:displayName>
                            <a:help>ELISEO.ORG_AREA.ID_AREA. Identificador numérico inmutable del área en el ERP LAMB. Mismo valor que OrgType.identifier. Indexed para assignmentTargetSearch en parentOrgRef y costCenter lookups.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>10</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- O2 — ID_DEPTO (código contable 8 dígitos, puede ser null) -->
                    <xsd:element name="orgDepto" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Código contable (ID_DEPTO)</a:displayName>
                            <a:help>ELISEO.ORG_SEDE_AREA.ID_DEPTO. Código de departamento 8 dígitos para integración contable. Solo presente si el área tiene entrada en ORG_SEDE_AREA. Formato: XXXXXXXX (8 dígitos, ej: 20010002).</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>20</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- O3 — TIPO_AREA (categoría del área para futuro mapeo a archetypes) -->
                    <xsd:element name="tipoArea" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Tipo de área LAMB</a:displayName>
                            <a:help>ELISEO.ORG_AREA.TIPO_AREA. Categoría interna LAMB del área. Ola 3: usada para mapeo dinámico a archetypes específicos (faculty/campus/vicerrectorado/etc.).</a:help>
                            <a:displayOrder>30</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- O4 — ID_SEDE (para filtros por campus Lima/Juliaca/Tarapoto) -->
                    <xsd:element name="sedeId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>ID Sede LAMB</a:displayName>
                            <a:help>ELISEO.ORG_SEDE.ID_SEDE referenciado via ORG_SEDE_AREA. Identifica la sede principal del área. Solo presente si el área tiene entrada en ORG_SEDE_AREA. Pilot Lima first.</a:help>
                            <a:displayOrder>40</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                </xsd:sequence>
            </xsd:complexType>

        </xsd:schema>
    </definition>
</schema>
