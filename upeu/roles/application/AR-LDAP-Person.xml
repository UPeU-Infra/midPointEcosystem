<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      oid="7c1a2b3d-4e5f-6a7b-8c9d-0e1f2a3b4c5d">
    <name>AR-LDAP-Person</name>
    <description>Application Role que provee cuenta LDAP en OpenLDAP (Identity Cache UPeU). Asignado vía inducement desde BR-* para todos los usuarios activos. Solo se crea shadow cuando lifecycleState=active.</description>
    <assignment>
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="7b4e1c2d-3f8a-4d6b-9e5c-0a1b2c3d4e5f" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
        </construction>
        <!-- Guard IGA: solo provisionar LDAP cuando el usuario tiene lifecycleState=active.
             Jubilados (archived), ex-trabajadores (suspended/archived) y cualquier otro
             estado inactivo quedan excluidos. Si lifecycleState es null se trata como active
             (comportamiento por defecto de MidPoint). Cuando el estado pase de active a
             otro valor, MidPoint deprovisionará la cuenta LDAP en el próximo recompute. -->
        <condition>
            <script>
                <code>focus?.lifecycleState == 'active' || focus?.lifecycleState == null</code>
            </script>
        </condition>
    </inducement>
</role>
