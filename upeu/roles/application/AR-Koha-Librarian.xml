<?xml version="1.0" encoding="UTF-8"?>
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="91b2cbcd-3db9-4e90-b72e-b874b3c48fa6">
    <name>AR-Koha-Librarian</name>
    <description>Application Role: personal del CRAI (biblioteca). Marca al patron Koha
        con el atributo extendido AREA=CRAI (extended_attributes), filtrable en la
        busqueda de usuarios del intranet de Koha. La categoria patron es ADMINIST
        (derivada por el resource desde primaryAffiliation=staff) — la categoria STAFF
        fue eliminada 2026-05-22 y unificada en ADMINIST. Los permisos de intranet
        se materializan en los roles de tier derivados del puesto de RR.HH.
        Fuente de verdad unica para "es personal CRAI".</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="e10a539a-cb7f-4c72-a19f-60f7f62e4b96" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <!-- 2026-05-22: el override category_id=STAFF fue eliminado. STAFF se
                 unifico en ADMINIST. Este rol ahora marca al patron con el par
                 AREA=CRAI dentro de extended_attributes (atributo multivaluado).
                 El resource koha-ils declara ri:extended_attributes como
                 tolerant=true + intolerantValuePattern "type":"AREA" → MidPoint
                 gobierna SOLO el par AREA:* y nunca pisa DNI/SEDE/otros pares.
                 El valor JSON debe coincidir con el formato que el conector
                 v1.3.0 produce al leer (PatronMapper.convertExtendedAttributes*). -->
            <attribute>
                <ref>ri:extended_attributes</ref>
                <outbound>
                    <name>area-crai-extended-attribute</name>
                    <strength>strong</strength>
                    <expression>
                        <value>{"type":"AREA","value":"CRAI"}</value>
                    </expression>
                </outbound>
            </attribute>
        </construction>
    </inducement>
</role>
