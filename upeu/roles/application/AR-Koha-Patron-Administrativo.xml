<?xml version="1.0" encoding="UTF-8"?>
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="a1b2c3d4-e5f6-7890-abcd-ef1234567803">
    <name>AR-Koha-Patron-Administrativo</name>
    <description>Application Role: cuenta patron trabajador administrativo no-biblioteca en Koha ILS. Categoría ADMINIST (8 chars, código real en Koha). Strength weak — cede ante STAFF (normal), POSGRADO (normal) y DOCEN (strong). Para usuarios con primaryAffiliation=staff que no tengan acceso a AR-Koha-Patron-Staff.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="9b5a7c81-47aa-42ac-9a08-4de8b64935af" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <!-- Override category_id: weak — cede ante STAFF (normal), POSGRADO (normal) y DOCEN (strong)
                 Código correcto en Koha: ADMINIST (máximo 8 chars, truncado de ADMINISTRATIVO) -->
            <attribute>
                <ref>ri:category_id</ref>
                <outbound>
                    <strength>weak</strength>
                    <expression><value>ADMINIST</value></expression>
                </outbound>
            </attribute>
        </construction>
    </inducement>
</role>
