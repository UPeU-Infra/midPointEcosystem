<?xml version="1.0" encoding="UTF-8"?>
<!--
  AR-Koha-Researcher — Application Role: marca investigador RENACYT en Koha
  OID: 02e7a70b-32e5-48c9-96ab-84ecdde119e2
  Versión: 1.0 (2026-05-25)
  Resource target: Koha ILS (OID: 9b5a7c81-47aa-42ac-9a08-4de8b64935af)
  Archetype: Application Role (OID: 279ad5be-a892-4add-946f-8cb3740bfc31)

  Propósito:
    Marca al patron Koha con el atributo extendido RESEARCHER=Y (extended_attributes).
    Ortogonal a primaryAffiliation: un usuario puede ser faculty/staff/student/alum
    Y simultáneamente researcher. NO altera el categorycode del patron.

  Diferencia con AR-Koha-Investigador:
    - AR-Koha-Investigador (OID 251f52db): override category_id=INVESTI (categoría legacy).
      Asignado a los 78 investigadores RENACYT actuales.
    - AR-Koha-Researcher (este rol): extended_attribute RESEARCHER=Y. Filtrable en
      búsquedas de Koha sin depender de categorycode. Preparación para Fase 8
      (drop categorías legacy; investigadores quedarán como 'faculty' + RESEARCHER=Y).

  Fase de activación:
    - Fase 2 (actual): crear rol + test 1 usuario.
    - Fase 8 post-migración categías: asignar masivamente, deprecar AR-Koha-Investigador.

  Patrón:
    Mismo patrón que AR-Koha-Librarian (AREA=CRAI). La mecánica tolerant/intolerant
    en koha-ils.xml garantiza que MidPoint gobierna SOLO el par RESEARCHER:*
    sin pisar DNI/SEDE/AREA/CRAI_TIER ni otros pares existentes en extended_attributes.

  Asignación:
    Manual para pruebas (Fase 2). Birthright via inducement en BR-Investigador
    (pendiente Fase 8 del plan de migración categorycodes Koha).
-->
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="02e7a70b-32e5-48c9-96ab-84ecdde119e2">
    <name>AR-Koha-Researcher</name>
    <description>Application Role: marca al patron Koha con extended_attribute RESEARCHER=Y. Ortogonal a primaryAffiliation y categorycode. Filtrable en busquedas Koha. Preparacion para Fase 8: reemplaza AR-Koha-Investigador (INVESTI legacy) con faculty + RESEARCHER=Y.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="9b5a7c81-47aa-42ac-9a08-4de8b64935af" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <!-- Marca al patron con RESEARCHER=Y en extended_attributes.
                 El resource koha-ils declara ri:extended_attributes como
                 tolerant=true + intolerantValuePattern incluyendo "type":"RESEARCHER"
                 → MidPoint gobierna SOLO el par RESEARCHER:* y nunca pisa
                 DNI/SEDE/AREA/CRAI_TIER ni otros pares existentes. -->
            <attribute>
                <ref>ri:extended_attributes</ref>
                <outbound>
                    <name>researcher-extended-attribute</name>
                    <strength>strong</strength>
                    <expression>
                        <value>{"type":"RESEARCHER","value":"Y"}</value>
                    </expression>
                </outbound>
            </attribute>
        </construction>
    </inducement>
</role>
