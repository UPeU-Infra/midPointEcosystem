<?xml version="1.0" encoding="UTF-8"?>
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="a1b2c3d4-e5f6-7890-abcd-ef1234567804">
    <name>AR-Koha-Patron-Alumni</name>
    <description>Application Role: cuenta patron egresado en Koha ILS. La categoría (ALUMNI) la deriva el mapping category-id-from-primary-affiliation del resource koha-ils (R5 FASE 4) cuando primaryAffiliation=alum: ya NO hay override por-rol. Para usuarios con primaryAffiliation=alum.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="9b5a7c81-47aa-42ac-9a08-4de8b64935af" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <!-- R5 (FASE 4): override category_id eliminado.
                 category_id lo resuelve el resource koha-ils desde
                 extension/sciback:primaryAffiliation (mapping unico, deterministico). -->
            <!-- FASE A deprovisioning canónico (Semancik Cap. 6 §6.4 — Existence and
                 Condition): no provisionar la cuenta Koha si el user está archived.
                 Defensa secundaria: la causa primaria de expiración es
                 <activation><validTo> en el assignment que genera el template
                 (Cap. 7 — Time-Constrained Roles). Esta cláusula <existence> protege
                 contra cualquier ruta de archivado del focus que no pase por validTo
                 (e.g. Bloque H del template: terminationDate > 180d para empleados
                 que también fueron alumni). lifecycleState archived ⇒ DELETE en
                 Koha (el conector v1.3.3 maneja correctamente el ciclo DELETE → 404
                 → re-create con fallback POST/GET cardnumber para 409). -->
            <existence>
                <expression>
                    <script>
                        <code>def ls = midpoint.focusObject?.lifecycleState; ls != 'archived' &amp;&amp; ls != 'failed'</code>
                    </script>
                </expression>
            </existence>
        </construction>
    </inducement>
</role>
