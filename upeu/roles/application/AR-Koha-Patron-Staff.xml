      oid="72589f9c-84d2-47d0-9412-9d2a6b9ef8e0">
    <name>AR-Koha-Patron-Staff</name>
    <description>Application Role: cuenta patron administrativo en Koha ILS (BUL/BUJ/BUT/CIA). Categoría patron Staff. ConnId Java conector custom UPeU. Construction activa — Fase 7.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="9b5a7c81-47aa-42ac-9a08-4de8b64935af" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <!-- Override category_id: normal — supera ESTUDI (weak) pero cede ante DOCEN (strong) -->
            <attribute>
                <ref>ri:category_id</ref>
                <outbound>
                    <strength>normal</strength>
                    <expression><value>STAFF</value></expression>
                </outbound>
            </attribute>
        </construction>
    </inducement>
</role>
