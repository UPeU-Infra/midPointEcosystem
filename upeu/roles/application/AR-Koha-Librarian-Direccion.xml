<?xml version="1.0" encoding="UTF-8"?>
<!--
  Application Role: AR-Koha-Librarian-Direccion
  OID: d3303cec-7b05-4415-a19d-84a1c899f4c4
  Versión: 1.0 (2026-05-22)

  Nivel de acceso CRAI "direccion" — Director / Coordinador de CRAI.
  Overlay individual de tier por cargo. NO marca pertenencia CRAI: la
  pertenencia la marca AR-Koha-Librarian (AREA=CRAI), asignado por el bloque Q4
  del template. Este rol solo escribe el par CRAI_TIER en extended_attributes
  del patrón Koha.

  Asignado por: UserTemplate-EmployeeStaff bloque Q5 (birthright cargo→tier)
  vía assignmentTargetSearch, resolviendo extension/upeu:lambPositionId contra
  el LookupTable LT-CRAI-Puesto-Tier.

  Construction: marca al patrón Koha con extended_attributes
  {"type":"CRAI_TIER","value":"direccion"}. El resource koha-ils declara
  ri:extended_attributes tolerant=true + intolerantValuePattern que cubre
  (AREA|CRAI_TIER) → MidPoint gobierna SOLO el par CRAI_TIER y nunca pisa
  AREA/DNI/SEDE/otros pares.
-->
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="d3303cec-7b05-4415-a19d-84a1c899f4c4">
    <name>AR-Koha-Librarian-Direccion</name>
    <description>Application Role: nivel de acceso CRAI "direccion" (Director / Coordinador de CRAI). Marca al patrón Koha con extended_attributes CRAI_TIER=direccion. Overlay individual por cargo, asignado por birthright Q5.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="e10a539a-cb7f-4c72-a19f-60f7f62e4b96" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <attribute>
                <ref>ri:extended_attributes</ref>
                <outbound>
                    <name>crai-tier-extended-attribute</name>
                    <strength>strong</strength>
                    <expression>
                        <value>{"type":"CRAI_TIER","value":"direccion"}</value>
                    </expression>
                </outbound>
            </attribute>
            <!-- FASE B (conector Koha v1.4.0): cuando v1.4.0 exista, agregar aqui dos
                 bloques attribute dentro de esta misma construction: uno para ri:flags
                 (bitmask borrowers.flags del nivel direccion) y otro para
                 ri:user_permissions (lista de permisos granulares del nivel). Valores
                 definitivos los fija koha-expert en Fase B. No incluir XML de ejemplo
                 en este comentario para no romper el parseo. -->
        </construction>
    </inducement>
</role>
