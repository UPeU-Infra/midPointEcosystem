<?xml version="1.0" encoding="UTF-8"?>
<!--
  AR-CRIS-OrgUnit — Application Role: cuenta OrgUnit (unidad de investigacion) en DSpace-CRIS
  OID: bdfe5f18-99f1-437b-80e6-ccffb52215ad
  Versión: 1.0 (2026-06-18)
  Resource target: DSpace-CRIS UPeU (OID 3f8b2d61-7c94-4a05-9e3b-6d1f8a2c5e70)
  Archetype: Application Role (OID 279ad5be-a892-4add-946f-8cb3740bfc31)

  ── PROBLEMA QUE RESUELVE ────────────────────────────────────────────────────────
    El objectType orgUnit de cris-dspace.xml (kind=generic intent=orgUnit, focus
    OrgType, default=true) define los outbound PerúCRIS (legalName, parentOrganization,
    tiposubunidad, esRaiz, ruc) pero NO tiene <construction> que lo bootstrappee. En
    MidPoint 4.10 un objectType default=true sin construction inducida NO se proyecta
    en un recompute focus-driven del OrgType (verificado: recompute/reconcile de DGI
    deja 0 shadows orgUnit). Hasta ahora los OrgUnit del CRIS se creaban solo on-demand
    (ensureMinimalOrgUnit) durante la proyeccion de Personas → OrgUnit MINIMOS (solo
    legalName+entity.type, sin tiposubunidad ni parentOrganization).

  ── ENFOQUE CANÓNICO: AR construction-driven (espejo de AR-CRIS-Person) ────────────
    Esta AR aporta la <construction> (kind=generic intent=orgUnit) que faltaba. Al
    asignarse a un foco OrgType, la construction entra al lensContext → la proyeccion
    orgUnit se instancia (bootstrap) → corren los outbound del resource (legalName,
    parentOrganizationName, tiposubunidad por archetype, esRaiz, ruc) → el connector
    hace upsert idempotente por organization.legalName (Update-no-create si existe).
    Asi los 3 CII minimos auto-creados quedan ENRIQUECIDOS, no duplicados.
    midpoint-best-practices §4.5 (outbound phase consolida constructions de inducements),
    §2.3/§2.4 (application role = 1 app, 1 construction).

  ── GATE: condición del INDUCEMENT (unidades de investigación) ─────────────────────
    La construction solo aplica si el OrgType holder es una unidad de investigacion:
      (A) archetype org-research-center (6b1d9a4e-…) = los 7 CII
      (B) archetype org-research-line   (7c2e0b5f-…) = las 178 lineas
      (C) la propia DGI (identifier=69) = la direccion raiz de investigacion
    Asi, aunque por error se asignara a una org administrativa, no proyectaria.
    iga-canonical-standards §10.2/§10.3; midpoint-best-practices §4.2/§7 (conditions
    on inducements). El focus aqui es el propio OrgType (no hay "holder" persona).

  ── ASIGNACIÓN (ejecución acotada DGI) ─────────────────────────────────────────────
    Se asigna por direct-assignment a los OrgType del subtree DGI (DGI + 7 CII + 178
    lineas = 186). La asignacion explicita es el control de alcance; el gate es defensa
    en profundidad. NO se autoasigna (el ecosistema no usa autoassign para esto).

  Patrón IGA SciBack reutilizable: "AR construction-driven para proyectar OrgType de
  investigacion a un CRIS PerúCRIS-compliant".
-->
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="bdfe5f18-99f1-437b-80e6-ccffb52215ad">
    <name>AR-CRIS-OrgUnit</name>
    <description>Application Role: proyecta la cuenta OrgUnit (unidad de investigacion) en DSpace-CRIS. Aporta la construction (kind=generic intent=orgUnit) que faltaba al objectType orgUnit de cris-dspace.xml para que el lens bootstrappee la proyeccion del OrgType con metadata PeruCRIS rica (legalName, parentOrganization, tiposubunidad por archetype, esRaiz, ruc). Gate: solo unidades de investigacion (research-center, research-line, o DGI). Upsert idempotente por organization.legalName. Espejo de AR-CRIS-Person.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="3f8b2d61-7c94-4a05-9e3b-6d1f8a2c5e70" type="ResourceType"/>
            <kind>generic</kind>
            <intent>orgUnit</intent>
            <!-- Sin <attribute> override: los outbound (legalName/parentOrganizationName/
                 tiposubunidad/esRaiz/ruc) viven en el objectType orgUnit del resource.
                 Esta construction solo instancia la proyeccion. -->
        </construction>
        <!-- GATE UNIDAD DE INVESTIGACIÓN — defensa en profundidad. El foco es el propio
             OrgType. Si no es CII, LINEA ni DGI, la condicion es false → no proyecta. -->
        <condition>
            <expression>
                <script>
                    <code><![CDATA[
def RESEARCH_CENTER = '6b1d9a4e-2f53-4c8a-bf17-9d0c6e2a4b81'  // org-research-center (7 CII)
def RESEARCH_LINE   = '7c2e0b5f-3a64-4d9b-c028-ae1d7f3b5c92'  // org-research-line (178 lineas)
// (A)(B) por archetype del propio OrgType
def archRefs = (focus?.archetypeRef instanceof Collection) ? focus.archetypeRef
               : (focus?.archetypeRef == null ? [] : [focus.archetypeRef])
for (a in archRefs) {
    def oid = a?.getOid()
    if (RESEARCH_CENTER.equals(oid) || RESEARCH_LINE.equals(oid)) return true
}
// (C) la propia DGI (direccion raiz de investigacion) por identifier
if ('69'.equals(focus?.identifier)) return true
return false
                    ]]></code>
                </script>
            </expression>
        </condition>
    </inducement>
</role>
