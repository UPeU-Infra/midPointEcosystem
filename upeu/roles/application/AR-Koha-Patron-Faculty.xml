<?xml version="1.0" encoding="UTF-8"?>
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="3294189e-958f-447d-a07b-83f986a7a1c7">
    <name>AR-Koha-Patron-Faculty</name>
    <description>Application Role: cuenta patron docente en Koha ILS — bases académicas, préstamos extendidos. Categoría patron Faculty. ConnId Java conector custom UPeU. Construction activa — Fase 7.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="9b5a7c81-47aa-42ac-9a08-4de8b64935af" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <!-- Override category_id: código de categoría Koha para docentes -->
            <attribute>
                <ref>ri:category_id</ref>
                <outbound>
                    <strength>strong</strength>
                    <expression><value>DOCEN</value></expression>
                </outbound>
            </attribute>
        </construction>
    </inducement>
</role>
