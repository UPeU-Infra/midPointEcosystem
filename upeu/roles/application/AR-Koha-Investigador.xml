<?xml version="1.0" encoding="UTF-8"?>
<!--
  AR-Koha-Investigador — Application Role para investigadores DGI en Koha ILS
  OID: 251f52db-af86-435d-9307-cc18ee0c3fa8
  Versión: 1.0 (2026-05-24)
  Resource target: Koha ILS (OID: 9b5a7c81-47aa-42ac-9a08-4de8b64935af)
  Archetype: Application Role (OID: 279ad5be-a892-4add-946f-8cb3740bfc31)

  Propósito:
    Asigna la categoría INVESTI en Koha para investigadores RENACYT/DGI.
    Los investigadores DGI son docentes (primaryAffiliation=faculty) cuya
    condición de investigador es ADICIONAL a su rol docente. Sin este override,
    el mapping category-id-from-primary-affiliation del resource les asignaría
    DOCEN (correcto por afiliación) pero no INVESTI (correcto por investigación).

  Fuente autoritativa:
    Lista anual Excel DGI (Charmín Wilter) — 97 investigadores RENACYT 2026.
    Pendiente: Resource CSV MidPoint que lea el Excel y asigne este rol
    como birthright vía assignmentTargetSearch en el object template.
    Mientras tanto: asignación manual o via importación CSV ad-hoc.

  Construcción:
    Override fuerte de category_id=INVESTI. Prevalece sobre el mapping
    category-id-from-primary-affiliation del resource (strength=strong en
    koha-ils.xml) porque el evaluador de construcciones MidPoint consolida
    primero los valores de inducements de rol.

  Expiración:
    Sin override de expiry_date. La lista DGI se actualiza anualmente;
    cuando un investigador es removido de la lista, su rol se desasigna
    y Koha recibe la categoría base (DOCEN) por el mapping del resource.

  Patrón IGA: rol birthright por lista externa (CSV/Excel anual).
  Reutilizable para otras universidades con padrones RENACYT/CONCYTEC.
-->
<role xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="251f52db-af86-435d-9307-cc18ee0c3fa8">
    <name>AR-Koha-Investigador</name>
    <description>Application Role: cuenta patron investigador RENACYT/DGI en Koha ILS. Override de category_id=INVESTI. Los investigadores son docentes (faculty) cuya condición de investigador se acredita por lista anual DGI. Asignado desde Resource CSV DGI (pendiente) o manualmente. Prevalece sobre el mapping category-id-from-primary-affiliation del resource koha-ils. Excepción: si motivoCese=jubilacion, retorna null para que AR-Koha-Jubilado imponga JUBILADO sin conflicto de strong mappings.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <!-- Archetype: Application role (OID canónico PROD) -->
        <targetRef oid="279ad5be-a892-4add-946f-8cb3740bfc31" relation="org:default" type="ArchetypeType"/>
    </assignment>
    <inducement>
        <construction>
            <resourceRef oid="9b5a7c81-47aa-42ac-9a08-4de8b64935af" type="ResourceType"/>
            <kind>account</kind>
            <intent>default</intent>
            <!-- Override category_id=INVESTI.
                 Prevalece sobre el mapping category-id-from-primary-affiliation del resource
                 (que asignaría DOCEN para los docentes-investigadores).
                 Un docente que es investigador DGI debe tener INVESTI en Koha,
                 no DOCEN, para acceder a los servicios diferenciados de investigación.
                 Excepción: si el usuario es jubilado (motivoCese=jubilacion), retorna null
                 para que el inducement de AR-Koha-Jubilado sea el único valor strong
                 y JUBILADO prevalezca (jubilado-investigador → JUBILADO, no INVESTI). -->
            <attribute>
                <ref>ri:category_id</ref>
                <outbound>
                    <name>investigador-category-override</name>
                    <strength>strong</strength>
                    <source>
                        <path xmlns:upeu="urn:upeu:midpoint:local">$focus/extension/upeu:motivoCese</path>
                    </source>
                    <expression>
                        <script>
                            <code>def motive = motivoCese != null ? basic.stringify(motivoCese).trim().toLowerCase() : ''; if (motive == 'jubilacion') return null; return 'INVESTI'</code>
                        </script>
                    </expression>
                </outbound>
            </attribute>
        </construction>
    </inducement>
</role>
