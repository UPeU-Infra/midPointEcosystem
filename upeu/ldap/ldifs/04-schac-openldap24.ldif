# 04-schac-openldap24.ldif — Schema SCHAC para OpenLDAP 2.4.x (osixia format)
# Compatible con OpenLDAP 2.4.57 (osixia/openldap:1.5.0)
# OID arc SCHAC: 1.3.6.1.4.1.25178
#
# IMPORTANTE: Las continuaciones de línea en cn=config ldapadd deben usar
# exactamente un espacio al inicio de la línea de continuación.
# Las definiciones largas deben estar en UNA sola línea lógica.
#
# Aplicar: ldapadd -Y EXTERNAL -H ldapi:/// -f /tmp/04-schac-openldap24.ldif

dn: cn={10}schac,cn=schema,cn=config
changetype: modify
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.15 NAME 'schacPersonalUniqueID' DESC 'SCHAC unique person identifier (national ID, passport)' EQUALITY caseExactMatch SUBSTR caseExactSubstringsMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.14 NAME 'schacPersonalUniqueCode' DESC 'SCHAC unique code assigned by institution' EQUALITY caseExactMatch SUBSTR caseExactSubstringsMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.9 NAME 'schacHomeOrganization' DESC 'SCHAC domain name of persons home organization' EQUALITY caseIgnoreMatch SUBSTR caseIgnoreSubstringsMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 SINGLE-VALUE )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.10 NAME 'schacHomeOrganizationType' DESC 'SCHAC type of home organization' EQUALITY caseIgnoreMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.3 NAME 'schacDateOfBirth' DESC 'SCHAC date of birth YYYYMMDD' EQUALITY numericStringMatch ORDERING numericStringOrderingMatch SUBSTR numericStringSubstringsMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.36 SINGLE-VALUE )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.2 NAME 'schacGender' DESC 'SCHAC gender ISO 5218' EQUALITY integerMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.27 SINGLE-VALUE )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.5 NAME 'schacCountryOfCitizenship' DESC 'SCHAC country of citizenship ISO 3166-1 alpha-2' EQUALITY caseIgnoreMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.20 NAME 'schacUserPresenceID' DESC 'SCHAC identifier in external presence system' EQUALITY caseExactMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 )
-
add: olcAttributeTypes
olcAttributeTypes: ( 1.3.6.1.4.1.25178.1.2.19 NAME 'schacExpiryDate' DESC 'SCHAC expiry date of account or affiliation' EQUALITY generalizedTimeMatch ORDERING generalizedTimeOrderingMatch SYNTAX 1.3.6.1.4.1.1466.115.121.1.24 SINGLE-VALUE )
-
add: olcObjectClasses
olcObjectClasses: ( 1.3.6.1.4.1.25178.1.1.2 NAME 'schacPersonalCharacteristics' DESC 'SCHAC personal characteristics' SUP top AUXILIARY MAY ( schacPersonalUniqueID $ schacPersonalUniqueCode $ schacDateOfBirth $ schacGender $ schacCountryOfCitizenship $ schacUserPresenceID $ schacExpiryDate ) )
-
add: olcObjectClasses
olcObjectClasses: ( 1.3.6.1.4.1.25178.1.1.4 NAME 'schacLinkageIdentifiers' DESC 'SCHAC linkage identifiers' SUP top AUXILIARY MAY ( schacPersonalUniqueID $ schacPersonalUniqueCode ) )
-
add: olcObjectClasses
olcObjectClasses: ( 1.3.6.1.4.1.25178.1.1.7 NAME 'schacEntryMetadata' DESC 'SCHAC entry metadata' SUP top AUXILIARY MAY ( schacHomeOrganization $ schacHomeOrganizationType $ schacExpiryDate ) )
