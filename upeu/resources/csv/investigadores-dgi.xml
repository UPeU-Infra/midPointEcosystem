<?xml version="1.0" encoding="UTF-8"?>
<!--
  Resource CSV: Investigadores DGI UPeU (RENACYT)
  OID: a7c4f219-b3e8-4d6a-9f12-3e5a7c8b2d1f
  Versión: 1.0 (2026-05-26)
  Conector: CSV Connector v2.8 (OID: 28bbe21c-8fa9-4b8e-b784-4633b96f83c9)

  Propósito:
    Fuente parcial de enriquecimiento. Lee el archivo CSV anual generado por
    la Dirección General de Investigación (Charmín Wilter) con los 97 DNIs
    de investigadores activos RENACYT en las 3 sedes (Lima/Juliaca/Tarapoto).

    Para cada DNI encontrado, correlaciona el usuario MidPoint por taxId (URN
    SCHAC) y asigna el rol AR-Koha-Investigador (OID: 251f52db-af86-435d-9307-cc18ee0c3fa8).
    Este rol override la categorycode de Koha a INVESTI.

    Cuando un investigador deja el padrón RENACYT, se elimina del CSV. En el
    siguiente reconcile, su shadow queda como "deleted" y MidPoint retira
    automáticamente la asignación de AR-Koha-Investigador (mapped assignment).
    Su Koha categorycode vuelve a la base (DOCEN para faculty, según el
    mapping category-id-from-primary-affiliation del resource koha-ils).

  Flujo anual:
    1. DGI (Charmín) actualiza el Excel de investigadores
    2. Ejecutar: python3 generate-investigadores-csv.py > investigadores-dgi-2026.csv
    3. Hacer git add + commit + push del CSV generado
    4. En PROD: git pull + cp al container
    5. Lanzar reconciliación de este resource

  Archivo CSV fuente:
    /opt/midpoint/var/import/investigadores-dgi-YYYY.csv
    Columnas: DNI (unique), NOMBRE, CAMPUS
    Header en fila 1. Encoding UTF-8.

  Correlación:
    DNI normalizado a URN SCHAC → correlate por extension/sb:taxId
    (mismo patrón que grados.xml, egresados.xml)

  Assigned roles:
    linked/unlinked → AR-Koha-Investigador (OID: 251f52db-af86-435d-9307-cc18ee0c3fa8)
    deleted → remove AR-Koha-Investigador (mapped assignment cleanup automático)

  MidPoint Book cap. 9: partial source / enrichment resource.
  NO crea usuarios, NO modifica lifecycleState, NO toca activation.
-->
<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
    xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
    xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
    xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
    xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    oid="a7c4f219-b3e8-4d6a-9f12-3e5a7c8b2d1f">
    <name>CSV DGI Investigadores RENACYT v1</name>
    <description>Fuente parcial de enriquecimiento. Lee CSV anual DGI (Charmín Wilter) con DNIs de 97 investigadores RENACYT UPeU (Lima/Juliaca/Tarapoto). Asigna AR-Koha-Investigador a usuarios ya existentes correlacionados por taxId (DNI). NO crea usuarios. Flujo anual: Excel DGI → CSV → git push → docker cp → reconcile.</description>
    <lifecycleState>proposed</lifecycleState>
    <connectorRef oid="28bbe21c-8fa9-4b8e-b784-4633b96f83c9" relation="org:default" type="c:ConnectorType"/>
    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:resultsHandlerConfiguration>
            <icfc:enableNormalizingResultsHandler>false</icfc:enableNormalizingResultsHandler>
            <icfc:enableFilteredResultsHandler>false</icfc:enableFilteredResultsHandler>
            <icfc:enableAttributesToGetSearchResultsHandler>false</icfc:enableAttributesToGetSearchResultsHandler>
        </icfc:resultsHandlerConfiguration>
        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/com.evolveum.polygon.connector-csv/com.evolveum.polygon.connector.csv.CsvConnector">
            <!-- Ruta al CSV dentro del container MidPoint -->
            <cfg:filePath>/opt/midpoint/var/import/investigadores-dgi-2026.csv</cfg:filePath>
            <!-- DNI es el identificador único de cada fila -->
            <cfg:uniqueAttribute>DNI</cfg:uniqueAttribute>
            <!-- El CSV tiene header en la primera fila -->
            <!-- encoding UTF-8, separador coma por defecto -->
        </icfc:configurationProperties>
    </connectorConfiguration>
    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>default</intent>
            <displayName>Investigador RENACYT (CSV DGI)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
                <!-- Sin archetypeRef: fuente parcial, no define naturaleza del user.
                     Los investigadores ya tienen archetype estructural (faculty/staff)
                     asignado por Oracle LAMB Trabajadores. -->
            </focus>
            <attribute>
                <ref>ri:DNI</ref>
                <!-- DNI → extension/sb:taxId en forma URN SCHAC, fase beforeCorrelation.
                     Normaliza el valor ANTES de que el correlator evalúe.
                     Idéntico patrón a grados.xml (dni-to-taxId-urn). -->
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def d = (input ?: '').toString().trim(); d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
                <!-- Inbound que asigna AR-Koha-Investigador cuando el usuario está
                     en el CSV (linked). Cuando desaparece del CSV (deleted), MidPoint
                     retira automáticamente el mapped assignment (comportamiento
                     estándar de inbound con target=assignment). -->
                <inbound>
                    <name>csv-dgi-assign-ar-koha-investigador</name>
                    <strength>strong</strength>
                    <expression>
                        <assignmentTargetSearch>
                            <targetType>c:RoleType</targetType>
                            <oid>251f52db-af86-435d-9307-cc18ee0c3fa8</oid>
                            <!-- AR-Koha-Investigador -->
                        </assignmentTargetSearch>
                    </expression>
                    <target>
                        <path>assignment</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NOMBRE</ref>
                <!-- Sin inbound: el nombre canónico viene de Oracle LAMB.
                     NOMBRE en el CSV es solo para diagnóstico/verificación. -->
            </attribute>
            <attribute>
                <ref>ri:CAMPUS</ref>
                <!-- Sin inbound: el campus viene de Oracle LAMB (locality).
                     CAMPUS en el CSV es solo para trazabilidad. -->
            </attribute>
            <correlation>
                <!-- Correlator por taxId: mismo patrón que grados.xml y egresados.xml.
                     El inbound dni-to-taxId-urn normaliza el DNI a URN SCHAC
                     en fase beforeCorrelation antes de que este correlator evalúe. -->
                <correlators>
                    <items>
                        <name>correlate-by-taxId</name>
                        <item>
                            <ref xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>
            <synchronization>
                <!-- FUENTE PARCIAL DE ENRIQUECIMIENTO:
                     Solo enriquece usuarios existentes (faculty en Oracle LAMB).
                     linked → synchronize: re-asigna AR-Koha-Investigador si hay cambios.
                     unlinked → link: vincula el shadow al usuario ya existente.
                     unmatched → no action: DNI no encontrado en MidPoint → ignorar.
                       (investigador externo, DNI errado o aún no onboarded)
                     deleted → no action: la fila desapareció del CSV → el mapped
                       assignment ya elimina AR-Koha-Investigador automáticamente.
                       No desactivar al usuario (decisión de las fuentes primarias). -->
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <!-- sin actions: investigador no encontrado en MidPoint → ignorar -->
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <!-- sin actions: el mapped assignment cleanup es automático;
                         no inactivar el usuario -->
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>
    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create>
                <cap:enabled>false</cap:enabled>
            </cap:create>
            <cap:update>
                <cap:enabled>false</cap:enabled>
            </cap:update>
            <cap:delete>
                <cap:enabled>false</cap:enabled>
            </cap:delete>
        </configured>
    </capabilities>
    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>
</resource>
