            <!-- ================================================================
                 INBOUND — lectura Entra ID → MidPoint (Fase 1, preservado)
                 Strength weak: MidPoint no sobrescribe si Oracle LAMB ya proveyó.
                 ================================================================ -->
            <attribute>
                <ref>icfs:name</ref>
                <!-- UPN como fuente de username (split en @) -->
                <inbound>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>input ? input.toString().split("@")[0] : null</code>
                        </script>
                    </expression>
                    <target>
                        <path>$user/name</path>
                    </target>
                </inbound>
                <!-- UPN completo como emailAddress institucional — WEAK fallback.
                     WEAK (fix 2026-06-06b): algunos usuarios tienen UPN ≠ ri:mail
                     (ej. jorgemaquera@ vs jorge.maquera@). ri:mail es el campo canónico
                     M365; UPN es el login que puede diferir. Con STRONG+STRONG conflicto
                     "2 values". Cambiado a WEAK: ri:mail STRONG gana si existe; si no hay
                     ri:mail, este WEAK se aplica como fallback.
                     GUARD idéntico: descarta numéricos y no-upeu. -->
                <inbound>
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim().toLowerCase(); if (!v.endsWith('@upeu.edu.pe')) return null; def local = v.substring(0, v.indexOf('@')); return local ==~ /\d+/ ? null : v</code>
                        </script>
                    </expression>
                    <target>
                        <path>$user/emailAddress</path>
                    </target>
                </inbound>
                <!-- OUTBOUND ELIMINADO (2026-05-28): el outbound UPN provocaba que el
                     clockwork construyera el shadow Entra ID a crear. Inbound-only hasta Fase 12.
                     Para reactivar: restaurar el <outbound> UPN desde git history. -->
