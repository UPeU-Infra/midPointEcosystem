<?xml version="1.0" encoding="UTF-8"?>
<!--
  Resource: LAMB-Oracle-Investigacion-DGI-Org v1.0
  OID: 5a3d7e92-4c61-4b8f-9a02-7e1c3d6b2f84

  Pilar — Estructura REAL de investigación UPeU como ramas nuevas del árbol OrgType,
  colgando de la Dirección General de Investigación (DGI, ID_AREA=69, ya existente en
  MidPoint como OrgType identifier=69 / name=DIR-INVESTIGACION-E-INNOVACION).

  Fuente (Oracle LAMB, schema ESTHER, SOLO LECTURA):
    - ESTHER.DGI_CENTRO_INVESTIGACION  → 7 Centros de Investigación e Innovación (CII).
        CIIDE(3), CIIEC(5), CIISA(6), CIITI(7), CIIT(8), CIIA(9), CIIG(10). ESTADO='1'.
    - ESTHER.DGI_LINEA_INVESTIGACION   → 185 líneas (FK ID_CENTRO_INVESTIGACION).
        Solo se ingieren las ESTADO='1' (~178 activas).

  Modelo canónico (iga-canonical-standards §10.2 + skill midpoint-best-practices §5):
    Cada Centro CII  = 1 OrgType  archetype-org-research-center (6b1d9a4e-...).
    Cada Línea       = 1 OrgType  archetype-org-research-line   (7c2e0b5f-...).
    Jerarquía vía assignment al padre (NO inducement — org tree = assignments):
        Centro CII   → parent = DGI (OrgType identifier=69).
        Línea        → parent = su Centro CII (OrgType identifier = CII-{idCentro}).
    Mismo patrón que oracle-lamb/org.xml (generic synchronization, Semančík cap.10.6).

  Naming / identifiers persistentes (skill §5.2 — identifier separado de name):
    Centro:  __UID__ = 'CII-' || ID_CENTRO_INVESTIGACION   identifier = mismo
             name    = 'CII-' || ID_CENTRO_INVESTIGACION    displayName = NOMBRE LAMB
    Línea:   __UID__ = 'LINEA-' || ID_LINEA_INVESTIGACION   identifier = mismo
             name    = 'LINEA-' || ID_LINEA_INVESTIGACION   displayName = NOMBRE LAMB
    El UID inmutable evita identificadores human-friendly (skill §4.4 / regla de oro 10).

  Archetype: asignado por inbound (assignmentTargetSearch a ArchetypeType) discriminado
  por el tipo de fila (CII vs LINEA). Esto difiere de oracle-lamb/org.xml (que delega al
  OrgTemplate-Area) porque aquí el tipo es DETERMINÍSTICO por la fila de origen, no por
  TIPO_AREA ambiguo. El OrgTemplate-Area solo asigna org-department cuando archetypeRef
  está vacío, así que NO colisiona: estas orgs ya llegan archetipadas.

  PerúCRIS tiposubunidad (lo emite el outbound CRIS, NO se almacena aquí):
    research-center → #unidadDeInvestigacionOInnovacion
    research-line   → #lineaDeInvestigacion

  Solo inbound. Capabilities create/update/delete=false (Oracle LAMB solo-lectura absoluta).

  Reactions:
    unmatched → addFocus (crea OrgType nuevo)
    unlinked  → link
    linked    → synchronize (actualiza displayName)
    deleted   → inactivateFocus (centro/línea dado de baja → archived, no borrar por cascada)

  Historial: v1.0 2026-06-17 — Fase 5 CRIS. lifecycleState=proposed hasta validar recon.
-->
<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
    xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
    xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
    xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
    xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
    xmlns:upeu="urn:upeu:midpoint:local"
    oid="5a3d7e92-4c61-4b8f-9a02-7e1c3d6b2f84">

    <name>Oracle LAMB Investigacion DGI (Org)</name>
    <description>Inbound ScriptedSQL desde ESTHER.DGI_CENTRO_INVESTIGACION + ESTHER.DGI_LINEA_INVESTIGACION. Crea las ramas de investigación del árbol OrgType: 7 Centros CII (research-center) colgando de DGI(69) + sus líneas (research-line) colgando de cada CII. Jerarquía vía assignmentTargetSearch por identifier. focus=OrgType (IIA Patrón B). Fase 5 CRIS (2026-06-17).</description>
    <lifecycleState>proposed</lifecycleState>

    <!-- Mismo connector ScriptedSQL Tirasa que los otros LAMB resources -->
    <connectorRef oid="e4cd8ed3-2e91-48d9-abb7-32090a5e8849" relation="org:default" type="c:ConnectorType"/>

    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:resultsHandlerConfiguration>
            <icfc:enableNormalizingResultsHandler>false</icfc:enableNormalizingResultsHandler>
            <icfc:enableFilteredResultsHandler>false</icfc:enableFilteredResultsHandler>
            <icfc:filteredResultsHandlerInValidationMode>true</icfc:filteredResultsHandlerInValidationMode>
            <icfc:enableAttributesToGetSearchResultsHandler>false</icfc:enableAttributesToGetSearchResultsHandler>
        </icfc:resultsHandlerConfiguration>

        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/net.tirasa.connid.bundles.db.scriptedsql/net.tirasa.connid.bundles.db.scriptedsql.ScriptedSQLConnector">
            <cfg:host>192.168.13.9</cfg:host>
            <cfg:port>1521</cfg:port>
            <cfg:user>JUANSANCHEZ</cfg:user>
            <!-- Password cifrado igual que en los otros LAMB resources (misma instancia Oracle) -->
            <cfg:password>
                <t:encryptedData>
                    <t:encryptionMethod>
                        <t:algorithm>http://www.w3.org/2001/04/xmlenc#aes256-cbc</t:algorithm>
                    </t:encryptionMethod>
                    <t:keyInfo>
                        <t:keyName>nkZ4VieDLlRmwD8hdryrmjz8IxQ=</t:keyName>
                    </t:keyInfo>
                    <t:cipherData>
                        <t:cipherValue>5PiBLf405M3U4ulm9p6WfqMMVVwtOcVl5PuL6/CqPRMTmbA5Aoa/axj4ks8onfI2</t:cipherValue>
                    </t:cipherData>
                </t:encryptedData>
            </cfg:password>
            <cfg:database>UPEU</cfg:database>
            <cfg:jdbcDriver>oracle.jdbc.OracleDriver</cfg:jdbcDriver>
            <cfg:jdbcUrlTemplate>jdbc:oracle:thin:@%h:%p/%d</cfg:jdbcUrlTemplate>
            <cfg:rethrowAllSQLExceptions>true</cfg:rethrowAllSQLExceptions>
            <cfg:nativeTimestamps>true</cfg:nativeTimestamps>
            <cfg:allNative>false</cfg:allNative>
            <cfg:scriptingLanguage>GROOVY</cfg:scriptingLanguage>
            <cfg:reloadScriptOnExecution>false</cfg:reloadScriptOnExecution>

            <!--
              searchScript — UNION de Centros (KIND='CII') y Líneas activas (KIND='LINEA').
              Columnas comunes:
                ROW_KIND  : 'CII' | 'LINEA'
                ROW_ID    : ID_CENTRO_INVESTIGACION (CII) | ID_LINEA_INVESTIGACION (LINEA)
                NOMBRE    : nombre legible
                CODIGO    : código corto (CIIDE, etc.) — null para líneas
                PARENT_ID : (CII) -> '69' (DGI área) | (LINEA) -> 'CII-{idCentro}' (identifier del padre)
              El connector entrega __UID__ y __NAME__ ya prefijados ('CII-'/'LINEA-') para que
              el correlador y el name sean estables e inmutables.
              Soporta EqualsFilter en __NAME__/__UID__ para recon scoped (igual que org.xml).
              Script en una sola línea lógica.
            -->
            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseQuery = "SELECT 'CII' AS ROW_KIND, TO_CHAR(cc.ID_CENTRO_INVESTIGACION) AS ROW_ID, cc.NOMBRE AS NOMBRE, cc.CODIGO AS CODIGO, '69' AS PARENT_ID FROM ESTHER.DGI_CENTRO_INVESTIGACION cc WHERE cc.ESTADO='1' UNION ALL SELECT 'LINEA' AS ROW_KIND, TO_CHAR(l.ID_LINEA_INVESTIGACION) AS ROW_ID, l.NOMBRE AS NOMBRE, l.CODIGO AS CODIGO, 'CII-' || TO_CHAR(l.ID_CENTRO_INVESTIGACION) AS PARENT_ID FROM ESTHER.DGI_LINEA_INVESTIGACION l WHERE l.ESTADO='1'"; def rows; if (query != null) { if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { def val = (query.right as String).trim(); def kind; def rid; if (val.startsWith('CII-')) { kind='CII'; rid=val.substring(4) } else if (val.startsWith('LINEA-')) { kind='LINEA'; rid=val.substring(6) } else { throw new UnsupportedOperationException('UID/NAME debe empezar con CII- o LINEA-: ' + val) }; def scoped = '(' + baseQuery + ') WHERE ROW_KIND = ? AND ROW_ID = ?'; rows = sql.rows(('SELECT * FROM ' + scoped).toString(), [kind, rid]) } else { throw new UnsupportedOperationException('Investigacion-DGI searchScript solo soporta EqualsFilter en __NAME__/__UID__; recibido: ' + query) } } else { rows = sql.rows(baseQuery) }; rows.each { row -&gt; def kind = row.ROW_KIND?.toString(); def rid = row.ROW_ID?.toString(); def prefix = (kind == 'CII') ? 'CII-' : 'LINEA-'; def uid = prefix + rid; result &lt;&lt; ['__UID__': uid, '__NAME__': uid, 'ROW_KIND': kind, 'ROW_ID': rid, 'NOMBRE': (row.NOMBRE?.toString() ?: ''), 'CODIGO': (row.CODIGO?.toString() ?: ''), 'PARENT_ID': row.PARENT_ID?.toString()] }; return result</cfg:searchScript>

            <cfg:syncScript>return null</cfg:syncScript>

            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro('ROW_KIND', true)); ocib.addAttributeInfo(ro('ROW_ID', true)); ocib.addAttributeInfo(ro('NOMBRE', true)); ocib.addAttributeInfo(ro('CODIGO', false)); ocib.addAttributeInfo(ro('PARENT_ID', false)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>

            <cfg:testScript>import groovy.sql.Sql; def sql = new Sql(connection); def c = sql.firstRow("SELECT (SELECT COUNT(*) FROM ESTHER.DGI_CENTRO_INVESTIGACION WHERE ESTADO='1') AS CENTROS, (SELECT COUNT(*) FROM ESTHER.DGI_LINEA_INVESTIGACION WHERE ESTADO='1') AS LINEAS FROM dual"); return 'OK - CII activos: ' + c.CENTROS + ' | Lineas activas: ' + c.LINEAS</cfg:testScript>

        </icfc:configurationProperties>
    </connectorConfiguration>

    <schemaHandling>
        <objectType>
            <kind>generic</kind>
            <intent>research-unit</intent>
            <displayName>Unidad de investigación UPeU (DGI/CII/Línea)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>OrgType</type>
                <!-- archetype dinámico (CII vs LINEA) asignado por inbound abajo -->
            </focus>

            <!-- UID = 'CII-{id}' | 'LINEA-{id}' → identifier (correlador + inbound) -->
            <attribute>
                <ref>icfs:uid</ref>
                <correlator/>
                <inbound>
                    <name>uid-to-identifier</name>
                    <strength>strong</strength>
                    <target><path>identifier</path></target>
                </inbound>
            </attribute>

            <!-- NAME = mismo UID → OrgType.name (único, estable, indexado). WEAK: protege
                 cualquier OrgType curado a mano cuyo identifier coincida (no debería haber). -->
            <attribute>
                <ref>icfs:name</ref>
                <inbound>
                    <name>name-to-name</name>
                    <strength>weak</strength>
                    <target><path>name</path></target>
                </inbound>
            </attribute>

            <!-- NOMBRE → displayName (legible) -->
            <attribute>
                <ref>ri:NOMBRE</ref>
                <inbound>
                    <name>nombre-to-displayName</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim(); v ?: null</code>
                        </script>
                    </expression>
                    <target><path>displayName</path></target>
                </inbound>
            </attribute>

            <!-- CODIGO → extension/upeu:tipoArea (reutilizado como código corto del CII: CIIDE, etc.)
                 Solo presente para Centros. Para líneas queda null. Informativo. -->
            <attribute>
                <ref>ri:CODIGO</ref>
                <inbound>
                    <name>codigo-to-tipoArea</name>
                    <strength>normal</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim(); v ?: null</code>
                        </script>
                    </expression>
                    <target><path>extension/upeu:tipoArea</path></target>
                </inbound>
            </attribute>

            <!-- ROW_ID → extension/upeu:areaId (id LAMB numérico del centro/línea, indexado).
                 NOTA semántica: para CII = ID_CENTRO_INVESTIGACION; para LINEA = ID_LINEA_INVESTIGACION.
                 Reutiliza el item areaId del OrgExtensionType (indexed) para correlación/consultas. -->
            <attribute>
                <ref>ri:ROW_ID</ref>
                <inbound>
                    <name>rowid-to-areaId</name>
                    <strength>strong</strength>
                    <target><path>extension/upeu:areaId</path></target>
                </inbound>
            </attribute>

            <!-- ROW_KIND → subtype (research-center | research-line) para filtros/depuración -->
            <attribute>
                <ref>ri:ROW_KIND</ref>
                <inbound>
                    <name>kind-to-subtype</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def k = (input ?: '').toString().trim(); k == 'CII' ? 'research-center' : (k == 'LINEA' ? 'research-line' : null)</code>
                        </script>
                    </expression>
                    <target><path>subtype</path></target>
                </inbound>
                <!-- ROW_KIND → archetype dinámico:
                     CII   → archetype-org-research-center (6b1d9a4e-2f53-4c8a-bf17-9d0c6e2a4b81)
                     LINEA → archetype-org-research-line   (7c2e0b5f-3a64-4d9b-c028-ae1d7f3b5c92)
                     assignmentTargetSearch por OID resuelto en la expresión (filtro por name del archetype). -->
                <inbound>
                    <name>kind-to-archetype</name>
                    <strength>strong</strength>
                    <expression>
                        <assignmentTargetSearch>
                            <targetType>ArchetypeType</targetType>
                            <filter>
                                <q:equal>
                                    <q:path>name</q:path>
                                    <expression>
                                        <script>
                                            <code>def k = (input ?: '').toString().trim(); k == 'CII' ? 'archetype-org-research-center' : (k == 'LINEA' ? 'archetype-org-research-line' : null)</code>
                                        </script>
                                    </expression>
                                </q:equal>
                            </filter>
                            <createOnDemand>false</createOnDemand>
                        </assignmentTargetSearch>
                    </expression>
                    <target><path>assignment</path></target>
                    <condition>
                        <script>
                            <code>def k = (input ?: '').toString().trim(); k == 'CII' || k == 'LINEA'</code>
                        </script>
                    </condition>
                </inbound>
            </attribute>

            <!-- PARENT_ID → assignment → OrgType padre (jerarquía).
                 CII   → '69'           (DGI, OrgType identifier=69)
                 LINEA → 'CII-{idCentro}' (identifier del Centro padre, ya creado en la misma pasada)
                 assignmentTargetSearch por identifier. createOnDemand=false: si el padre aún no
                 existe (centros se procesan en la misma corrida que líneas, orden UNION ALL pone
                 CII primero), converge en 1-2 pasadas (igual que org.xml). -->
            <attribute>
                <ref>ri:PARENT_ID</ref>
                <inbound>
                    <name>parent-to-parentOrg</name>
                    <strength>strong</strength>
                    <expression>
                        <assignmentTargetSearch>
                            <targetType>OrgType</targetType>
                            <filter>
                                <q:equal>
                                    <q:path>identifier</q:path>
                                    <expression>
                                        <script>
                                            <code>def v = (input ?: '').toString().trim(); v ?: null</code>
                                        </script>
                                    </expression>
                                </q:equal>
                            </filter>
                            <createOnDemand>false</createOnDemand>
                        </assignmentTargetSearch>
                    </expression>
                    <target><path>assignment</path></target>
                    <condition>
                        <script>
                            <code>input != null &amp;&amp; !input.toString().trim().isEmpty()</code>
                        </script>
                    </condition>
                </inbound>
            </attribute>

            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions><addFocus/></actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions><inactivateFocus/></actions>
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>

    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create><cap:enabled>false</cap:enabled></cap:create>
            <cap:update><cap:enabled>false</cap:enabled></cap:update>
            <cap:delete><cap:enabled>false</cap:enabled></cap:delete>
        </configured>
    </capabilities>

    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>

</resource>
