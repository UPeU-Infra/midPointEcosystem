<!--
  Resource: LAMB-Oracle-Investigadores-Afiliacion v1.0
  OID: 8c4f1a36-9d27-4e58-bb03-1f6a2c7d3e95

  Pilar — Afiliación de investigación persona↔Centro (CII) como assignment del User.
  Fuente parcial de enriquecimiento (NO crea usuarios; complementa Oracle LAMB Trabajadores).

  Fuente (Oracle LAMB, schema ESTHER, SOLO LECTURA), cadena de derivación verificada:
    DGI_INVESTIGADOR (ID_PERSONA, ID_INVESTIGACION, ESTADO)
      → DGI_INVESTIGACION_LINEA (ID_INVESTIGACION → ID_LINEA_PROGRAMA)
        → DGI_LINEA_PROGRAMA (ID_LINEA_PROGRAMA → ID_LINEA_INVESTIGACION)
          → DGI_LINEA_INVESTIGACION (ID_LINEA_INVESTIGACION → ID_CENTRO_INVESTIGACION)
            → DGI_CENTRO_INVESTIGACION (CII)
    Resultado: 1 fila por (ID_PERSONA, ID_CENTRO_INVESTIGACION) de investigadores con
    proyecto. 3,776 personas distintas; mono-centro en 3,769 (7 con 2 centros).

  Correlación canónica:
    __UID__ = ID_PERSONA || ':' || ID_CENTRO_INVESTIGACION  (clave compuesta de la fila)
    Correlador de FOCO = extension/upeu:lambIdPersona  (IIA estable de la persona, indexed).
    El inbound persona-id → lambIdPersona se evalúa beforeCorrelation.
    Patrón idéntico a los demás LAMB resources que correlacionan por lambIdPersona.

  Efecto (skill midpoint-best-practices §5.5 — afiliación = assignment, NO atributo):
    Por cada fila → assignment del User al OrgType research-center (CII-{idCentro})
    con relation org:default (miembro). Es la afiliación de investigación.
    Cuando la persona deja el proyecto/centro (fila desaparece del resultset), el
    mapped assignment se retira automáticamente (inbound con target=assignment).

  Canónico: la dependencia laboral (VW_APS_EMPLEADO.ID_DEPTO → área, vía costCenter en
  trabajadores.xml) es la afiliación PRINCIPAL (place 0 en CRIS); la afiliación de
  investigación a un Centro CII es SECUNDARIA. Caso piloto Charming (ID_PERSONA 29266):
  su dependencia laboral activa es DGI (área 69) → principal; no tiene fila en
  DGI_INVESTIGADOR (es staff/director de la DGI, no investigador de proyecto) → este
  resource NO le añade afiliación CII. Su rama Teología/CIIT (si aplica) vendría de otra
  vía (no DGI_INVESTIGADOR). Esto es correcto: el resource solo afilia a quien ESTHER
  declara como investigador de un proyecto con línea→centro resoluble.

  Solo inbound. create/update/delete=false.

  Reactions (fuente parcial de enriquecimiento):
    linked    → synchronize (re-evalúa el assignment CII)
    unlinked  → link
    unmatched → (sin acción) persona no onboarded en MidPoint → ignorar
    deleted   → (sin acción) el mapped assignment cleanup es automático; no inactivar persona

  Historial: v1.0 2026-06-17 — Fase 5 CRIS. lifecycleState=proposed.
-->
<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
    xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
    xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
    xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
    xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
    xmlns:upeu="urn:upeu:midpoint:local"
    oid="8c4f1a36-9d27-4e58-bb03-1f6a2c7d3e95">

    <name>Oracle LAMB Investigadores Afiliacion</name>
    <description>Fuente parcial de enriquecimiento. Deriva la afiliación de investigación persona->Centro (CII) desde la cadena ESTHER.DGI_INVESTIGADOR -> ... -> DGI_CENTRO_INVESTIGACION. Correlaciona por lambIdPersona y crea un assignment al OrgType research-center (CII-{idCentro}) con relation org:default. NO crea usuarios. Fase 5 CRIS (2026-06-17).</description>
    <lifecycleState>proposed</lifecycleState>

    <connectorRef oid="e4cd8ed3-2e91-48d9-abb7-32090a5e8849" relation="org:default" type="c:ConnectorType"/>

    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:resultsHandlerConfiguration>
            <icfc:enableNormalizingResultsHandler>false</icfc:enableNormalizingResultsHandler>
            <icfc:enableFilteredResultsHandler>false</icfc:enableFilteredResultsHandler>
            <icfc:filteredResultsHandlerInValidationMode>true</icfc:filteredResultsHandlerInValidationMode>
            <icfc:enableAttributesToGetSearchResultsHandler>false</icfc:enableAttributesToGetSearchResultsHandler>
        </icfc:resultsHandlerConfiguration>

        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/net.tirasa.connid.bundles.db.scriptedsql/net.tirasa.connid.bundles.db.scriptedsql.ScriptedSQLConnector">
            <cfg:host>192.168.13.9</cfg:host>
            <cfg:port>1521</cfg:port>
            <cfg:user>JUANSANCHEZ</cfg:user>
            <cfg:password>
                <t:encryptedData>
                    <t:encryptionMethod>
                        <t:algorithm>http://www.w3.org/2001/04/xmlenc#aes256-cbc</t:algorithm>
                    </t:encryptionMethod>
                    <t:keyInfo>
                        <t:keyName>nkZ4VieDLlRmwD8hdryrmjz8IxQ=</t:keyName>
                    </t:keyInfo>
                    <t:cipherData>
                        <t:cipherValue>5PiBLf405M3U4ulm9p6WfqMMVVwtOcVl5PuL6/CqPRMTmbA5Aoa/axj4ks8onfI2</t:cipherValue>
                    </t:cipherData>
                </t:encryptedData>
            </cfg:password>
            <cfg:database>UPEU</cfg:database>
            <cfg:jdbcDriver>oracle.jdbc.OracleDriver</cfg:jdbcDriver>
            <cfg:jdbcUrlTemplate>jdbc:oracle:thin:@%h:%p/%d</cfg:jdbcUrlTemplate>
            <cfg:rethrowAllSQLExceptions>true</cfg:rethrowAllSQLExceptions>
            <cfg:nativeTimestamps>true</cfg:nativeTimestamps>
            <cfg:allNative>false</cfg:allNative>
            <cfg:scriptingLanguage>GROOVY</cfg:scriptingLanguage>
            <cfg:reloadScriptOnExecution>false</cfg:reloadScriptOnExecution>

            <!--
              searchScript — 1 fila por (ID_PERSONA, ID_CENTRO_INVESTIGACION).
              Columnas: ID_PERSONA, ID_CENTRO, CII_UID ('CII-{idCentro}')
              __UID__ = ID_PERSONA || ':' || ID_CENTRO  (clave de fila, estable)
              __NAME__ = mismo
              Soporta EqualsFilter en __UID__/__NAME__ (recon scoped por persona:centro).
              Script en una sola línea lógica.
            -->
            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseQuery = 'SELECT DISTINCT i.ID_PERSONA AS ID_PERSONA, l.ID_CENTRO_INVESTIGACION AS ID_CENTRO FROM ESTHER.DGI_INVESTIGADOR i JOIN ESTHER.DGI_INVESTIGACION_LINEA il ON il.ID_INVESTIGACION = i.ID_INVESTIGACION JOIN ESTHER.DGI_LINEA_PROGRAMA lp ON lp.ID_LINEA_PROGRAMA = il.ID_LINEA_PROGRAMA JOIN ESTHER.DGI_LINEA_INVESTIGACION l ON l.ID_LINEA_INVESTIGACION = lp.ID_LINEA_INVESTIGACION'; def rows; if (query != null) { if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { def val = (query.right as String).trim(); def parts = val.split(':'); def pid = Long.parseLong(parts[0]); def cid = Long.parseLong(parts[1]); rows = sql.rows(('SELECT * FROM (' + baseQuery + ') WHERE ID_PERSONA = ? AND ID_CENTRO = ?').toString(), [pid, cid]) } else { throw new UnsupportedOperationException('Afiliacion searchScript solo soporta EqualsFilter en __NAME__/__UID__; recibido: ' + query) } } else { rows = sql.rows(baseQuery) }; rows.each { row -&gt; def pid = row.ID_PERSONA?.toString(); def cid = row.ID_CENTRO?.toString(); def uid = pid + ':' + cid; result &lt;&lt; ['__UID__': uid, '__NAME__': uid, 'ID_PERSONA': pid, 'ID_CENTRO': cid, 'CII_UID': 'CII-' + cid] }; return result</cfg:searchScript>

            <cfg:syncScript>return null</cfg:syncScript>

            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro('ID_PERSONA', true)); ocib.addAttributeInfo(ro('ID_CENTRO', true)); ocib.addAttributeInfo(ro('CII_UID', true)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>

            <cfg:testScript>import groovy.sql.Sql; def sql = new Sql(connection); def row = sql.firstRow('SELECT COUNT(*) AS N FROM (SELECT DISTINCT i.ID_PERSONA, l.ID_CENTRO_INVESTIGACION FROM ESTHER.DGI_INVESTIGADOR i JOIN ESTHER.DGI_INVESTIGACION_LINEA il ON il.ID_INVESTIGACION = i.ID_INVESTIGACION JOIN ESTHER.DGI_LINEA_PROGRAMA lp ON lp.ID_LINEA_PROGRAMA = il.ID_LINEA_PROGRAMA JOIN ESTHER.DGI_LINEA_INVESTIGACION l ON l.ID_LINEA_INVESTIGACION = lp.ID_LINEA_INVESTIGACION)'); return 'OK - filas persona:centro = ' + row.N</cfg:testScript>

        </icfc:configurationProperties>
    </connectorConfiguration>

    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>research-affiliation</intent>
            <displayName>Afiliación de investigación (persona-Centro CII)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
                <!-- Sin archetypeRef: fuente parcial; el archetype estructural (faculty/staff)
                     lo asigna Oracle LAMB Trabajadores. -->
            </focus>

            <!-- ID_PERSONA → extension/upeu:lambIdPersona (beforeCorrelation) para correlación -->
            <attribute>
                <ref>ri:ID_PERSONA</ref>
                <inbound>
                    <name>persona-id-to-lambIdPersona</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim(); v ?: null</code>
                        </script>
                    </expression>
                    <target><path>extension/upeu:lambIdPersona</path></target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>

            <!-- CII_UID → assignment al OrgType research-center (relation org:default).
                 Es la afiliación de investigación. assignmentTargetSearch por identifier. -->
            <attribute>
                <ref>ri:CII_UID</ref>
                <inbound>
                    <name>cii-to-research-affiliation</name>
                    <strength>strong</strength>
                    <expression>
                        <assignmentTargetSearch>
                            <targetType>OrgType</targetType>
                            <filter>
                                <q:equal>
                                    <q:path>identifier</q:path>
                                    <expression>
                                        <script>
                                            <code>def v = (input ?: '').toString().trim(); v ?: null</code>
                                        </script>
                                    </expression>
                                </q:equal>
                            </filter>
                            <createOnDemand>false</createOnDemand>
                        </assignmentTargetSearch>
                    </expression>
                    <target><path>assignment</path></target>
                    <condition>
                        <script>
                            <code>input != null &amp;&amp; !input.toString().trim().isEmpty()</code>
                        </script>
                    </condition>
                </inbound>
            </attribute>

            <correlation>
                <correlators>
                    <items>
                        <name>correlate-by-lambIdPersona</name>
                        <item>
                            <ref>extension/upeu:lambIdPersona</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>

            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <!-- persona no onboarded en MidPoint → ignorar -->
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <!-- mapped assignment cleanup automático; no inactivar persona -->
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>

    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create><cap:enabled>false</cap:enabled></cap:create>
            <cap:update><cap:enabled>false</cap:enabled></cap:update>
            <cap:delete><cap:enabled>false</cap:enabled></cap:delete>
        </configured>
    </capabilities>

    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>

</resource>
