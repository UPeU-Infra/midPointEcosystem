            <icfc:filteredResultsHandlerInValidationMode>true</icfc:filteredResultsHandlerInValidationMode>
            <icfc:enableAttributesToGetSearchResultsHandler>false</icfc:enableAttributesToGetSearchResultsHandler>
        </icfc:resultsHandlerConfiguration>
        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/net.tirasa.connid.bundles.db.scriptedsql/net.tirasa.connid.bundles.db.scriptedsql.ScriptedSQLConnector">
            <cfg:host>192.168.13.9</cfg:host>
            <cfg:port>1521</cfg:port>
            <cfg:user>JUANSANCHEZ</cfg:user>
            <cfg:password>
                <t:encryptedData>
                    <t:encryptionMethod>
                        <t:algorithm>http://www.w3.org/2001/04/xmlenc#aes256-cbc</t:algorithm>
                    </t:encryptionMethod>
                    <t:keyInfo>
                        <t:keyName>nkZ4VieDLlRmwD8hdryrmjz8IxQ=</t:keyName>
                    </t:keyInfo>
                    <t:cipherData>
                        <t:cipherValue>s3rJv3xg278GQMnS0vOO2cQQ6vXL2ShnJ2hhQaYPmUeOtb1O1qpyXjrVZ/rS6Ij4</t:cipherValue>
                    </t:cipherData>
                </t:encryptedData>
            </cfg:password>
            <cfg:database>UPEU</cfg:database>
            <cfg:jdbcDriver>oracle.jdbc.OracleDriver</cfg:jdbcDriver>
            <cfg:jdbcUrlTemplate>jdbc:oracle:thin:@%h:%p/%d</cfg:jdbcUrlTemplate>
            <cfg:rethrowAllSQLExceptions>true</cfg:rethrowAllSQLExceptions>
            <cfg:nativeTimestamps>true</cfg:nativeTimestamps>
            <cfg:allNative>false</cfg:allNative>
            <cfg:scriptingLanguage>GROOVY</cfg:scriptingLanguage>
            <cfg:reloadScriptOnExecution>false</cfg:reloadScriptOnExecution>
            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseSelect = 'SELECT pna.CODIGO, p.NOMBRE, p.PATERNO, p.MATERNO, pn.CORREO_INST AS CORREO_UPEU, pn.CORREO AS CORREO_PERSONAL, pn.CELULAR, pn.FEC_NACIMIENTO, pn.SEXO AS CODIGO_SEXO, pn.NUM_DOCUMENTO, pn.FOTO, ag.STUDENT_CYCLE, ag.PROGRAM_CODES, ag.SCHOOL_NAME, ag.SEDE_NOMBRE, ag.DATE_EXPIRY, ag.NIVEL_ENSENANZA FROM MOISES.PERSONA p INNER JOIN MOISES.PERSONA_NATURAL pn ON pn.ID_PERSONA = p.ID_PERSONA INNER JOIN MOISES.PERSONA_NATURAL_ALUMNO pna ON pna.ID_PERSONA = p.ID_PERSONA INNER JOIN ( SELECT aac.ID_PERSONA, MAX(apc.CICLO) AS STUDENT_CYCLE, LISTAGG(TO_CHAR(asp.ID_PROGRAMA_ESTUDIO), \',\') WITHIN GROUP (ORDER BY asp.ID_PROGRAMA_ESTUDIO) AS PROGRAM_CODES, MAX(oa.NOMBRE) AS SCHOOL_NAME, MAX(os.NOMBRE) AS SEDE_NOMBRE, TO_CHAR(MAX(amd.FECHA_FIN), \'YYYY-MM-DD\') AS DATE_EXPIRY, MAX(tne.NOMBRE) AS NIVEL_ENSENANZA FROM DAVID.ACAD_ALUMNO_CONTRATO aac INNER JOIN DAVID.ACAD_SEMESTRE_PROGRAMA asp ON asp.ID_SEMESTRE_PROGRAMA = aac.ID_SEMESTRE_PROGRAMA AND asp.ID_SEMESTRE IN (279, 267) INNER JOIN DAVID.ACAD_ALUMNO_CONTRATO_CURSO aacc ON aacc.ID_ALUMNO_CONTRATO = aac.ID_ALUMNO_CONTRATO INNER JOIN DAVID.ACAD_CURSO_ALUMNO aca ON aca.ID_CURSO_ALUMNO = aacc.ID_CURSO_ALUMNO AND aca.ESTADO = \'1\' INNER JOIN DAVID.ACAD_PROGRAMA_ESTUDIO ape ON ape.ID_PROGRAMA_ESTUDIO = asp.ID_PROGRAMA_ESTUDIO INNER JOIN DAVID.TIPO_NIVEL_ENSENANZA tne ON tne.ID_NIVEL_ENSENANZA = ape.ID_NIVEL_ENSENANZA INNER JOIN ELISEO.ORG_SEDE_AREA osa ON osa.ID_SEDEAREA = ape.ID_SEDEAREA INNER JOIN ELISEO.ORG_AREA oa ON oa.ID_AREA = osa.ID_AREA INNER JOIN ELISEO.ORG_SEDE os ON os.ID_SEDE = osa.ID_SEDE LEFT JOIN DAVID.ACAD_PLAN_PROGRAMA app ON app.ID_PLAN_PROGRAMA = aca.ID_PLAN_PROGRAMA LEFT JOIN DAVID.ACAD_PLAN_CURSO apc ON apc.ID_PLAN = app.ID_PLAN AND apc.ID_CURSO_DETALLE = aca.ID_CURSO_DETALLE LEFT JOIN (SELECT ID_SEMESTRE_PROGRAMA, MAX(FECHA_FIN) AS FECHA_FIN FROM DAVID.ACAD_MODULO_DETALLE GROUP BY ID_SEMESTRE_PROGRAMA) amd ON amd.ID_SEMESTRE_PROGRAMA = asp.ID_SEMESTRE_PROGRAMA GROUP BY aac.ID_PERSONA ) ag ON ag.ID_PERSONA = p.ID_PERSONA WHERE pn.CORREO_INST IS NOT NULL'; def finalQuery = ''; def params = []; if (query != null &amp;&amp; query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { finalQuery = baseSelect + ' AND pna.CODIGO = ?'; params &lt;&lt; (query.right as String); } else if (query != null) { throw new UnsupportedOperationException('Estudiantes-v4 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } else { finalQuery = baseSelect; }; sql.eachRow(finalQuery, params) { row -&gt; def map = [:]; map['__UID__'] = row.CODIGO as String; map['__NAME__'] = row.CODIGO as String; map['CODIGO'] = row.CODIGO as String; map['NOMBRE'] = row.NOMBRE as String; map['PATERNO'] = row.PATERNO as String; map['MATERNO'] = row.MATERNO as String; map['CORREO_UPEU'] = row.CORREO_UPEU as String; map['CORREO_PERSONAL'] = row.CORREO_PERSONAL as String; map['CELULAR'] = row.CELULAR as String; map['FEC_NACIMIENTO'] = row.FEC_NACIMIENTO?.toString(); map['CODIGO_SEXO'] = row.CODIGO_SEXO as String; map['NUM_DOCUMENTO'] = row.NUM_DOCUMENTO as String; map['FOTO'] = row.FOTO as String; map['STUDENT_CYCLE'] = row.STUDENT_CYCLE?.toString(); if (row.PROGRAM_CODES != null) { def codes = (row.PROGRAM_CODES as String).split(',').collect { it.trim() }.findAll { it }.unique(); if (codes) map['PROGRAM_CODES'] = codes; }; map['SCHOOL_NAME'] = row.SCHOOL_NAME as String; map['SEDE_NOMBRE'] = row.SEDE_NOMBRE as String; map['DATE_EXPIRY'] = row.DATE_EXPIRY as String; map['NIVEL_ENSENANZA'] = row.NIVEL_ENSENANZA as String; result &lt;&lt; map }; return result</cfg:searchScript>
            <cfg:syncScript>return null</cfg:syncScript>
            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required, boolean multiValued = false -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.setMultiValued(multiValued); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro("CODIGO", true)); ocib.addAttributeInfo(ro("NOMBRE", true)); ocib.addAttributeInfo(ro("PATERNO", false)); ocib.addAttributeInfo(ro("MATERNO", false)); ocib.addAttributeInfo(ro("CORREO_UPEU", false)); ocib.addAttributeInfo(ro("CELULAR", false)); ocib.addAttributeInfo(ro("FEC_NACIMIENTO", false)); ocib.addAttributeInfo(ro("CODIGO_SEXO", false)); ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false)); ocib.addAttributeInfo(ro("FOTO", false)); ocib.addAttributeInfo(ro("STUDENT_CYCLE", false)); ocib.addAttributeInfo(ro("PROGRAM_CODES", false, true)); ocib.addAttributeInfo(ro("SCHOOL_NAME", false)); ocib.addAttributeInfo(ro("SEDE_NOMBRE", false)); ocib.addAttributeInfo(ro("DATE_EXPIRY", false)); ocib.addAttributeInfo(ro("CORREO_PERSONAL", false)); ocib.addAttributeInfo(ro("NIVEL_ENSENANZA", false)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>
            <cfg:testScript>import groovy.sql.Sql; def sql = new Sql(connection); sql.firstRow("SELECT 1 AS OK FROM DUAL"); return "OK"</cfg:testScript>
        </icfc:configurationProperties>
    </connectorConfiguration>
    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>default</intent>
            <displayName>Alumno UPeU (LAMB SIS v3)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
                <!-- archetypeRef removido — Bloque D.7 del Object Template asigna el archetype
                     estructural correcto según prioridad de sb:affiliations (faculty > staff > student > alum).
                     MidPoint Book Cap. 8-9: template decide, resources solo proveen datos. -->
            </focus>
            <attribute>
                <ref>ri:CODIGO</ref>
                <inbound>
                    <name>codigo-to-name</name>
                    <strength>weak</strength>
                    <target><path>name</path></target>
                </inbound>
                <inbound>
                    <name>codigo-to-personalNumber</name>
                    <strength>weak</strength>
                    <target><path>personalNumber</path></target>
                </inbound>
                <inbound>
                    <name>codigo-to-institutionalCode</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:institutionalCode</path>
                    </target>
                </inbound>
            </attribute>
            <!-- Patrón B (docs/IIA-MATRIX.md §2.1, §3.1, 2026-05-26 Ola 1):
                 givenName/familyName/birthDate/telephoneNumber bajan a weak.
                 IIA principal = trabajadores (strong). Override jurídico = reniec-cache (strong).
                 estudiantes solo sirve como fallback para student-only sin RENIEC.
                 emailAddress: inbound ELIMINADO — trabajadores es IIA único de email institucional.
                 (Antes de Ola 1: estos 4 inbounds eran strength=strong y competían con trabajadores/reniec).
            -->
            <attribute>
                <ref>ri:NOMBRE</ref>
                <inbound>
                    <name>nombre-to-givenName</name>
                    <strength>weak</strength>
                    <target><path>givenName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:PATERNO</ref>
                <inbound>
                    <name>paterno-materno-to-familyName</name>
                    <strength>weak</strength>
                    <source><path>$shadow/attributes/ri:PATERNO</path></source>
                    <source><path>$shadow/attributes/ri:MATERNO</path></source>
                    <expression>
                        <script>
                            <code>def p = (PATERNO ?: '').toString().trim(); def m = (MATERNO ?: '').toString().trim(); (p + (m ? ' ' + m : '')).trim() ?: null</code>
                        </script>
                    </expression>
                    <target><path>familyName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CORREO_UPEU</ref>
                <!-- Inbound emailAddress ELIMINADO Ola 1 (Patrón B). El email institucional
                     viene exclusivamente de trabajadores.xml (CORREO_INST). Para estudiantes
                     que NUNCA fueron trabajador, el email se construye en el template
                     UserTemplate-Person-Base.xml (personalNumber + '@upeu.edu.pe', weak).
                     CORREO_UPEU se sigue fetcheando para correlación / data quality. -->
            </attribute>
            <attribute>
                <ref>ri:CELULAR</ref>
                <inbound>
                    <name>celular-to-telephoneNumber</name>
                    <strength>weak</strength>
                    <target><path>telephoneNumber</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <!-- Ola 1 fix 7.1 (2026-05-26): correlator shorthand <correlator/> dentro
                     de <attribute> está roto en MidPoint 4.10 cuando hay inbounds con
                     beforeCorrelation. Reemplazado por correlator explícito a nivel
                     objectType abajo, mismo patrón que egresados.xml/grados.xml.
                     El inbound dni-to-taxId-urn (beforeCorrelation) sigue normalizando
                     NUM_DOCUMENTO a URN SCHAC en extension/sb:taxId. -->
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def d = (input ?: '').toString().trim(); d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
                <inbound>
                    <!-- FIX correlación cruzada (2026-05-29, runbook org-canonical sesión PM7):
                         igual que egresados.xml. Alumnos que ADEMÁS son trabajadores tienen lambDocNum
                         poblado (Trabajadores) pero taxId vacío → el correlador por taxId no los enlaza.
                         Poblamos lambDocNum y añadimos correlador por él. Unifica el identificador de
                         correlación de persona entre resources. -->
                    <name>num-documento-to-lambDocNum</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <!-- FIX RAIZ C v2 (2026-05-31): normalizacion tipo-preservante del documento de
                                 correlacion (identica a trabajadores.xml/egresados.xml), ALINEADA AL GATE
                                 (strip-primero). El v1 media longitud sobre el crudo => '001756348' (9) no
                                 colapsaba con '01756348'. Regla canonica (== gate SQL):
                                   1) strip ceros lider PRIMERO.
                                   2) numerico stripped <=8 => zfill(8) (DNI peruano canonico = 8 digitos).
                                   3) numerico stripped  >8 => stripped tal cual (no truncar, no rellenar).
                                   4) no-numerico => intacto (solo trim).
                                   5) vacio / '0' / '000...0' => null.
                                 Colapsa 001756348->01756348 == 01756348. 123456789->123456789.
                                 Gate previo OBLIGATORIO: 0 colisiones DIFFERENT_PERSON. -->
                            <code>def d = (input ?: '').toString().trim()
if (!d) return null
if (d ==~ /\d+/) {
    def norm = d.replaceFirst(/^0+/, '')
    if (!norm) return null
    return norm.length() &lt;= 8 ? norm.padLeft(8, '0') : norm
}
return d</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:lambDocNum</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:FEC_NACIMIENTO</ref>
                <!-- Patrón B Ola 1: weak (era strong). Autoridad jurídica = reniec-cache (RENIEC). -->
                <inbound>
                    <name>fec-nacimiento-to-birthDate</name>
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>if (input == null) return null; def s = input.toString(); s.length() >= 10 ? s.substring(0, 10) : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:birthDate</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CODIGO_SEXO</ref>
                <inbound>
                    <name>codigo-sexo-to-gender-iso5218</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <!-- MOISES.PERSONA_NATURAL.SEXO ya envía ISO 5218: '1'=Masculino, '2'=Femenino.
                                 Solo validar y pasar; null si valor desconocido. -->
                            <code>def v = (input ?: '').toString().trim(); ['1','2'].contains(v) ? v : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:gender</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:STUDENT_CYCLE</ref>
                <inbound>
                    <name>student-cycle-to-extension</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:studentCycle</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:PROGRAM_CODES</ref>
                <!-- PROGRAM_CODES contiene IDs numéricos Oracle (ej: "327") — no usar como academicProgramCode canónico.
                     academicProgramCode canónico EP-XXX se resuelve desde SCHOOL_NAME via resolveProgramCode. -->
            </attribute>
            <attribute>
                <ref>ri:SCHOOL_NAME</ref>
                <inbound>
                    <name>school-name-to-academicProgramUri</name>
                    <strength>strong</strength>
                    <expression>
                        <function>
                            <libraryRef oid="6a99f9de-5db6-43d5-9b20-0cfd2b79ecf9" type="FunctionLibraryType"/>
                            <name>resolveProgramUri</name>
                            <parameter>
                                <name>programText</name>
                                <expression><path>$input</path></expression>
                            </parameter>
                        </function>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:academicProgramUri</path>
                    </target>
                </inbound>
                <inbound>
                    <name>school-name-to-academicProgramRole</name>
                    <strength>weak</strength>
                    <expression>
                        <value>student</value>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:academicProgramRole</path>
                    </target>
                </inbound>
                <!-- ELIMINADO 2026-05-29 (doble-autoridad Reality-vs-Policy §2.1):
                     inbound school-name-to-primaryAffiliation borrado. primaryAffiliation es un
                     atributo DERIVADO por el template (Bloque J3, strong, desde affiliations);
                     NO debe ser target de inbounds de recurso. school-name-to-affiliations (abajo)
                     alimenta affiliations → J3 deriva primaryAffiliation. Único escritor = template. -->
                <!-- NEUTRALIZADO 2026-05-30 (OPCIÓN 2, runbook PM10): el inbound
                     `school-name-to-affiliations` (multivalor multi-source) se elimina por la misma
                     causa raíz (zero-set no materializa). Sustituido por: (1)
                     `school-name-to-liveAffiliationStudent` (abajo, item per-IIA single-source) + (2)
                     Bloque J3b del template que deriva `affiliations` como unión. Autoridad única de
                     `affiliations` = template (Reality-vs-Policy §2.1). -->
                <inbound>
                    <name>school-name-to-liveAffiliationStudent</name>
                    <!-- OPCIÓN 2 (runbook PM10): item per-IIA SINGLE-SOURCE para la afiliación de
                         estudiante. single-valor, único escritor → strong materializa de forma fiable
                         (sin zero-set multi-source). Presente SOLO mientras hay matrícula vigente: el
                         searchScript de Estudiantes v4 ya restringe a semestres 279/267, por lo que la
                         existencia del shadow ⇔ matrícula vigente. Al perder matrícula, el shadow se
                         desproyecta → el item se vacía → 'student' deja de ser afiliación viva.
                         IIA única: Estudiantes (iga-canonical §1.3). -->
                    <strength>strong</strength>
                    <expression>
                        <value>student</value>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:liveAffiliationStudent</path>
                    </target>
                    <!-- SIN <evaluationPhases>: default (solo clockwork). Ver nota en
                         egresados.xml (afiliacion-to-liveAffiliationAlum): beforeCorrelation empuja
                         el valor al zero-set y no materializa el item vacío. -->
                </inbound>
                <inbound>
                    <name>school-name-to-academicProgramCode</name>
                    <strength>strong</strength>
                    <expression>
                        <function>
                            <libraryRef oid="6a99f9de-5db6-43d5-9b20-0cfd2b79ecf9" type="FunctionLibraryType"/>
                            <name>resolveProgramCode</name>
                            <parameter>
                                <name>programText</name>
                                <expression><path>$input</path></expression>
                            </parameter>
                        </function>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:academicProgramCode</path>
                    </target>
                </inbound>
                <!-- SCHOOL_NAME → organizationalUnit
                     IIA: ELISEO.ORG_AREA.NOMBRE (via MAX en subquery, nombre de EP/facultad del semestre activo).
                     Koha outbound usa $focus/organizationalUnit para poblar statistics_1 (campo libre Koha).
                     weak: para usuarios con doble afiliación, la unidad del trabajador (si existe) toma precedencia. -->
                <inbound>
                    <name>school-name-to-organizationalUnit</name>
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim(); v ?: null</code>
                        </script>
                    </expression>
                    <target><path>organizationalUnit</path></target>
                </inbound>
            </attribute>
            <attribute>
                <!-- SEDE_NOMBRE → locality
                     IIA: ELISEO.ORG_SEDE (via JOIN ELISEO.ORG_SEDE_AREA osa, JOIN ELISEO.ORG_SEDE os en subquery).
                     Valores LAMB: "Sede Lima" → LIMA | "Filial Tarapoto" → TARAPOTO | "Filial Juliaca" → JULIACA.
                     weak: cede ante trabajadores (strength=strong) para usuarios con doble afiliación.
                     Cuando BUJ/BUT se autoricen, locality ya enruta automáticamente a Koha via mapa library_id. -->
                <ref>ri:SEDE_NOMBRE</ref>
                <inbound>
                    <name>sede-nombre-to-locality</name>
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim(); ['Sede Lima':'LIMA','Filial Tarapoto':'TARAPOTO','Filial Juliaca':'JULIACA'].getOrDefault(v, 'LIMA')</code>
                        </script>
                    </expression>
                    <target><path>locality</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:DATE_EXPIRY</ref>
                <!-- DATE_EXPIRY = MAX(FECHA_FIN) del semestre de matrícula vigente.
                     IIA única (canónico §1.3): resource Estudiantes. Single-source, single-writer.
                     Antes escribía weak a extension/sb:terminationDate (target compartido con
                     Trabajadores/FEC_TERMINO strong) -> el valor stale del semestre anterior (279)
                     no se refrescaba al vigente (267) y Koha expiraba ~562 student + 168 faculty.
                     Opción 2 canónica: atributo por-IIA dedicado terminationDateStudent (strong,
                     single-source), análogo a liveAffiliationStudent. Sin colisión dual-strong en
                     focos employee+student porque cada IIA escribe SU PROPIO atributo. El expiry
                     efectivo a Koha se calcula como MAX(terminationDate, terminationDateStudent)
                     en expiry-date-outbound del resource koha-ils.xml. -->
                <inbound>
                    <name>date-expiry-to-terminationDateStudent</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>if (input == null) return null; def s = input.toString(); s.length() >= 10 ? s.substring(0, 10) : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:terminationDateStudent</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CORREO_PERSONAL</ref>
                <!-- MOISES.PERSONA_NATURAL.CORREO: correo personal libre (gmail, hotmail, etc.)
                     Weak: cede ante trabajadores si tiene correo personal más confiable. -->
                <inbound>
                    <name>correo-personal-to-personalEmail</name>
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim().toLowerCase(); v ? v : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:personalEmail</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <!-- NIVEL_ENSENANZA → sb:studyLevel
                     IIA: DAVID.TIPO_NIVEL_ENSENANZA.NOMBRE via JOIN en subquery ag.
                     Valores relevantes IGA: Pregrado, Posgrado, Técnica, Idiomas, CEPRE, etc.
                     normal: permite multi-programa simultáneo (ej. Pregrado+Posgrado en mismo semestre).
                     Con strong MidPoint lanza fatal_error si dos shadows tienen NIVEL_ENSENANZA distinto.
                     El último shadow procesado prevalece; sin impacto práctico (mismo semestre activo). -->
                <ref>ri:NIVEL_ENSENANZA</ref>
                <inbound>
                    <name>nivel-ensenanza-to-studyLevel</name>
                    <strength>normal</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:studyLevel</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <!-- FOTO → upeu:photoUrl
                     IIA: MOISES.PERSONA_NATURAL.FOTO (ruta relativa MinIO, ej. "foto/alumno/038xxx.jpg").
                     El inbound construye la URL completa al MinIO institucional.
                     strength weak: cede ante el mapping de trabajadores (strength=normal) para usuarios
                     con doble afiliación (estudiante + empleado). La foto del trabajador prevalece.
                     Cobertura: ~49.216 estudiantes con foto en LAMB. -->
                <ref>ri:FOTO</ref>
                <inbound>
                    <name>foto-to-photoUrl</name>
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>input ? 'https://lamb-files.upeu.edu.pe/lamb-academic/' + input.toString().replaceAll('^lamb-academic/', '') : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:photoUrl</path>
                    </target>
                </inbound>
            </attribute>
            <correlation>
                <!-- Ola 1 fix 7.1 (2026-05-26): correlator explícito a nivel objectType.
                     Reemplaza el <correlator/> shorthand dentro de <attribute>ri:NUM_DOCUMENTO</attribute>
                     que estaba roto en MidPoint 4.10 cuando hay inbounds con beforeCorrelation.
                     Mismo patrón usado en egresados.xml/grados.xml. El inbound dni-to-taxId-urn
                     normaliza NUM_DOCUMENTO a URN SCHAC en extension/sb:taxId antes de
                     que este correlator evalúe. -->
                <correlators>
                    <items>
                        <name>correlate-by-taxId</name>
                        <item>
                            <ref xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</ref>
                        </item>
                    </items>
                    <!-- FIX correlación cruzada (2026-05-29, PM7): correlador adicional por lambDocNum
                         para alumnos-trabajadores con taxId vacío. Mismo patrón que egresados.xml. -->
                    <items>
                        <name>correlate-by-lambDocNum</name>
                        <item>
                            <ref xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:lambDocNum</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions><addFocus/></actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions><inactivateFocus/></actions>
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>
    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create>
                <cap:enabled>false</cap:enabled>
            </cap:create>
            <cap:update>
                <cap:enabled>false</cap:enabled>
            </cap:update>
            <cap:delete>
                <cap:enabled>false</cap:enabled>
            </cap:delete>
        </configured>
    </capabilities>
    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>
</resource>
