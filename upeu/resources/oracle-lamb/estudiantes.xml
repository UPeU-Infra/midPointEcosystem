            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseSelect = 'SELECT pna.CODIGO, p.NOMBRE, p.PATERNO, p.MATERNO, pn.CORREO_INST AS CORREO_UPEU, pn.CORREO AS CORREO_PERSONAL, pn.CELULAR, pn.FEC_NACIMIENTO, pn.SEXO AS CODIGO_SEXO, pn.NUM_DOCUMENTO, pn.ID_TIPODOCUMENTO AS TIPO_DOC, pn.FOTO, ag.STUDENT_CYCLE, ag.PROGRAM_CODES, ag.SCHOOL_NAME, ag.SEDE_NOMBRE, ag.DATE_EXPIRY, ag.NIVEL_ENSENANZA, ag.SUNEDU_CODE, ag.FACULTY_NAME, ag.PROGRAM_LEVEL, ag.TIPO_ALUMNO FROM MOISES.PERSONA p INNER JOIN MOISES.PERSONA_NATURAL pn ON pn.ID_PERSONA = p.ID_PERSONA INNER JOIN MOISES.PERSONA_NATURAL_ALUMNO pna ON pna.ID_PERSONA = p.ID_PERSONA INNER JOIN ( SELECT aac.ID_PERSONA, LISTAGG(apc.CICLO, \',\') WITHIN GROUP (ORDER BY apc.CICLO) AS STUDENT_CYCLE, LISTAGG(TO_CHAR(asp.ID_PROGRAMA_ESTUDIO), \',\') WITHIN GROUP (ORDER BY asp.ID_PROGRAMA_ESTUDIO) AS PROGRAM_CODES, MAX(oa.NOMBRE) KEEP (DENSE_RANK LAST ORDER BY amd.FECHA_FIN NULLS FIRST) AS SCHOOL_NAME, MAX(os.NOMBRE) KEEP (DENSE_RANK LAST ORDER BY amd.FECHA_FIN NULLS FIRST) AS SEDE_NOMBRE, TO_CHAR(MAX(amd.FECHA_FIN), \'YYYY-MM-DD\') AS DATE_EXPIRY, MAX(tne.NOMBRE) KEEP (DENSE_RANK LAST ORDER BY amd.FECHA_FIN NULLS FIRST) AS NIVEL_ENSENANZA, MAX(COALESCE(ape.CODIGO_SUNEDU2, 'P'||ape.CODIGO_SUNEDU)) KEEP (DENSE_RANK LAST ORDER BY (CASE WHEN COALESCE(ape.CODIGO_SUNEDU2,ape.CODIGO_SUNEDU) IS NOT NULL THEN 1 ELSE 0 END), amd.FECHA_FIN NULLS FIRST) AS SUNEDU_CODE, MAX(oafac.NOMBRE) KEEP (DENSE_RANK LAST ORDER BY (CASE WHEN ape.CODIGO_SUNEDU2 IS NOT NULL THEN 1 ELSE 0 END), amd.FECHA_FIN NULLS FIRST) AS FACULTY_NAME, MAX(CASE WHEN ape.CODIGO_SUNEDU2 IS NOT NULL THEN \'pregrado\' WHEN tne.NOMBRE = \'Pregrado\' THEN \'pregrado\' WHEN tne.NOMBRE = \'Posgrado\' AND UPPER(ape.NOMBRE) LIKE \'%DOCTORADO%\' THEN \'doctorado\' WHEN tne.NOMBRE = \'Posgrado\' AND UPPER(ape.NOMBRE) LIKE \'%SEGUNDA ESPECIAL%\' THEN \'segunda-especialidad\' WHEN tne.NOMBRE = \'Posgrado\' THEN \'posgrado\' ELSE LOWER(tne.NOMBRE) END) KEEP (DENSE_RANK LAST ORDER BY (CASE WHEN ape.CODIGO_SUNEDU2 IS NOT NULL THEN 1 ELSE 0 END), amd.FECHA_FIN NULLS FIRST) AS PROGRAM_LEVEL, MAX(aac.TIPO_ALUMNO) KEEP (DENSE_RANK LAST ORDER BY amd.FECHA_FIN NULLS FIRST) AS TIPO_ALUMNO FROM DAVID.ACAD_ALUMNO_CONTRATO aac INNER JOIN DAVID.ACAD_SEMESTRE_PROGRAMA asp ON asp.ID_SEMESTRE_PROGRAMA = aac.ID_SEMESTRE_PROGRAMA AND asp.ID_SEMESTRE IN (267, 279, 283) INNER JOIN DAVID.ACAD_ALUMNO_CONTRATO_CURSO aacc ON aacc.ID_ALUMNO_CONTRATO = aac.ID_ALUMNO_CONTRATO INNER JOIN DAVID.ACAD_CURSO_ALUMNO aca ON aca.ID_CURSO_ALUMNO = aacc.ID_CURSO_ALUMNO AND aca.ESTADO = \'1\' INNER JOIN DAVID.ACAD_PROGRAMA_ESTUDIO ape ON ape.ID_PROGRAMA_ESTUDIO = asp.ID_PROGRAMA_ESTUDIO INNER JOIN DAVID.TIPO_NIVEL_ENSENANZA tne ON tne.ID_NIVEL_ENSENANZA = ape.ID_NIVEL_ENSENANZA INNER JOIN ELISEO.ORG_SEDE_AREA osa ON osa.ID_SEDEAREA = ape.ID_SEDEAREA INNER JOIN ELISEO.ORG_AREA oa ON oa.ID_AREA = osa.ID_AREA LEFT JOIN ELISEO.ORG_AREA oafac ON oafac.ID_AREA = oa.ID_PARENT INNER JOIN ELISEO.ORG_SEDE os ON os.ID_SEDE = osa.ID_SEDE LEFT JOIN DAVID.ACAD_PLAN_PROGRAMA app ON app.ID_PLAN_PROGRAMA = aca.ID_PLAN_PROGRAMA LEFT JOIN DAVID.ACAD_PLAN_CURSO apc ON apc.ID_PLAN = app.ID_PLAN AND apc.ID_CURSO_DETALLE = aca.ID_CURSO_DETALLE LEFT JOIN (SELECT ID_SEMESTRE_PROGRAMA, MAX(FECHA_FIN) AS FECHA_FIN FROM DAVID.ACAD_MODULO_DETALLE GROUP BY ID_SEMESTRE_PROGRAMA) amd ON amd.ID_SEMESTRE_PROGRAMA = asp.ID_SEMESTRE_PROGRAMA GROUP BY aac.ID_PERSONA ) ag ON ag.ID_PERSONA = p.ID_PERSONA'; def finalQuery = ''; def params = []; if (query != null &amp;&amp; query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { finalQuery = baseSelect + ' AND pna.CODIGO = ?'; params &lt;&lt; (query.right as String); } else if (query != null) { throw new UnsupportedOperationException('Estudiantes-v4 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } else { finalQuery = baseSelect; }; sql.eachRow(finalQuery, params) { row -&gt; def map = [:]; map['__UID__'] = row.CODIGO as String; map['__NAME__'] = row.CODIGO as String; map['CODIGO'] = row.CODIGO as String; map['NOMBRE'] = row.NOMBRE as String; map['PATERNO'] = row.PATERNO as String; map['MATERNO'] = row.MATERNO as String; map['CORREO_UPEU'] = row.CORREO_UPEU as String; map['CORREO_PERSONAL'] = row.CORREO_PERSONAL as String; map['CELULAR'] = row.CELULAR as String; map['FEC_NACIMIENTO'] = row.FEC_NACIMIENTO?.toString(); map['CODIGO_SEXO'] = row.CODIGO_SEXO as String; map['NUM_DOCUMENTO'] = row.NUM_DOCUMENTO as String; map['TIPO_DOC'] = row.TIPO_DOC?.toString(); map['FOTO'] = row.FOTO as String; if (row.STUDENT_CYCLE != null) { def cyc = (row.STUDENT_CYCLE as String).split(',').collect { it.trim() }.findAll { it }.unique(); if (cyc) map['STUDENT_CYCLE'] = cyc; }; if (row.PROGRAM_CODES != null) { def codes = (row.PROGRAM_CODES as String).split(',').collect { it.trim() }.findAll { it }.unique(); if (codes) map['PROGRAM_CODES'] = codes; }; map['SCHOOL_NAME'] = row.SCHOOL_NAME as String; map['SEDE_NOMBRE'] = row.SEDE_NOMBRE as String; map['DATE_EXPIRY'] = row.DATE_EXPIRY as String; map['NIVEL_ENSENANZA'] = row.NIVEL_ENSENANZA as String; map['SUNEDU_CODE'] = row.SUNEDU_CODE as String; map['FACULTY_NAME'] = row.FACULTY_NAME as String; map['PROGRAM_LEVEL'] = row.PROGRAM_LEVEL as String; map['TIPO_ALUMNO'] = row.TIPO_ALUMNO as String; result &lt;&lt; map }; return result</cfg:searchScript>
            <cfg:syncScript>return null</cfg:syncScript>
            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required, boolean multiValued = false -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.setMultiValued(multiValued); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro("CODIGO", true)); ocib.addAttributeInfo(ro("NOMBRE", true)); ocib.addAttributeInfo(ro("PATERNO", false)); ocib.addAttributeInfo(ro("MATERNO", false)); ocib.addAttributeInfo(ro("CORREO_UPEU", false)); ocib.addAttributeInfo(ro("CELULAR", false)); ocib.addAttributeInfo(ro("FEC_NACIMIENTO", false)); ocib.addAttributeInfo(ro("CODIGO_SEXO", false)); ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false)); ocib.addAttributeInfo(ro("TIPO_DOC", false)); ocib.addAttributeInfo(ro("FOTO", false)); ocib.addAttributeInfo(ro("STUDENT_CYCLE", false, true)); ocib.addAttributeInfo(ro("PROGRAM_CODES", false, true)); ocib.addAttributeInfo(ro("SCHOOL_NAME", false)); ocib.addAttributeInfo(ro("SEDE_NOMBRE", false)); ocib.addAttributeInfo(ro("DATE_EXPIRY", false)); ocib.addAttributeInfo(ro("CORREO_PERSONAL", false)); ocib.addAttributeInfo(ro("NIVEL_ENSENANZA", false)); ocib.addAttributeInfo(ro("SUNEDU_CODE", false)); ocib.addAttributeInfo(ro("FACULTY_NAME", false)); ocib.addAttributeInfo(ro("PROGRAM_LEVEL", false)); ocib.addAttributeInfo(ro("TIPO_ALUMNO", false)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>
