            </attribute>
            <attribute>
                <ref>ri:NIVEL_ENSENANZA</ref>
                <inbound>
                    <name>nivel-ensenanza-to-studyLevel</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>(input ?: '').toString().trim() ?: null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:studyLevel</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:MODALIDAD_ESTUDIO</ref>
                <inbound>
                    <name>modalidad-to-studyModality</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>(input ?: '').toString().trim() ?: null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:studyModality</path>
