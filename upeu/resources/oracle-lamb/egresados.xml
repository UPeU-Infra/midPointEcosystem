            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseQuery = '''SELECT * FROM ( SELECT e.CODIGO, MAX(e.NOMBRE) AS NOMBRE, MAX(e.PATERNO) AS PATERNO, MAX(e.MATERNO) AS MATERNO, MAX(e.CORREO_UPEU) AS CORREO_UPEU, MAX(e.CELULAR) AS CELULAR, MAX(e.NUM_DOCUMENTO) AS NUM_DOCUMENTO, MAX(e.FEC_NACIMIENTO) AS FEC_NACIMIENTO, MAX(e.ESCUELA_PROFESIONAL) AS ESCUELA_PROFESIONAL, MAX(e.NOM_FACULTAD) AS NOM_FACULTAD, MAX(e.NIVEL_ENSENANZA) AS NIVEL_ENSENANZA, MAX(e.MODALIDAD_ESTUDIO) AS MODALIDAD_ESTUDIO, MAX(e.ANIO) AS ANIO, MAX(e.SEMESTRE) AS SEMESTRE, MAX(pn.FOTO) AS FOTO, \'alum\' AS AFILIACION FROM DAVID.VW_PERSONA_EGRESADO e LEFT JOIN MOISES.PERSONA_NATURAL pn ON pn.ID_PERSONA = e.ID_PERSONA GROUP BY e.CODIGO )'''; def whereClause = ''; def params = []; if (query != null) { if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { whereClause = ' WHERE CODIGO = ?'; params &lt;&lt; (query.right as String); } else { throw new UnsupportedOperationException('Egresados-v2 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } }; def finalQuery = "SELECT * FROM (${baseQuery})${whereClause}".toString(); sql.eachRow(finalQuery, params) { row -&gt; result &lt;&lt; ['__UID__': row.CODIGO as String, '__NAME__': row.CODIGO as String, 'CODIGO': row.CODIGO as String, 'NOMBRE': row.NOMBRE as String, 'PATERNO': row.PATERNO as String, 'MATERNO': row.MATERNO as String, 'CORREO_UPEU': row.CORREO_UPEU as String, 'CELULAR': row.CELULAR as String, 'NUM_DOCUMENTO': row.NUM_DOCUMENTO as String, 'FEC_NACIMIENTO': row.FEC_NACIMIENTO?.toString(), 'ESCUELA_PROFESIONAL': row.ESCUELA_PROFESIONAL as String, 'NOM_FACULTAD': row.NOM_FACULTAD as String, 'NIVEL_ENSENANZA': row.NIVEL_ENSENANZA as String, 'MODALIDAD_ESTUDIO': row.MODALIDAD_ESTUDIO as String, 'ANIO': row.ANIO?.toString(), 'SEMESTRE': row.SEMESTRE?.toString(), 'FOTO': row.FOTO as String, 'AFILIACION': row.AFILIACION as String] }; return result</cfg:searchScript>
            <cfg:syncScript>return null</cfg:syncScript>
            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro("CODIGO", true)); ocib.addAttributeInfo(ro("NOMBRE", true)); ocib.addAttributeInfo(ro("PATERNO", false)); ocib.addAttributeInfo(ro("MATERNO", false)); ocib.addAttributeInfo(ro("CORREO_UPEU", false)); ocib.addAttributeInfo(ro("CELULAR", false)); ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false)); ocib.addAttributeInfo(ro("FEC_NACIMIENTO", false)); ocib.addAttributeInfo(ro("ESCUELA_PROFESIONAL", false)); ocib.addAttributeInfo(ro("NOM_FACULTAD", false)); ocib.addAttributeInfo(ro("NIVEL_ENSENANZA", false)); ocib.addAttributeInfo(ro("MODALIDAD_ESTUDIO", false)); ocib.addAttributeInfo(ro("ANIO", false)); ocib.addAttributeInfo(ro("SEMESTRE", false)); ocib.addAttributeInfo(ro("FOTO", false)); ocib.addAttributeInfo(ro("AFILIACION", false)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>
            <cfg:testScript>import groovy.sql.Sql; def sql = new Sql(connection); sql.firstRow("SELECT 1 AS OK FROM DUAL"); return "OK"</cfg:testScript>
