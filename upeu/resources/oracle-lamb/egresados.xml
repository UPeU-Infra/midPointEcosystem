            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def d = (input ?: '').toString().trim(); d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
                <inbound>
                    <!-- FIX correlación cruzada (2026-05-29, runbook org-canonical sesión PM7):
                         Trabajadores correlaciona/identifica por extension/upeu:lambDocNum (NUM_DOCUMENTO
                         crudo), NO por taxId (su mapeo dni-to-taxId-urn está deprecado/archived). Por eso
                         los egresados que ADEMÁS son trabajadores tienen lambDocNum poblado pero taxId
                         vacío, y el correlador de Egresados por taxId NO los encuentra → no se proyecta
                         el shadow Egresado → no se puebla affiliations=alum. Poblamos lambDocNum aquí
                         (idéntico a trabajadores.xml: num-documento-to-lambDocNum) y añadimos un
                         correlador por lambDocNum para enlazar a esos usuarios.
                         Identificador de correlación canónico unificado entre resources de persona
                         (best-practices §4.4 / iga-canonical-standards §1.3: una sola representación
                         del documento para correlación). beforeCorrelation: poblado antes de correlar. -->
                    <name>num-documento-to-lambDocNum</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <!-- FIX RAIZ C (2026-05-31): normalizacion tipo-preservante del documento de
                                 correlacion (identica a trabajadores.xml/estudiantes.xml). Evita split de persona
                                 por ceros a la izquierda. Regla:
                                   - numerico <=8 => zfill(8) (DNI peruano canonico = 8 digitos)
                                   - numerico  >8 => strip ceros a la izquierda
                                   - no-numerico  => intacto (solo trim)
                                 Gate previo OBLIGATORIO: 0 colisiones DIFFERENT_PERSON. -->
                            <code>def d = (input ?: '').toString().trim()
if (!d) return null
if (d ==~ /\d+/) {
    return d.length() &lt;= 8 ? d.padLeft(8, '0' as char) : d.replaceFirst(/^0+(?=\d)/, '')
}
return d</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:lambDocNum</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:FEC_NACIMIENTO</ref>
                <!-- Patrón B Ola 1: weak (era strong). Autoridad jurídica = reniec-cache (RENIEC). -->
                <inbound>
                    <name>fec-nacimiento-to-birthDate</name>
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>if (input == null) return null; def s = input.toString(); s.length() >= 10 ? s.substring(0, 10) : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:birthDate</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
