            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <inbound>
                    <!-- FIX type-aware (2026-06-05): igual que estudiantes.xml/trabajadores.xml. Antes
                         hardcodeaba ':DNI:PE:' para todo documento. Ahora el URN SCHAC refleja el tipo
                         real desde TIPO_DOC (MOISES.PERSONA_NATURAL.ID_TIPODOCUMENTO). Imprescindible para
                         egresados que TAMBIEN son estudiantes activos: si egresados emitiera lambDocNum
                         type-blind y estudiantes el type-aware, habria conflicto strong/strong en lambDocNum.
                         Tipos: 1/24=DNI, 4/6/31=CE, 22=PTP, 23=CPP, 7/9=passport. -->
                    <name>dni-to-taxId-urn</name>
                    <!-- WEAK (FIX 2026-06-29 v2). Mismo patrón robusto que lambDocNum/estudiantes:
                         taxId (URN SCHAC type-aware) es single-valued y colisiona si dos fuentes clasifican
                         el doc distinto. trabajadores ya NO escribe taxId (archived) y Bloque J2 lo limpia;
                         todas las fuentes activas (estudiantes/egresados/reniec) weak con la misma forma
                         SCHAC → valores coincidentes idénticos, sin colisión. -->
                    <strength>weak</strength>
                    <source><path>$shadow/attributes/ri:NUM_DOCUMENTO</path></source>
                    <source><path>$shadow/attributes/ri:TIPO_DOC</path></source>
                    <expression>
                        <script>
                            <code>def d = (NUM_DOCUMENTO ?: '').toString().trim(); if (!d) return null
def t = (TIPO_DOC ?: '').toString().trim()
def sub = 'DNI'
if (['4','6','31'].contains(t)) sub = 'CE'
else if (t == '22') sub = 'PTP'
else if (t == '23') sub = 'CPP'
else if (['7','9'].contains(t)) sub = 'passport'
return 'urn:schac:personalUniqueID:pe:' + sub + ':PE:' + d</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
                <inbound>
                    <!-- FIX correlación cruzada (2026-05-29, runbook org-canonical sesión PM7):
                         Trabajadores correlaciona/identifica por extension/upeu:lambDocNum (NUM_DOCUMENTO
                         crudo), NO por taxId (su mapeo dni-to-taxId-urn está deprecado/archived). Por eso
                         los egresados que ADEMÁS son trabajadores tienen lambDocNum poblado pero taxId
                         vacío, y el correlador de Egresados por taxId NO los encuentra → no se proyecta
                         el shadow Egresado → no se puebla affiliations=alum. Poblamos lambDocNum aquí
                         (idéntico a trabajadores.xml: num-documento-to-lambDocNum) y añadimos un
                         correlador por lambDocNum para enlazar a esos usuarios.
                         Identificador de correlación canónico unificado entre resources de persona
                         (best-practices §4.4 / iga-canonical-standards §1.3: una sola representación
                         del documento para correlación). beforeCorrelation: poblado antes de correlar. -->
                    <name>num-documento-to-lambDocNum</name>
                    <!-- WEAK (FIX 2026-06-29 v2, colisión lambDocNum). Mismo patrón robusto que givenName:
                         un ÚNICO strong (trabajadores) por item single-valued; estudiantes/egresados WEAK.
                         El intento previo con <condition>liveAffiliationWorker==null</condition> NO funcionó:
                         liveAffiliationWorker es un valor COMPUTADO por inbound en el mismo projector wave,
                         no está disponible/estable cuando se evalúa la condición de OTRO inbound → egresados
                         seguía emitiendo strong y colisionaba (canario Gabriela: worker vivo pero condición
                         no suprimía). weak es determinista:
                           - solo-egresado → weak provee (sin strong compitiendo) ✓
                           - trabajador+egresado (Gabriela) → trabajadores strong gana, egresados weak NO
                             compite → un solo valor ✓
                         Canonicalización vía sb-document-normalizer (output byte-idéntico a trabajadores
                         para igual (num,type)). beforeCorrelation: weak igual emite la clave de correlación
                         si el foco aún no tiene lambDocNum (egresado puro). -->
                    <strength>weak</strength>
                    <source><path>$shadow/attributes/ri:NUM_DOCUMENTO</path></source>
                    <source><path>$shadow/attributes/ri:TIPO_DOC</path></source>
                    <expression>
                        <function>
                            <libraryRef oid="1c7e4b2d-3f5a-4061-ac9d-8f7e6d5c4b31" type="FunctionLibraryType"/>
                            <name>toCanonicalDocNumber</name>
                            <parameter>
                                <name>rawNum</name>
                                <expression><path>$shadow/attributes/ri:NUM_DOCUMENTO</path></expression>
                            </parameter>
                            <parameter>
                                <name>docType</name>
                                <expression><path>$shadow/attributes/ri:TIPO_DOC</path></expression>
                            </parameter>
                        </function>
                    </expression>
                    <target>
                        <path xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:lambDocNum</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
