                            <code>def p = (PATERNO ?: '').toString().trim(); def m = (MATERNO ?: '').toString().trim(); def full = (p + (m ? ' ' + m : '')).trim(); if (!full) return null; def prep = ['de','del','la','las','los','y','e','a','al','en','con','o'] as Set; def titled = full.toLowerCase().split(' ').toList().findAll { it }.withIndex().collect { w, i -&gt; (i == 0 || !(w in prep)) ? w.capitalize() : w }.join(' '); return java.text.Normalizer.normalize(titled, java.text.Normalizer.Form.NFC).replaceAll('\\s+', ' ').trim() ?: null</code>
