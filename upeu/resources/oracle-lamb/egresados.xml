            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseQuery = '''SELECT * FROM ( SELECT e.CODIGO, MAX(e.ID_PERSONA) AS ID_PERSONA, MAX(e.NOMBRE) AS NOMBRE, MAX(e.PATERNO) AS PATERNO, MAX(e.MATERNO) AS MATERNO, MAX(e.CORREO_UPEU) AS CORREO_UPEU, MAX(e.CELULAR) AS CELULAR, MAX(e.NUM_DOCUMENTO) AS NUM_DOCUMENTO, MAX(pn.ID_TIPODOCUMENTO) AS TIPO_DOC, MAX(e.FEC_NACIMIENTO) AS FEC_NACIMIENTO, MAX(e.ESCUELA_PROFESIONAL) AS ESCUELA_PROFESIONAL, MAX(e.NOM_FACULTAD) AS NOM_FACULTAD, MAX(e.NIVEL_ENSENANZA) AS NIVEL_ENSENANZA, MAX(e.MODALIDAD_ESTUDIO) AS MODALIDAD_ESTUDIO, MAX(e.ANIO) AS ANIO, MAX(e.SEMESTRE) AS SEMESTRE, MAX(pn.FOTO) AS FOTO, MAX(pn.CORREO) AS CORREO_PERSONAL, \'alum\' AS AFILIACION FROM DAVID.VW_PERSONA_EGRESADO e LEFT JOIN MOISES.PERSONA_NATURAL pn ON pn.ID_PERSONA = e.ID_PERSONA WHERE e.CODIGO IS NOT NULL GROUP BY e.CODIGO )'''; def whereClause = ''; def params = []; if (query != null) { if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { whereClause = ' WHERE CODIGO = ?'; params &lt;&lt; (query.right as String); } else { throw new UnsupportedOperationException('Egresados-v2 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } }; def finalQuery = "SELECT * FROM (${baseQuery})${whereClause}".toString(); sql.eachRow(finalQuery, params) { row -&gt; if (row.CODIGO == null || (row.CODIGO as String).trim().isEmpty()) return; result &lt;&lt; ['__UID__': (row.CODIGO as String).trim(), '__NAME__': (row.CODIGO as String).trim(), 'CODIGO': row.CODIGO as String, 'ID_PERSONA': row.ID_PERSONA as String, 'NOMBRE': row.NOMBRE as String, 'PATERNO': row.PATERNO as String, 'MATERNO': row.MATERNO as String, 'CORREO_UPEU': row.CORREO_UPEU as String, 'CELULAR': row.CELULAR as String, 'NUM_DOCUMENTO': row.NUM_DOCUMENTO as String, 'TIPO_DOC': row.TIPO_DOC?.toString(), 'FEC_NACIMIENTO': row.FEC_NACIMIENTO?.toString(), 'ESCUELA_PROFESIONAL': row.ESCUELA_PROFESIONAL as String, 'NOM_FACULTAD': row.NOM_FACULTAD as String, 'NIVEL_ENSENANZA': row.NIVEL_ENSENANZA as String, 'MODALIDAD_ESTUDIO': row.MODALIDAD_ESTUDIO as String, 'ANIO': row.ANIO?.toString(), 'SEMESTRE': row.SEMESTRE?.toString(), 'FOTO': row.FOTO as String, 'CORREO_PERSONAL': row.CORREO_PERSONAL as String, 'AFILIACION': row.AFILIACION as String] }; return result</cfg:searchScript>
