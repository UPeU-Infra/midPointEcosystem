            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseQuery = '''SELECT * FROM ( SELECT * FROM ( SELECT e.COD_APS, e.ID_PERSONA, e.NOMBRE, e.PATERNO, e.MATERNO, e.NUM_DOCUMENTO, e.ID_TIPODOCUMENTO, e.SEXO, e.FEC_NACIMIENTO, e.FEC_INICIO, e.FEC_TERMINO, e.ESTADO, e.ID_CATEGORIAOCUPACIONAL, t.CELULAR, t.CORREO_INST, t.ID_TIPOESTADOCIVIL, t.ID_SEDEAREA, t.ID_PUESTO, p.NOMBRE AS NOMBRE_PUESTO, t.FOTO, pnm.CORREO AS CORREO_PERSONAL, os.NOMBRE AS SEDE_NOMBRE, CASE WHEN cd.ID_DOCENTE IS NOT NULL THEN 'archetype-user-employee-faculty' ELSE 'archetype-user-employee-staff' END AS UPEU_ARCHETYPE_NAME, pc.ID_MOTIVO_CESE AS MOTIVO_CESE_RAW, ROW_NUMBER() OVER (PARTITION BY e.COD_APS ORDER BY CASE e.ID_TIPODOCUMENTO WHEN 1 THEN 1 WHEN 4 THEN 2 WHEN 7 THEN 3 WHEN 22 THEN 4 WHEN 24 THEN 5 WHEN 31 THEN 6 WHEN 23 THEN 7 WHEN 9 THEN 8 WHEN 6 THEN 9 WHEN 0 THEN 10 WHEN 97 THEN 11 WHEN 98 THEN 12 WHEN 99 THEN 13 ELSE 14 END ASC, e.FEC_INICIO DESC NULLS LAST) AS RN FROM ELISEO.VW_APS_EMPLEADO e LEFT JOIN ENOC.CAT_DOCENTE cd ON cd.ID_PERSONA = e.ID_PERSONA AND cd.ID_ESTADO_DOCENTE = '02' LEFT JOIN ENOC.VW_TRABAJADOR t ON t.ID_PERSONA = e.ID_PERSONA LEFT JOIN ENOC.PLLA_PUESTO p ON p.ID_PUESTO = t.ID_PUESTO LEFT JOIN MOISES.PERSONA_NATURAL pnm ON pnm.ID_PERSONA = e.ID_PERSONA LEFT JOIN ELISEO.ORG_SEDE_AREA osa ON osa.ID_SEDEAREA = t.ID_SEDEAREA LEFT JOIN ELISEO.ORG_SEDE os ON os.ID_SEDE = osa.ID_SEDE LEFT JOIN (SELECT ID_CONTRATO, ID_MOTIVO_CESE FROM ENOC.PLLA_CESE WHERE FECHA_CESE = (SELECT MAX(pc2.FECHA_CESE) FROM ENOC.PLLA_CESE pc2 WHERE pc2.ID_CONTRATO = ENOC.PLLA_CESE.ID_CONTRATO)) pc ON pc.ID_CONTRATO = e.ID_CONTRATO WHERE e.ID_EMPRESA = 201 AND e.COD_APS IS NOT NULL AND TRIM(e.COD_APS) IS NOT NULL AND NOT REGEXP_LIKE(TRIM(e.COD_APS), '^0+$') AND (e.ESTADO = 'A' OR (e.ESTADO = 'I' AND e.FEC_TERMINO >= SYSDATE - 730)) ) WHERE RN = 1 )'''; def whereClause = ''; def params = []; if (query != null) { if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { whereClause = ' WHERE COD_APS = ?'; params &lt;&lt; (query.right as String); } else { throw new UnsupportedOperationException('Trabajadores-v3 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } }; def finalQuery = "SELECT * FROM (${baseQuery})${whereClause}".toString(); sql.eachRow(finalQuery, params) { row -&gt; result &lt;&lt; ['__UID__': row.COD_APS as String, '__NAME__': row.COD_APS as String, 'COD_APS': row.COD_APS as String, 'ID_PERSONA': row.ID_PERSONA?.toString(), 'NOMBRE': row.NOMBRE as String, 'PATERNO': row.PATERNO as String, 'MATERNO': row.MATERNO as String, 'NUM_DOCUMENTO': row.NUM_DOCUMENTO as String, 'ID_TIPODOCUMENTO': row.ID_TIPODOCUMENTO?.toString(), 'SEXO': row.SEXO as String, 'FEC_NACIMIENTO': row.FEC_NACIMIENTO?.toString(), 'FEC_INICIO': row.FEC_INICIO?.toString(), 'FEC_TERMINO': row.FEC_TERMINO?.toString(), 'ESTADO': row.ESTADO as String, 'ID_CATEGORIAOCUPACIONAL': row.ID_CATEGORIAOCUPACIONAL?.toString(), 'CELULAR': row.CELULAR as String, 'CORREO_INST': row.CORREO_INST as String, 'ID_TIPOESTADOCIVIL': row.ID_TIPOESTADOCIVIL?.toString(), 'ID_SEDEAREA': row.ID_SEDEAREA?.toString(), 'ID_PUESTO': row.ID_PUESTO?.toString(), 'NOMBRE_PUESTO': row.NOMBRE_PUESTO as String, 'FOTO': row.FOTO as String, 'CORREO_PERSONAL': row.CORREO_PERSONAL as String, 'SEDE_NOMBRE': row.SEDE_NOMBRE as String, 'UPEU_ARCHETYPE_NAME': row.UPEU_ARCHETYPE_NAME as String, 'MOTIVO_CESE_RAW': row.MOTIVO_CESE_RAW?.toString()] }; return result</cfg:searchScript>
            <cfg:syncScript>return null</cfg:syncScript>
            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro("COD_APS", true)); ocib.addAttributeInfo(ro("ID_PERSONA", false)); ocib.addAttributeInfo(ro("NOMBRE", true)); ocib.addAttributeInfo(ro("PATERNO", true)); ocib.addAttributeInfo(ro("MATERNO", false)); ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false)); ocib.addAttributeInfo(ro("ID_TIPODOCUMENTO", false)); ocib.addAttributeInfo(ro("SEXO", false)); ocib.addAttributeInfo(ro("FEC_NACIMIENTO", false)); ocib.addAttributeInfo(ro("FEC_INICIO", false)); ocib.addAttributeInfo(ro("FEC_TERMINO", false)); ocib.addAttributeInfo(ro("ESTADO", true)); ocib.addAttributeInfo(ro("ID_CATEGORIAOCUPACIONAL", false)); ocib.addAttributeInfo(ro("CELULAR", false)); ocib.addAttributeInfo(ro("CORREO_INST", false)); ocib.addAttributeInfo(ro("ID_TIPOESTADOCIVIL", false)); ocib.addAttributeInfo(ro("ID_SEDEAREA", false)); ocib.addAttributeInfo(ro("ID_PUESTO", false)); ocib.addAttributeInfo(ro("NOMBRE_PUESTO", false)); ocib.addAttributeInfo(ro("FOTO", false)); ocib.addAttributeInfo(ro("CORREO_PERSONAL", false)); ocib.addAttributeInfo(ro("SEDE_NOMBRE", false)); ocib.addAttributeInfo(ro("UPEU_ARCHETYPE_NAME", true)); ocib.addAttributeInfo(ro("MOTIVO_CESE_RAW", false)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>
