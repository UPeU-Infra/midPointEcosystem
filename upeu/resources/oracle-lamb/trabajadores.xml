            <attribute>
                <!-- SEDE_NOMBRE → locality
                     IIA: ELISEO.ORG_SEDE (via JOIN ELISEO.ORG_SEDE_AREA osa ON osa.ID_SEDEAREA = t.ID_SEDEAREA).
                     Valores LAMB: "Sede Lima" → LIMA | "Filial Tarapoto" → TARAPOTO | "Filial Juliaca" → JULIACA.
                     Koha outbound usa locality para enrutar library_id: LIMA→BUL, JULIACA→BUJ, TARAPOTO→BUT.
                     strong: trabajadores tienen IIA autoritativa de sede; prevalece sobre estudiantes (weak).
                     Fase 5b multi-biblioteca: cuando BUJ/BUT se autoricen, AR-Koha se asignará a esos usuarios
                     y locality los enrutará automáticamente al branchcode correcto sin cambio adicional aquí. -->
                <ref>ri:SEDE_NOMBRE</ref>
                <inbound>
                    <name>sede-nombre-to-locality</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim(); ['Sede Lima':'LIMA','Filial Tarapoto':'TARAPOTO','Filial Juliaca':'JULIACA'].getOrDefault(v, 'LIMA')</code>
                        </script>
                    </expression>
                    <target><path>locality</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:UPEU_ARCHETYPE_NAME</ref>
                <!-- upeu-archetype-assign ELIMINADO 2026-05-18:
                     El archetype structural lo decide el Bloque D7 del Object Template
                     (UserTemplate-Person-Base) desde sb:affiliations con prioridad
                     faculty > staff > student > alum. Asignarlo aquí causa
                     PolicyViolationException "multiple structural archetypes" en usuarios
                     con doble afiliación (egresados-trabajadores).
                     MidPoint Book Cap. 8-9: resources aportan datos; templates deciden estructura. -->
                <!-- Fase 1 eduPerson 202208: archetype-to-primaryAffiliation conservado como
                     weak para retrocompatibilidad. El Bloque J3 del template (normal) calcula
                     primaryAffiliation desde affiliations con prioridad. El strong anterior fue
                     cambiado a weak para no bloquear el override del Bloque K (strong, jubilados→alum).
                     Con strong aquí, jubilados en el período de 730d post-cese tenían faculty/staff
                     escrito fuerte desde trabajadores, impidiendo que K los marcara como alum. -->
                <inbound>
                    <name>archetype-to-primaryAffiliation</name>
                    <!-- Retrocompatibilidad: weak para usuarios sin affiliations aún poblado.
                         J3 (normal) sobreescribe cuando affiliations tiene valor.
                         K (strong) sobreescribe para jubilados puros. -->
                    <strength>weak</strength>
                    <expression>
                        <script>
                            <code>input == 'archetype-user-employee-faculty' ? 'faculty' : 'staff'</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:primaryAffiliation</path>
                    </target>
                </inbound>
                <inbound>
                    <name>archetype-to-affiliations</name>
                    <!-- Fuente principal para Bloque J3. normal: permite coexistencia con
                         affiliations de egresados/estudiantes en usuarios dual-affiliation.
                         Valor: faculty o staff (lowercase eduPerson 202208). -->
                    <strength>normal</strength>
                    <expression>
                        <script>
                            <code>input == 'archetype-user-employee-faculty' ? 'faculty' : 'staff'</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:affiliations</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:MOTIVO_CESE_RAW</ref>
                <!-- MOTIVO_CESE_RAW → upeu:motivoCese
                     IIA: ENOC.PLLA_CESE.ID_MOTIVO_CESE (último cese por COD_APS, via subquery).
                     Llega para empleados con ESTADO='I' y motivo registrado en PLLA_CESE
                     (el searchScript incluye TODOS los ESTADO='I' con FEC_TERMINO >= SYSDATE-730,
                     sin filtrar por motivo). Para activos (ESTADO='A'), este campo es NULL.
                     Normalización de códigos LAMB → vocabulario canónico:
                       '05' → jubilacion (Jubilación voluntaria)
                       '18' → jubilacion (Límite de edad 70 años)
                       '09' → fallecimiento
                       '01' → renuncia (Renuncia voluntaria)
                       '02' → renuncia (Renuncia con incentivos)
                       '21' → renuncia (Renuncia por abandono)
                       '03' → despido
                       '07' → termino_contrato (Terminación obra/servicio/plazo)
                       '08' → mutuo_disenso
                       otros no-nulos → otro
                       NULL → null (no se escribe el campo; HR no registró el motivo)
                     strength=strong: se sobrescribe en cada sync. Si PLLA_CESE no tiene registro,
                     el campo queda vacío/null.
                     Esto es intencional: el IGA no infiere motivoCese si HR no lo registra. -->
                <inbound>
                    <name>motivo-cese-raw-to-motivoCese</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def v = (input ?: '').toString().trim(); if (!v) return null; if (v == '05' || v == '18') return 'jubilacion'; if (v == '09') return 'fallecimiento'; if (v == '01' || v == '02' || v == '21') return 'renuncia'; if (v == '03') return 'despido'; if (v == '07') return 'termino_contrato'; if (v == '08') return 'mutuo_disenso'; return 'otro'</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:motivoCese</path>
                    </target>
                </inbound>
            </attribute>
            <!-- Correlator explícito 4.10: reemplaza <correlator/> shorthand en ri:NUM_DOCUMENTO.
                 El shorthand en 4.10 no resuelve el focus item cuando los únicos inbounds con
                 beforeCorrelation están en lifecycleState archived.
                 MidPoint busca UserType donde extension/upeu:lambDocNum == ri:NUM_DOCUMENTO del shadow.
                 El inbound activo num-documento-to-lambDocNum popula lambDocNum antes de correlación
                 (evaluationPhases: beforeCorrelation). -->
            <correlation>
                <correlators>
                    <items>
                        <name>correlate-by-num-documento</name>
                        <item>
                            <ref xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:lambDocNum</ref>
                        </item>
                    </items>
                </correlators>
            </correlation>
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions><addFocus/></actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions><inactivateFocus/></actions>
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>
    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create>
