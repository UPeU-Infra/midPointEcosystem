                </inbound>
                <inbound>
                    <!-- DEPRECADO: transportaba el número raw a sciback:taxId (campo de transporte legacy).
                         Reemplazado por num-documento-to-lambDocNum que usa upeu:lambDocNum.
                         Se mantiene archived para trazabilidad. -->
                    <name>num-documento-raw-to-taxId-transport</name>
                    <lifecycleState>archived</lifecycleState>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def d = (input ?: '').toString().trim(); d ?: null</code>
                        </script>
                    </expression>
                    <target>
