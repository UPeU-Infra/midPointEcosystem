                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
                <inbound>
                    <!-- Transporta el número de documento raw a upeu:lambDocNum (campo de transporte canónico).
                         El Bloque J del UserTemplate-Person-Base lo combina con upeu:lambDocType
