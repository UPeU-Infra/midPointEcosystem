<?xml version="1.0" encoding="UTF-8"?>
<!--
  Task: cleanup-numeric-emails
  OID: b9e11002-f001-4abc-9def-202406060002
  Objetivo: Limpiar ~31.158 emails numéricos inventados (patrón ^\d+@upeu.edu.pe)
            seteados por el mapping B-emailAddress-fallback-from-name (archivado 2026-06-06).

  Mecanismo: iterativeScripting sobre usuarios active.
    - El script Groovy filtra internamente: solo actúa si emailAddress ~ ^\d+@upeu.edu.pe$
    - Para cada usuario con email numérico:
        1. DELETE explícito de emailAddress (el mapping archivado no produce zero-set).
        2. recompute del foco → activa B-email-review-flag del template.
           Si Entra ID tiene email real → inbound lo re-escribe.
           Si no → emailAddress=NULL y emailReviewNeeded=true.
    - Para usuarios sin email numérico: return (no-op).

  Por qué iterativeScripting y no iterativeChangeExecution:
    iterativeChangeExecution no soporta <scripts>; iterativeScripting sí (Semančík Cap.13).

  Filtro q:matches no soportado en esta versión → filtro interno en Groovy.

  Canary VALIDADO (2026-06-06): oid=03701518-e1ae-47ef-bae4-eb78ce25c347
    email_before=324109193@upeu.edu.pe → email_after=NULL + emailReviewNeeded=true

  OID determinista: b9e11002-f001-4abc-9def-202406060002
  Creado: 2026-06-06
-->
<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
      oid="b9e11002-f001-4abc-9def-202406060002">

    <name>cleanup-numeric-emails-2026-06-06</name>
    <description>Limpia emails numéricos inventados (^\d+@upeu.edu.pe). Para cada usuario con email numérico: DELETE emailAddress + recompute → emailReviewNeeded=true si Entra ID no provee email real. Canary PASS 2026-06-06. Scope: ~49K active, actúa en ~31.158 con email numérico.</description>
    <ownerRef oid="00000000-0000-0000-0000-000000000002" type="UserType"/>

    <executionState>suspended</executionState>
    <schedule>
        <recurrence>single</recurrence>
    </schedule>

    <activity>
        <work>
            <iterativeScripting>
                <objects>
                    <type>UserType</type>
                    <query>
                        <q:filter>
                            <q:equal>
                                <q:path>lifecycleState</q:path>
                                <q:value>active</q:value>
                            </q:equal>
                        </q:filter>
                    </query>
                </objects>
                <scriptExecutionRequest>
                    <execute>
                        <script>
                            <code><![CDATA[
import com.evolveum.midpoint.xml.ns._public.common.common_3.UserType

// Filtro interno: solo actúa si el email es numérico (patrón ^\d+@upeu.edu.pe$)
def email = object.emailAddress
if (email == null) return  // sin email → ya está limpio

def emailStr = email.toString().trim()
if (!emailStr.matches('^\\d+@upeu\\.edu\\.pe$')) return  // email no numérico → no tocar

// Paso 1: DELETE explícito del emailAddress numérico
def delta = prismContext.deltaFactory().object()
    .createModificationDeleteProperty(
        UserType.class,
        object.oid,
        UserType.F_EMAIL_ADDRESS,
        email
    )
midpoint.modifyObject(delta)

// Paso 2: recompute del foco → activa B-email-review-flag
midpoint.recompute(object.oid)
                            ]]></code>
                        </script>
                    </execute>
                </scriptExecutionRequest>
            </iterativeScripting>
        </work>
    </activity>

</task>
