<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
      oid="b9e11006-f001-4abc-9def-202406060006">

    <name>recompute-clean-emails-r4-20260606</name>
    <description>
        R4: recompute+reconcile usuarios active. Fix completo (commits 86779d0+3802f60+a00ae20).
        Limpia 38K emails numéricos. Entra ID strong → Oracle weak → null+emailReviewNeeded.
    </description>
    <ownerRef oid="00000000-0000-0000-0000-000000000002" type="UserType"/>
    <executionState>runnable</executionState>

    <activity>
        <work>
            <recomputation>
                <objects>
                    <type>UserType</type>
                    <query>
                        <q:filter>
                            <q:equal>
                                <q:path>lifecycleState</q:path>
                                <q:value>active</q:value>
                            </q:equal>
                        </q:filter>
                    </query>
                </objects>
                <executionOptions>
                    <reconcile>true</reconcile>
                </executionOptions>
            </recomputation>
        </work>
        <distribution>
            <workerThreads>4</workerThreads>
        </distribution>
    </activity>

</task>
