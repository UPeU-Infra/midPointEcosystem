<?xml version="1.0" encoding="UTF-8"?>
<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
      oid="b9e22001-f001-4abc-9def-202406070001">
    <name>recompute-set-email-review-flag-20260607</name>
    <ownerRef oid="00000000-0000-0000-0000-000000000002" type="UserType"/>
    <executionState>runnable</executionState>
    <activity>
        <work>
            <recomputation>
                <objects>
                    <type>UserType</type>
                    <query>
                        <q:filter>
                            <q:and>
                                <q:equal>
                                    <q:path>lifecycleState</q:path>
                                    <q:value>active</q:value>
                                </q:equal>
                                <!-- "emailAddress no existe / es null"
                                     Idiom MidPoint: NOT(equal sin value).
                                     q:exists falla en escalares (espera container).
                                     q:value/ vacío matchea string vacío, no NULL.
                                     NOT(equal-sin-value) → matchea NULL en SqaleRepo. -->
                                <q:not>
                                    <q:equal>
                                        <q:path>emailAddress</q:path>
                                    </q:equal>
                                </q:not>
                            </q:and>
                        </q:filter>
                    </query>
                </objects>
            </recomputation>
        </work>
        <distribution>
            <workerThreads>4</workerThreads>
        </distribution>
    </activity>
</task>
