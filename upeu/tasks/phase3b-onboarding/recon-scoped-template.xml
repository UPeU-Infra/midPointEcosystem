<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
      xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
      xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
      oid="d1a2b3c4-3b00-4abc-9def-0000003b0001">
    <name>phase3b-recon-scoped</name>
    <description>FASE 3b: recon Estudiantes acotado por __UID__=CODIGO (un objeto).
        addFocus si UNMATCHED, link si UNLINKED. Create-only limpio (sin borrower huerfano).
        El connector ScriptedSQL honra EqualsFilter sobre __UID__ -> pna.CODIGO=? -> scopea a Oracle.
        Driver externo reescribe el value y reejecuta por cada CODIGO del lote.</description>
    <executionState>runnable</executionState>
    <ownerRef oid="00000000-0000-0000-0000-000000000002" type="c:UserType"/>
    <activity>
        <work>
            <reconciliation>
                <resourceObjects>
                    <resourceRef oid="6a91f7e1-1b50-4dcf-9c4b-7c0c0e0e0e22" type="c:ResourceType"/>
                    <kind>account</kind>
                    <intent>default</intent>
                    <query>
                        <q:filter>
                            <q:equal>
                                <q:path>attributes/icfs:uid</q:path>
                                <q:value>__CODE__</q:value>
                            </q:equal>
                        </q:filter>
                    </query>
                </resourceObjects>
            </reconciliation>
        </work>
        <distribution><workerThreads>1</workerThreads></distribution>
    </activity>
</task>
