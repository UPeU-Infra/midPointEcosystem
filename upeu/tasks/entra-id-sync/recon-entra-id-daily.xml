<?xml version="1.0" encoding="UTF-8"?>
<!--
    UPEU-EntraID-Recon-Daily
    OID:        a1e5b2c3-0001-4def-9abc-202406060001
    Resource:   UPEU-EntraID-Graph (2f11c057-7b15-4641-a0eb-00c98a6fa4cb)
    Schedule:   2:00 AM Lima (America/Lima = UTC-5). Cron: 0 0 2 * * ?
    Propósito:  Reconciliación completa diaria de todos los shadows Entra ID.
                Garantiza que emailAddress en MidPoint converge con el estado
                real de Microsoft Graph API aunque el delta (livesync) haya
                perdido eventos (restart, gap de red, throttling Graph API).

    NOTA ARQUITECTÓNICA (lifecycleState=proposed en objectType):
    El objectType Entra ID tiene lifecycleState=proposed. Esto suprime todos
    los outbound mappings y el existence-outbound → MidPoint NUNCA intenta
    crear/actualizar cuentas en Entra ID durante esta tarea. Los inbound
    mappings (icfs:name → name, ri:mail → emailAddress) corren normalmente
    con strength=strong. La reconciliación actualiza shadows y dispara el
    focus-recompute con los inbounds activos. Correcto para Fase 1-11.
    Activar outbound en Fase 12 (David Urquizo, permiso User.ReadWrite.All).

    Workerheads: 2 hilos (Graph API tiene throttling; no saturar).
    misfireAction=executeImmediately: si el servidor estuvo down a las 2 AM,
    ejecuta en cuanto vuelva a estar disponible.
-->
<task xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
      xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
      oid="a1e5b2c3-0001-4def-9abc-202406060001">

    <name>recon-entra-id-daily</name>
    <description>Reconciliacion diaria Entra ID (Microsoft Graph API) — inbound-only. Actualiza emailAddress strong desde Entra. Cron 02:00 Lima (America/Lima). Resource lifecycleState=proposed: outbounds inertes, inbounds activos.</description>
    <ownerRef oid="00000000-0000-0000-0000-000000000002" relation="org:default" type="UserType"/>

    <executionState>runnable</executionState>

    <schedule>
        <!-- 2:00 AM Lima (America/Lima, UTC-5). Server TZ verificado: America/Lima. -->
        <!-- No solapar con Oracle LAMB (02:00 UTC ≈ 21:00 Lima día anterior). -->
        <!-- Koha ILS recon corre a las 03:00 UTC. Sin colisión. -->
        <cronLikePattern>0 0 2 * * ?</cronLikePattern>
        <misfireAction>executeImmediately</misfireAction>
    </schedule>

    <activity>
        <work>
            <reconciliation>
                <resourceObjects>
                    <resourceRef oid="2f11c057-7b15-4641-a0eb-00c98a6fa4cb" type="ResourceType"/>
                    <kind>account</kind>
                    <intent>default</intent>
                </resourceObjects>
            </reconciliation>
        </work>
        <distribution>
            <!-- Graph API tiene throttling (10,000 req/10min por tenant).
                 2 hilos es conservador y evita 429 TooManyRequests. -->
            <workerThreads>2</workerThreads>
        </distribution>
    </activity>

</task>
