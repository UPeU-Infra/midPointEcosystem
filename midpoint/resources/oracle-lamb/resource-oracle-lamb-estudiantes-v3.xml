<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
    xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
    xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
    xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
    xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    oid="6a91f7e1-1b50-4dcf-9c4b-7c0c0e0e0e22">
    <name>Oracle LAMB Estudiantes v2</name>
    <description>Inbound ScriptedSQL desde DAVID.VW_PERSONA_ALUMNO + subqueries de VW_FICHA_MATRICULA para cycle vigente y programas (LISTAGG). Fase 5a-v3 schema sb:.</description>
    <lifecycleState>active</lifecycleState>
    <connectorRef oid="e4cd8ed3-2e91-48d9-abb7-32090a5e8849" relation="org:default" type="c:ConnectorType"/>
    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:resultsHandlerConfiguration>
            <icfc:enableNormalizingResultsHandler>false</icfc:enableNormalizingResultsHandler>
            <icfc:enableFilteredResultsHandler>false</icfc:enableFilteredResultsHandler>
            <icfc:filteredResultsHandlerInValidationMode>true</icfc:filteredResultsHandlerInValidationMode>
            <icfc:enableAttributesToGetSearchResultsHandler>false</icfc:enableAttributesToGetSearchResultsHandler>
        </icfc:resultsHandlerConfiguration>
        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/net.tirasa.connid.bundles.db.scriptedsql/net.tirasa.connid.bundles.db.scriptedsql.ScriptedSQLConnector">
            <cfg:host>192.168.13.9</cfg:host>
            <cfg:port>1521</cfg:port>
            <cfg:user>JUANSANCHEZ</cfg:user>
            <cfg:password>
                <t:encryptedData>
                    <t:encryptionMethod>
                        <t:algorithm>http://www.w3.org/2001/04/xmlenc#aes256-cbc</t:algorithm>
                    </t:encryptionMethod>
                    <t:keyInfo>
                        <t:keyName>nkZ4VieDLlRmwD8hdryrmjz8IxQ=</t:keyName>
                    </t:keyInfo>
                    <t:cipherData>
                        <t:cipherValue>s3rJv3xg278GQMnS0vOO2cQQ6vXL2ShnJ2hhQaYPmUeOtb1O1qpyXjrVZ/rS6Ij4</t:cipherValue>
                    </t:cipherData>
                </t:encryptedData>
            </cfg:password>
            <cfg:database>UPEU</cfg:database>
            <cfg:jdbcDriver>oracle.jdbc.OracleDriver</cfg:jdbcDriver>
            <cfg:jdbcUrlTemplate>jdbc:oracle:thin:@%h:%p/%d</cfg:jdbcUrlTemplate>
            <cfg:rethrowAllSQLExceptions>true</cfg:rethrowAllSQLExceptions>
            <cfg:nativeTimestamps>true</cfg:nativeTimestamps>
            <cfg:allNative>false</cfg:allNative>
            <cfg:scriptingLanguage>GROOVY</cfg:scriptingLanguage>
            <cfg:reloadScriptOnExecution>false</cfg:reloadScriptOnExecution>
            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseSelect = 'SELECT a.CODIGO, a.NOMBRE, a.PATERNO, a.MATERNO, a.CORREO_UPEU, a.CELULAR, a.FEC_NACIMIENTO, a.CODIGO_SEXO, a.NUM_DOCUMENTO, f.STUDENT_CYCLE, f.PROGRAM_CODES, f.SCHOOL_NAME FROM DAVID.VW_PERSONA_ALUMNO a INNER JOIN ( SELECT DISTINCT ID_ALUMNO FROM DAVID.VW_FICHA_MATRICULA WHERE ID_SEMESTRE = 279 ) sem ON sem.ID_ALUMNO = a.ID_PERSONA LEFT JOIN ( SELECT ID_ALUMNO, MAX(CICLO) AS STUDENT_CYCLE, LISTAGG(TO_CHAR(ID_PROGRAMA_ESTUDIO), \',\') WITHIN GROUP (ORDER BY ID_PROGRAMA_ESTUDIO) AS PROGRAM_CODES, MAX(NOMBRE_ESCUELA) AS SCHOOL_NAME FROM DAVID.VW_FICHA_MATRICULA WHERE ID_SEMESTRE = 279 GROUP BY ID_ALUMNO ) f ON f.ID_ALUMNO = a.ID_PERSONA WHERE a.CORREO_UPEU IS NOT NULL'; def finalQuery = ''; def params = []; if (query != null &amp;&amp; query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { finalQuery = baseSelect + ' AND a.CODIGO = ?'; params &lt;&lt; (query.right as String); } else if (query != null) { throw new UnsupportedOperationException('Estudiantes-v3 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } else { finalQuery = baseSelect + ' AND a.CODIGO = \'202212349\''; }; sql.eachRow(finalQuery, params) { row -&gt; def map = [:]; map['__UID__'] = row.CODIGO as String; map['__NAME__'] = row.CODIGO as String; map['CODIGO'] = row.CODIGO as String; map['NOMBRE'] = row.NOMBRE as String; map['PATERNO'] = row.PATERNO as String; map['MATERNO'] = row.MATERNO as String; map['CORREO_UPEU'] = row.CORREO_UPEU as String; map['CELULAR'] = row.CELULAR as String; map['FEC_NACIMIENTO'] = row.FEC_NACIMIENTO?.toString(); map['CODIGO_SEXO'] = row.CODIGO_SEXO as String; map['NUM_DOCUMENTO'] = row.NUM_DOCUMENTO as String; map['STUDENT_CYCLE'] = row.STUDENT_CYCLE?.toString(); if (row.PROGRAM_CODES != null) { def codes = (row.PROGRAM_CODES as String).split(',').collect { it.trim() }.findAll { it }.unique(); if (codes) map['PROGRAM_CODES'] = codes; }; map['SCHOOL_NAME'] = row.SCHOOL_NAME as String; result &lt;&lt; map }; return result</cfg:searchScript>
            <cfg:syncScript>return null</cfg:syncScript>
            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required, boolean multiValued = false -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.setMultiValued(multiValued); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro("CODIGO", true)); ocib.addAttributeInfo(ro("NOMBRE", true)); ocib.addAttributeInfo(ro("PATERNO", false)); ocib.addAttributeInfo(ro("MATERNO", false)); ocib.addAttributeInfo(ro("CORREO_UPEU", false)); ocib.addAttributeInfo(ro("CELULAR", false)); ocib.addAttributeInfo(ro("FEC_NACIMIENTO", false)); ocib.addAttributeInfo(ro("CODIGO_SEXO", false)); ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false)); ocib.addAttributeInfo(ro("STUDENT_CYCLE", false)); ocib.addAttributeInfo(ro("PROGRAM_CODES", false, true)); ocib.addAttributeInfo(ro("SCHOOL_NAME", false)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>
            <cfg:testScript>import groovy.sql.Sql; def sql = new Sql(connection); sql.firstRow("SELECT 1 AS OK FROM DUAL"); return "OK"</cfg:testScript>
        </icfc:configurationProperties>
    </connectorConfiguration>
    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>default</intent>
            <displayName>Alumno UPeU (LAMB SIS v3)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
                <archetypeRef oid="3037fbd2-db02-4ffd-8b1a-83fab5e686aa" relation="org:default" type="ArchetypeType"/>
            </focus>
            <attribute>
                <ref>ri:CODIGO</ref>
                <inbound>
                    <name>codigo-to-name</name>
                    <strength>weak</strength>
                    <target><path>name</path></target>
                </inbound>
                <inbound>
                    <name>codigo-to-personalNumber</name>
                    <strength>weak</strength>
                    <target><path>personalNumber</path></target>
                </inbound>
                <inbound>
                    <name>codigo-to-institutionalCode</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:institutionalCode</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NOMBRE</ref>
                <inbound>
                    <name>nombre-to-givenName</name>
                    <strength>strong</strength>
                    <target><path>givenName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:PATERNO</ref>
                <inbound>
                    <name>paterno-materno-to-familyName</name>
                    <strength>strong</strength>
                    <source><path>$shadow/attributes/ri:PATERNO</path></source>
                    <source><path>$shadow/attributes/ri:MATERNO</path></source>
                    <expression>
                        <script>
                            <code>
                                def p = (PATERNO ?: '').toString().trim()
                                def m = (MATERNO ?: '').toString().trim()
                                (p + (m ? ' ' + m : '')).trim() ?: null
                            </code>
                        </script>
                    </expression>
                    <target><path>familyName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CORREO_UPEU</ref>
                <inbound>
                    <name>correo-upeu-to-emailAddress</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>(input ?: '').toString().trim().toLowerCase() ?: null</code>
                        </script>
                    </expression>
                    <target><path>emailAddress</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CELULAR</ref>
                <inbound>
                    <name>celular-to-telephoneNumber</name>
                    <strength>strong</strength>
                    <target><path>telephoneNumber</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <correlator/>
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
                                def d = (input ?: '').toString().trim()
                                d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:FEC_NACIMIENTO</ref>
                <inbound>
                    <name>fec-nacimiento-to-birthDate</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
                                if (input == null) return null
                                def s = input.toString()
                                s.length() >= 10 ? s.substring(0, 10) : null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:birthDate</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CODIGO_SEXO</ref>
                <inbound>
                    <name>codigo-sexo-to-gender-iso5218</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
                                switch ((input ?: '').toString().toUpperCase()) {
                                    case 'M': return '1'
                                    case 'F': return '2'
                                    default:  return '0'
                                }
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:gender</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:STUDENT_CYCLE</ref>
                <inbound>
                    <name>student-cycle-to-extension</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:studentCycle</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:PROGRAM_CODES</ref>
                <inbound>
                    <name>program-codes-to-extension</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:academicProgramCode</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:SCHOOL_NAME</ref>
                <inbound>
                    <name>school-name-to-academicProgramUri</name>
                    <strength>strong</strength>
                    <expression>
                        <function>
                            <libraryRef oid="6a99f9de-5db6-43d5-9b20-0cfd2b79ecf9" type="FunctionLibraryType"/>
                            <name>resolveProgramUri</name>
                            <parameter>
                                <name>programText</name>
                                <expression><path>$input</path></expression>
                            </parameter>
                        </function>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:academicProgramUri</path>
                    </target>
                </inbound>
                <inbound>
                    <name>school-name-to-academicProgramRole</name>
                    <strength>weak</strength>
                    <expression>
                        <value>student</value>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:academicProgramRole</path>
                    </target>
                </inbound>
                <inbound>
                    <name>school-name-to-primaryAffiliation</name>
                    <strength>strong</strength>
                    <expression>
                        <value>STUDENT</value>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:primaryAffiliation</path>
                    </target>
                </inbound>
            </attribute>
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions><addFocus/></actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions><inactivateFocus/></actions>
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>
    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create>
                <cap:enabled>false</cap:enabled>
            </cap:create>
            <cap:update>
                <cap:enabled>false</cap:enabled>
            </cap:update>
            <cap:delete>
                <cap:enabled>false</cap:enabled>
            </cap:delete>
        </configured>
    </capabilities>
    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>
</resource>
