import org.identityconnectors.framework.common.objects.ObjectClass
import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder

// Convención del connector Tirasa commons-scripted (AbstractScriptedConnector#schema):
//  - El binding `builder` es un org.identityconnectors.framework.common.objects.SchemaBuilder.
//  - El script DEBE MUTAR `builder` (builder.defineObjectClass(...)); el valor de
//    retorno se ignora. Tras el script, el connector hace builder.build().
//  - ConnId añade automáticamente __NAME__ (required). __UID__ es implícito.
// Atributos read-only (resource inbound-only; create/update/delete deshabilitados).

def ro = { String attrName, boolean required -&gt;
    def aib = new AttributeInfoBuilder(attrName, String.class)
    aib.setRequired(required)
    aib.setCreateable(false)
    aib.setUpdateable(false)
    aib.setReadable(true)
    aib.build()
}

def ocib = new ObjectClassInfoBuilder()
ocib.setType(ObjectClass.ACCOUNT_NAME)

ocib.addAttributeInfo(ro("COD_APS", true))                  // = __UID__/__NAME__ (también atributo regular)
ocib.addAttributeInfo(ro("NOMBRE", true))
ocib.addAttributeInfo(ro("PATERNO", true))
