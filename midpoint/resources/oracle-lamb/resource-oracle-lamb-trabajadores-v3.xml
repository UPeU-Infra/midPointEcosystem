    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>default</intent>
            <displayName>Empleado UPeU (LAMB RRHH v3)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
                <!-- Sin archetypeRef aquí: el archetype se asigna dinámicamente
                     vía inbound UPEU_ARCHETYPE_NAME → assignmentTargetSearch.
                     Esto permite mapear faculty vs staff desde el mismo resource. -->
            </focus>

            <!-- ──────────────────────────────────────────────
                 IDENTIFICADORES
            ────────────────────────────────────────────── -->
            <attribute>
                <ref>ri:COD_APS</ref>
                <!-- COD_APS = identificador inmutable del empleado en LAMB.
                     Mapea a name (username técnico) y a personalNumber (correlación HR). -->
                <inbound>
                    <name>cod-aps-to-name</name>
                    <strength>strong</strength>
                    <target>
                        <path>name</path>
                    </target>
                </inbound>
                <inbound>
                    <name>cod-aps-to-personalNumber</name>
                    <strength>strong</strength>
                    <target>
                        <path>personalNumber</path>
                    </target>
                </inbound>
            </attribute>

            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <!-- Correlador: NUM_DOCUMENTO (DNI) contra extension/sb:taxId (campo URN plano
                     indexado en el schema sb: canónico). Approach:
                       1. El inbound construye el URN SCHAC y lo guarda en sb:taxId.
                       2. El <correlator/> declara que este atributo se usa para correlación.
                     sb:taxId está marcado deprecated en schema pero sigue activo e indexado
                     — es el campo correcto para correlación simple hasta que se implemente
                     correlación por sub-campo de container (IdentityDocumentType). -->
                <correlator/>
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
def d = (input ?: '').toString().trim()
d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>

            <!-- ──────────────────────────────────────────────
                 NOMBRE
            ────────────────────────────────────────────── -->
            <attribute>
                <ref>ri:NOMBRE</ref>
                <!-- Nombres propios. AS-IS: ALL CAPS (formato RENIEC/DNI). No aplicar INITCAP. -->
                <inbound>
                    <name>nombre-to-givenName</name>
                    <strength>strong</strength>
                    <target>
                        <path>givenName</path>
                    </target>
                </inbound>
            </attribute>

            <attribute>
                <ref>ri:PATERNO</ref>
                <!-- familyName = PATERNO + ' ' + MATERNO (ambos fuentes; script combina). -->
                <inbound>
                    <name>paterno-materno-to-familyName</name>
                    <strength>strong</strength>
                    <source>
                        <path>$shadow/attributes/ri:PATERNO</path>
                    </source>
                    <source>
                        <path>$shadow/attributes/ri:MATERNO</path>
                    </source>
                    <expression>
                        <script>
                            <code>
def p = (PATERNO ?: '').toString().trim()
def m = (MATERNO ?: '').toString().trim()
(p + (m ? ' ' + m : '')).trim() ?: null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path>familyName</path>
                    </target>
                </inbound>
            </attribute>

            <!-- ──────────────────────────────────────────────
                 DATOS LABORALES (schema sb: canónico)
            ────────────────────────────────────────────── -->
            <attribute>
                <ref>ri:FEC_INICIO</ref>
                <inbound>
                    <name>fec-inicio-to-hireDate</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
if (input == null) return null
def s = input.toString()
s.length() >= 10 ? s.substring(0, 10) : null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:hireDate</path>
                    </target>
                </inbound>
            </attribute>

            <attribute>
                <ref>ri:FEC_TERMINO</ref>
                <inbound>
                    <name>fec-termino-to-terminationDate</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
if (input == null) return null
def s = input.toString()
s.length() >= 10 ? s.substring(0, 10) : null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:terminationDate</path>
                    </target>
                </inbound>
            </attribute>

            <attribute>
                <ref>ri:ID_CATEGORIAOCUPACIONAL</ref>
                <!-- employeeCategory: código de categoría ocupacional LAMB tal cual (AS-IS).
                     No se transforma aquí; la capa de roles/BR lo consume para PBAC. -->
                <inbound>
                    <name>categoria-to-employeeCategory</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:employeeCategory</path>
                    </target>
                </inbound>
            </attribute>

            <attribute>
                <ref>ri:ESTADO</ref>
                <!-- Activación: ESTADO='A' → enabled; cualquier otro valor → disabled.
                     IIA para estado de cuenta: Oracle LAMB (no AD, no Keycloak). -->
                <inbound>
                    <name>estado-to-administrativeStatus</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>(input == 'A') ? 'enabled' : 'disabled'</code>
                        </script>
                    </expression>
                    <target>
                        <path>activation/administrativeStatus</path>
                    </target>
                </inbound>
            </attribute>

            <!-- ──────────────────────────────────────────────
                 IDENTIFICADORES LAMB (schema upeu:local)
            ────────────────────────────────────────────── -->
            <!-- lambIdPersona no está disponible en VW_APS_EMPLEADO directamente;
                 se omite aquí. Si se agrega a la query en el futuro, descomentar. -->
            <!--
            <attribute>
                <ref>ri:ID_PERSONA</ref>
                <inbound>
                    <name>id-persona-to-lambIdPersona</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:upeu="urn:upeu:midpoint:local">extension/upeu:lambIdPersona</path>
                    </target>
                </inbound>
            </attribute>
            -->

            <!-- ──────────────────────────────────────────────
                 ARCHETYPE DINÁMICO
                 UPEU_ARCHETYPE_NAME viene del CASE WHEN de la query:
                   'archetype-user-employee-faculty' o 'archetype-user-employee-staff'
                 Se asigna como assignment vía assignmentTargetSearch para que
                 MidPoint active el archetype correcto al crear el focus.
            ────────────────────────────────────────────── -->
            <attribute>
                <ref>ri:UPEU_ARCHETYPE_NAME</ref>
                <inbound>
                    <name>upeu-archetype-assign</name>
                    <strength>strong</strength>
                    <expression>
                        <assignmentTargetSearch>
                            <targetType>ArchetypeType</targetType>
                            <filter>
                                <q:equal>
                                    <q:path>name</q:path>
                                    <expression>
                                        <path>$input</path>
                                    </expression>
                                </q:equal>
                            </filter>
                        </assignmentTargetSearch>
                    </expression>
                    <target>
                        <path>assignment</path>
                    </target>
                </inbound>
            </attribute>

            <!-- ──────────────────────────────────────────────
                 CORRELACIÓN
                 Correlador por NUM_DOCUMENTO (DNI).
                 El inbound dni-to-identityDocument-primary ya declara
                 evaluationPhases/beforeCorrelation para que el valor esté
                 disponible. El <correlator/> en el atributo activa la
                 correlación automática por ese atributo.
                 Fallback: si no hay DNI, queda unmatched → addFocus.
            ────────────────────────────────────────────── -->

            <!-- ──────────────────────────────────────────────
                 SYNCHRONIZATION REACTIONS
            ────────────────────────────────────────────── -->
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions>
                        <link/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions>
                        <addFocus/>
                    </actions>
                </reaction>
                <reaction>
                    <!-- deleted = el shadow desapareció de Oracle (empleado inactivado).
                         inactivateFocus cambia administrativeStatus a disabled;
                         NO se elimina el user (retención ISO 24760 / JML Leaver). -->
                    <situation>deleted</situation>
                    <actions>
                        <inactivateFocus/>
                    </actions>
                </reaction>
            </synchronization>

        </objectType>
    </schemaHandling>

    <capabilities>
