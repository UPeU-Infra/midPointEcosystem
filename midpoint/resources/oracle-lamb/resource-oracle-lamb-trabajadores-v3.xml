<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
    xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
    xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
    xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
    xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    oid="6a91f7e1-1b50-4dcf-9c4b-7c0c0e0e0e21">
    <name>Oracle LAMB Trabajadores v2</name>
    <description>Inbound ScriptedSQL desde ELISEO.VW_APS_EMPLEADO + JOIN ENOC.CAT_DOCENTE. SchemaHandling migrado a schema canónico sb:. Fase 5a-v3.</description>
    <lifecycleState>active</lifecycleState>
    <connectorRef oid="e4cd8ed3-2e91-48d9-abb7-32090a5e8849" relation="org:default" type="c:ConnectorType"/>
    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:resultsHandlerConfiguration>
            <icfc:enableNormalizingResultsHandler>false</icfc:enableNormalizingResultsHandler>
            <icfc:enableFilteredResultsHandler>false</icfc:enableFilteredResultsHandler>
            <icfc:filteredResultsHandlerInValidationMode>true</icfc:filteredResultsHandlerInValidationMode>
            <icfc:enableAttributesToGetSearchResultsHandler>false</icfc:enableAttributesToGetSearchResultsHandler>
        </icfc:resultsHandlerConfiguration>
        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/net.tirasa.connid.bundles.db.scriptedsql/net.tirasa.connid.bundles.db.scriptedsql.ScriptedSQLConnector">
            <cfg:host>192.168.13.9</cfg:host>
            <cfg:port>1521</cfg:port>
            <cfg:user>JUANSANCHEZ</cfg:user>
            <cfg:password>
                <t:encryptedData>
                    <t:encryptionMethod>
                        <t:algorithm>http://www.w3.org/2001/04/xmlenc#aes256-cbc</t:algorithm>
                    </t:encryptionMethod>
                    <t:keyInfo>
                        <t:keyName>nkZ4VieDLlRmwD8hdryrmjz8IxQ=</t:keyName>
                    </t:keyInfo>
                    <t:cipherData>
                        <t:cipherValue>5PiBLf405M3U4ulm9p6WfqMMVVwtOcVl5PuL6/CqPRMTmbA5Aoa/axj4ks8onfI2</t:cipherValue>
                    </t:cipherData>
                </t:encryptedData>
            </cfg:password>
            <cfg:database>UPEU</cfg:database>
            <cfg:jdbcDriver>oracle.jdbc.OracleDriver</cfg:jdbcDriver>
            <cfg:jdbcUrlTemplate>jdbc:oracle:thin:@%h:%p/%d</cfg:jdbcUrlTemplate>
            <cfg:rethrowAllSQLExceptions>true</cfg:rethrowAllSQLExceptions>
            <cfg:nativeTimestamps>true</cfg:nativeTimestamps>
            <cfg:allNative>false</cfg:allNative>
            <cfg:scriptingLanguage>GROOVY</cfg:scriptingLanguage>
            <cfg:reloadScriptOnExecution>false</cfg:reloadScriptOnExecution>
            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseQuery = '''SELECT * FROM ( SELECT * FROM ( SELECT e.COD_APS, e.NOMBRE, e.PATERNO, e.MATERNO, e.NUM_DOCUMENTO, e.FEC_INICIO, e.FEC_TERMINO, e.ESTADO, e.ID_CATEGORIAOCUPACIONAL, CASE WHEN cd.ID_DOCENTE IS NOT NULL THEN 'archetype-user-employee-faculty' ELSE 'archetype-user-employee-staff' END AS UPEU_ARCHETYPE_NAME, ROW_NUMBER() OVER (PARTITION BY e.COD_APS ORDER BY CASE e.ID_TIPODOCUMENTO WHEN 1 THEN 1 WHEN 4 THEN 2 WHEN 7 THEN 3 WHEN 22 THEN 4 WHEN 24 THEN 5 WHEN 31 THEN 6 WHEN 23 THEN 7 WHEN 9 THEN 8 WHEN 6 THEN 9 WHEN 0 THEN 10 WHEN 97 THEN 11 WHEN 98 THEN 12 WHEN 99 THEN 13 ELSE 14 END ASC, e.FEC_INICIO DESC NULLS LAST) AS RN FROM ELISEO.VW_APS_EMPLEADO e LEFT JOIN ENOC.CAT_DOCENTE cd ON cd.ID_PERSONA = e.ID_PERSONA AND cd.ID_ESTADO_DOCENTE = '02' WHERE e.ESTADO = 'A' AND e.COD_APS IS NOT NULL AND TRIM(e.COD_APS) IS NOT NULL AND NOT REGEXP_LIKE(TRIM(e.COD_APS), '^0+$') ) WHERE RN = 1 )'''; def whereClause = ''; def params = []; if (query != null) { if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { whereClause = ' WHERE COD_APS = ?'; params &lt;&lt; (query.right as String); } else { throw new UnsupportedOperationException('Trabajadores-v2 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } }; def finalQuery = "SELECT * FROM (${baseQuery})${whereClause}".toString(); sql.eachRow(finalQuery, params) { row -&gt; result &lt;&lt; ['__UID__': row.COD_APS as String, '__NAME__': row.COD_APS as String, 'COD_APS': row.COD_APS as String, 'NOMBRE': row.NOMBRE as String, 'PATERNO': row.PATERNO as String, 'MATERNO': row.MATERNO as String, 'NUM_DOCUMENTO': row.NUM_DOCUMENTO as String, 'FEC_INICIO': row.FEC_INICIO?.toString(), 'FEC_TERMINO': row.FEC_TERMINO?.toString(), 'ESTADO': row.ESTADO as String, 'ID_CATEGORIAOCUPACIONAL': row.ID_CATEGORIAOCUPACIONAL?.toString(), 'UPEU_ARCHETYPE_NAME': row.UPEU_ARCHETYPE_NAME as String] }; return result</cfg:searchScript>
            <cfg:syncScript>return null</cfg:syncScript>
            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro("COD_APS", true)); ocib.addAttributeInfo(ro("NOMBRE", true)); ocib.addAttributeInfo(ro("PATERNO", true)); ocib.addAttributeInfo(ro("MATERNO", false)); ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false)); ocib.addAttributeInfo(ro("FEC_INICIO", false)); ocib.addAttributeInfo(ro("FEC_TERMINO", false)); ocib.addAttributeInfo(ro("ESTADO", true)); ocib.addAttributeInfo(ro("ID_CATEGORIAOCUPACIONAL", false)); ocib.addAttributeInfo(ro("UPEU_ARCHETYPE_NAME", true)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>
            <cfg:testScript>import groovy.sql.Sql; def sql = new Sql(connection); sql.firstRow("SELECT 1 AS OK FROM DUAL"); return "OK"</cfg:testScript>
        </icfc:configurationProperties>
    </connectorConfiguration>
    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>default</intent>
            <displayName>Empleado UPeU (LAMB RRHH v3)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
            </focus>
            <attribute>
                <ref>ri:COD_APS</ref>
                <inbound>
                    <name>cod-aps-to-name</name>
                    <strength>strong</strength>
                    <target><path>name</path></target>
                </inbound>
                <inbound>
                    <name>cod-aps-to-personalNumber</name>
                    <strength>strong</strength>
                    <target><path>personalNumber</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NOMBRE</ref>
                <inbound>
                    <name>nombre-to-givenName</name>
                    <strength>strong</strength>
                    <target><path>givenName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:PATERNO</ref>
                <inbound>
                    <name>paterno-materno-to-familyName</name>
                    <strength>strong</strength>
                    <source><path>$shadow/attributes/ri:PATERNO</path></source>
                    <source><path>$shadow/attributes/ri:MATERNO</path></source>
                    <expression>
                        <script>
                            <code>def p = (PATERNO ?: '').toString().trim(); def m = (MATERNO ?: '').toString().trim(); (p + (m ? ' ' + m : '')).trim() ?: null</code>
                        </script>
                    </expression>
                    <target><path>familyName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <correlator/>
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def d = (input ?: '').toString().trim(); d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:FEC_INICIO</ref>
                <inbound>
                    <name>fec-inicio-to-hireDate</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>if (input == null) return null; def s = input.toString(); s.length() >= 10 ? s.substring(0, 10) : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:hireDate</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:FEC_TERMINO</ref>
                <inbound>
                    <name>fec-termino-to-terminationDate</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>if (input == null) return null; def s = input.toString(); s.length() >= 10 ? s.substring(0, 10) : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:terminationDate</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:ID_CATEGORIAOCUPACIONAL</ref>
                <inbound>
                    <name>categoria-to-employeeCategory</name>
                    <strength>strong</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:employeeCategory</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:ESTADO</ref>
                <inbound>
                    <name>estado-to-administrativeStatus</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>(input == 'A') ? 'enabled' : 'disabled'</code>
                        </script>
                    </expression>
                    <target><path>activation/administrativeStatus</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:UPEU_ARCHETYPE_NAME</ref>
                <inbound>
                    <name>upeu-archetype-assign</name>
                    <strength>strong</strength>
                    <expression>
                        <assignmentTargetSearch>
                            <targetType>ArchetypeType</targetType>
                            <filter>
                                <q:equal>
                                    <q:path>name</q:path>
                                    <expression><path>$input</path></expression>
                                </q:equal>
                            </filter>
                        </assignmentTargetSearch>
                    </expression>
                    <target><path>assignment</path></target>
                </inbound>
            </attribute>
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions><addFocus/></actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions><inactivateFocus/></actions>
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>
    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create>
                <cap:enabled>false</cap:enabled>
            </cap:create>
            <cap:update>
                <cap:enabled>false</cap:enabled>
            </cap:update>
            <cap:delete>
                <cap:enabled>false</cap:enabled>
            </cap:delete>
        </configured>
    </capabilities>
    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>
</resource>
