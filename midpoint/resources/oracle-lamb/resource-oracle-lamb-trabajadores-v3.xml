            <cap:create>
                <cap:enabled>false</cap:enabled>
            </cap:create>
            <cap:update>
                <cap:enabled>false</cap:enabled>
            </cap:update>
            <cap:delete>
                <cap:enabled>false</cap:enabled>
            </cap:delete>
        </configured>
    </capabilities>

    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>

</resource>
