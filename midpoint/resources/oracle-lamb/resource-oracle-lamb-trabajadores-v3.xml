            <cfg:searchScript><![CDATA[
import groovy.sql.Sql
def sql = new Sql(connection)
def result = []
def baseQuery = '''SELECT * FROM (
  SELECT * FROM (
    SELECT
      e.COD_APS, e.NOMBRE, e.PATERNO, e.MATERNO, e.NUM_DOCUMENTO,
      e.FEC_INICIO, e.FEC_TERMINO, e.ESTADO, e.ID_CATEGORIAOCUPACIONAL,
      CASE WHEN cd.ID_DOCENTE IS NOT NULL
           THEN 'archetype-user-employee-faculty'
           ELSE 'archetype-user-employee-staff'
      END AS UPEU_ARCHETYPE_NAME,
      ROW_NUMBER() OVER (
        PARTITION BY e.COD_APS
        ORDER BY CASE e.ID_TIPODOCUMENTO
          WHEN 1 THEN 1 WHEN 4 THEN 2 WHEN 7 THEN 3 WHEN 22 THEN 4
          WHEN 24 THEN 5 WHEN 31 THEN 6 WHEN 23 THEN 7 WHEN 9 THEN 8
          WHEN 6 THEN 9 WHEN 0 THEN 10 WHEN 97 THEN 11 WHEN 98 THEN 12
          WHEN 99 THEN 13 ELSE 14 END ASC,
        e.FEC_INICIO DESC NULLS LAST
      ) AS RN
    FROM ELISEO.VW_APS_EMPLEADO e
    LEFT JOIN ENOC.CAT_DOCENTE cd ON cd.ID_PERSONA = e.ID_PERSONA AND cd.ID_ESTADO_DOCENTE = '02'
    WHERE e.ESTADO = 'A' AND e.COD_APS IS NOT NULL
      AND TRIM(e.COD_APS) IS NOT NULL AND NOT REGEXP_LIKE(TRIM(e.COD_APS), '^0+$')
  ) WHERE RN = 1
)'''
def whereClause = ''
def params = []
if (query != null) {
    if (query.operation == 'EQUALS' && !query.not && (query.left == '__NAME__' || query.left == '__UID__')) {
        whereClause = ' WHERE COD_APS = ?'
        params << (query.right as String)
    } else {
        throw new UnsupportedOperationException('Trabajadores-v3 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query)
    }
}
def finalQuery = "SELECT * FROM (${baseQuery.trim()})${whereClause}".toString()
sql.eachRow(finalQuery, params) { row ->
    result << [
        '__UID__': row.COD_APS as String, '__NAME__': row.COD_APS as String,
        'COD_APS': row.COD_APS as String, 'NOMBRE': row.NOMBRE as String,
        'PATERNO': row.PATERNO as String, 'MATERNO': row.MATERNO as String,
        'NUM_DOCUMENTO': row.NUM_DOCUMENTO as String,
        'FEC_INICIO': row.FEC_INICIO?.toString(), 'FEC_TERMINO': row.FEC_TERMINO?.toString(),
        'ESTADO': row.ESTADO as String,
        'ID_CATEGORIAOCUPACIONAL': row.ID_CATEGORIAOCUPACIONAL?.toString(),
        'UPEU_ARCHETYPE_NAME': row.UPEU_ARCHETYPE_NAME as String
    ]
}
return result
]]></cfg:searchScript>
