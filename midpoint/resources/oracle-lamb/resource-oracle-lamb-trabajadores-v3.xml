            <cfg:schemaScript><![CDATA[
import org.identityconnectors.framework.common.objects.AttributeInfoBuilder
import org.identityconnectors.framework.common.objects.ObjectClass
import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder
def ro = { String attrName, boolean required ->
    def aib = new AttributeInfoBuilder(attrName, String.class)
    aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true)
    aib.build()
}
def ocib = new ObjectClassInfoBuilder()
ocib.setType(ObjectClass.ACCOUNT_NAME)
ocib.addAttributeInfo(ro("COD_APS", true))
ocib.addAttributeInfo(ro("NOMBRE", true))
ocib.addAttributeInfo(ro("PATERNO", true))
ocib.addAttributeInfo(ro("MATERNO", false))
ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false))
ocib.addAttributeInfo(ro("FEC_INICIO", false))
ocib.addAttributeInfo(ro("FEC_TERMINO", false))
ocib.addAttributeInfo(ro("ESTADO", true))
ocib.addAttributeInfo(ro("ID_CATEGORIAOCUPACIONAL", false))
ocib.addAttributeInfo(ro("UPEU_ARCHETYPE_NAME", true))
builder.defineObjectClass(ocib.build())
]]></cfg:schemaScript>
