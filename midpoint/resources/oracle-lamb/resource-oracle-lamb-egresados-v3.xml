                <inbound>
                    <name>fec-nacimiento-to-birthDate</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
if (input == null) return null
def s = input.toString()
s.length() >= 10 ? s.substring(0, 10) : null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:birthDate</path>
                    </target>
                </inbound>
            </attribute>

            <!-- ──────────────────────────────────────────────
                 CORRELACIÓN
