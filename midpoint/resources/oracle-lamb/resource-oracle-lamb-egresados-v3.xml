<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
    xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
    xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
    xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
    xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
    xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    oid="6a91f7e1-1b50-4dcf-9c4b-7c0c0e0e0e23">
    <name>Oracle LAMB Egresados v2</name>
    <description>Inbound ScriptedSQL desde DAVID.VW_PERSONA_EGRESADO con dedup por CODIGO. Fase 5a-v3 schema sb:.</description>
    <lifecycleState>active</lifecycleState>
    <connectorRef oid="e4cd8ed3-2e91-48d9-abb7-32090a5e8849" relation="org:default" type="c:ConnectorType"/>
    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:resultsHandlerConfiguration>
            <icfc:enableNormalizingResultsHandler>false</icfc:enableNormalizingResultsHandler>
            <icfc:enableFilteredResultsHandler>false</icfc:enableFilteredResultsHandler>
            <icfc:filteredResultsHandlerInValidationMode>true</icfc:filteredResultsHandlerInValidationMode>
            <icfc:enableAttributesToGetSearchResultsHandler>false</icfc:enableAttributesToGetSearchResultsHandler>
        </icfc:resultsHandlerConfiguration>
        <icfc:configurationProperties xmlns:cfg="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/net.tirasa.connid.bundles.db.scriptedsql/net.tirasa.connid.bundles.db.scriptedsql.ScriptedSQLConnector">
            <cfg:host>192.168.13.9</cfg:host>
            <cfg:port>1521</cfg:port>
            <cfg:user>JUANSANCHEZ</cfg:user>
            <cfg:password>
                <t:encryptedData>
                    <t:encryptionMethod>
                        <t:algorithm>http://www.w3.org/2001/04/xmlenc#aes256-cbc</t:algorithm>
                    </t:encryptionMethod>
                    <t:keyInfo>
                        <t:keyName>nkZ4VieDLlRmwD8hdryrmjz8IxQ=</t:keyName>
                    </t:keyInfo>
                    <t:cipherData>
                        <t:cipherValue>cbS0z8iJBH65IpXN1rHu7W+A4kDoVjubqe3LR3iXW/GlGCOKqSJT4lDv6GSwUeQl</t:cipherValue>
                    </t:cipherData>
                </t:encryptedData>
            </cfg:password>
            <cfg:database>UPEU</cfg:database>
            <cfg:jdbcDriver>oracle.jdbc.OracleDriver</cfg:jdbcDriver>
            <cfg:jdbcUrlTemplate>jdbc:oracle:thin:@%h:%p/%d</cfg:jdbcUrlTemplate>
            <cfg:rethrowAllSQLExceptions>true</cfg:rethrowAllSQLExceptions>
            <cfg:nativeTimestamps>true</cfg:nativeTimestamps>
            <cfg:allNative>false</cfg:allNative>
            <cfg:scriptingLanguage>GROOVY</cfg:scriptingLanguage>
            <cfg:reloadScriptOnExecution>false</cfg:reloadScriptOnExecution>
            <cfg:searchScript>import groovy.sql.Sql; def sql = new Sql(connection); def result = []; def baseQuery = '''SELECT * FROM ( SELECT e.CODIGO, MAX(e.NOMBRE) AS NOMBRE, MAX(e.PATERNO) AS PATERNO, MAX(e.MATERNO) AS MATERNO, MAX(e.CORREO_UPEU) AS CORREO_UPEU, MAX(e.CELULAR) AS CELULAR, MAX(e.NUM_DOCUMENTO) AS NUM_DOCUMENTO, MAX(e.FEC_NACIMIENTO) AS FEC_NACIMIENTO, 'ALUMNI' AS AFILIACION FROM DAVID.VW_PERSONA_EGRESADO e GROUP BY e.CODIGO )'''; def whereClause = ''; def params = []; if (query != null) { if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp; (query.left == '__NAME__' || query.left == '__UID__')) { whereClause = ' WHERE CODIGO = ?'; params &lt;&lt; (query.right as String); } else { throw new UnsupportedOperationException('Egresados-v2 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query); } }; def finalQuery = "SELECT * FROM (${baseQuery})${whereClause}".toString(); sql.eachRow(finalQuery, params) { row -&gt; result &lt;&lt; ['__UID__': row.CODIGO as String, '__NAME__': row.CODIGO as String, 'CODIGO': row.CODIGO as String, 'NOMBRE': row.NOMBRE as String, 'PATERNO': row.PATERNO as String, 'MATERNO': row.MATERNO as String, 'CORREO_UPEU': row.CORREO_UPEU as String, 'CELULAR': row.CELULAR as String, 'NUM_DOCUMENTO': row.NUM_DOCUMENTO as String, 'FEC_NACIMIENTO': row.FEC_NACIMIENTO?.toString(), 'AFILIACION': row.AFILIACION as String] }; return result</cfg:searchScript>
            <cfg:syncScript>return null</cfg:syncScript>
            <cfg:schemaScript>import org.identityconnectors.framework.common.objects.AttributeInfoBuilder; import org.identityconnectors.framework.common.objects.ObjectClass; import org.identityconnectors.framework.common.objects.ObjectClassInfoBuilder; def ro = { String attrName, boolean required -&gt; def aib = new AttributeInfoBuilder(attrName, String.class); aib.setRequired(required); aib.setCreateable(false); aib.setUpdateable(false); aib.setReadable(true); aib.build() }; def ocib = new ObjectClassInfoBuilder(); ocib.setType(ObjectClass.ACCOUNT_NAME); ocib.addAttributeInfo(ro("CODIGO", true)); ocib.addAttributeInfo(ro("NOMBRE", true)); ocib.addAttributeInfo(ro("PATERNO", false)); ocib.addAttributeInfo(ro("MATERNO", false)); ocib.addAttributeInfo(ro("CORREO_UPEU", false)); ocib.addAttributeInfo(ro("CELULAR", false)); ocib.addAttributeInfo(ro("NUM_DOCUMENTO", false)); ocib.addAttributeInfo(ro("FEC_NACIMIENTO", false)); ocib.addAttributeInfo(ro("AFILIACION", false)); builder.defineObjectClass(ocib.build())</cfg:schemaScript>
            <cfg:testScript>import groovy.sql.Sql; def sql = new Sql(connection); sql.firstRow("SELECT 1 AS OK FROM DUAL"); return "OK"</cfg:testScript>
        </icfc:configurationProperties>
    </connectorConfiguration>
    <schemaHandling>
        <objectType>
            <kind>account</kind>
            <intent>default</intent>
            <displayName>Egresado UPeU (LAMB SIS v3)</displayName>
            <default>true</default>
            <delineation>
                <objectClass>ri:AccountObjectClass</objectClass>
            </delineation>
            <focus>
                <type>UserType</type>
            </focus>
            <attribute>
                <ref>ri:CODIGO</ref>
                <inbound>
                    <name>codigo-to-name</name>
                    <strength>weak</strength>
                    <target><path>name</path></target>
                </inbound>
                <inbound>
                    <name>codigo-to-personalNumber</name>
                    <strength>weak</strength>
                    <target><path>personalNumber</path></target>
                </inbound>
                <inbound>
                    <name>codigo-to-institutionalCode</name>
                    <strength>weak</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:institutionalCode</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NOMBRE</ref>
                <inbound>
                    <name>nombre-to-givenName</name>
                    <strength>strong</strength>
                    <target><path>givenName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:PATERNO</ref>
                <inbound>
                    <name>paterno-materno-to-familyName</name>
                    <strength>strong</strength>
                    <source><path>$shadow/attributes/ri:PATERNO</path></source>
                    <source><path>$shadow/attributes/ri:MATERNO</path></source>
                    <expression>
                        <script>
                            <code>def p = (PATERNO ?: '').toString().trim(); def m = (MATERNO ?: '').toString().trim(); (p + (m ? ' ' + m : '')).trim() ?: null</code>
                        </script>
                    </expression>
                    <target><path>familyName</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CORREO_UPEU</ref>
                <inbound>
                    <name>correo-upeu-to-emailAddress</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>(input ?: '').toString().trim().toLowerCase() ?: null</code>
                        </script>
                    </expression>
                    <target><path>emailAddress</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:CELULAR</ref>
                <inbound>
                    <name>celular-to-telephoneNumber</name>
                    <strength>strong</strength>
                    <target><path>telephoneNumber</path></target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <correlator/>
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>def d = (input ?: '').toString().trim(); d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:FEC_NACIMIENTO</ref>
                <inbound>
                    <name>fec-nacimiento-to-birthDate</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>if (input == null) return null; def s = input.toString(); s.length() >= 10 ? s.substring(0, 10) : null</code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:birthDate</path>
                    </target>
                </inbound>
            </attribute>
            <attribute>
                <ref>ri:AFILIACION</ref>
                <inbound>
                    <name>afiliacion-to-primaryAffiliation</name>
                    <strength>weak</strength>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:primaryAffiliation</path>
                    </target>
                </inbound>
            </attribute>
            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions><synchronize/></actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions><link/></actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions><addFocus/></actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions><inactivateFocus/></actions>
                </reaction>
            </synchronization>
        </objectType>
    </schemaHandling>
    <capabilities>
        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:create>
                <cap:enabled>false</cap:enabled>
            </cap:create>
            <cap:update>
                <cap:enabled>false</cap:enabled>
            </cap:update>
            <cap:delete>
                <cap:enabled>false</cap:enabled>
            </cap:delete>
        </configured>
    </capabilities>
    <projection>
        <assignmentPolicyEnforcement>relative</assignmentPolicyEnforcement>
    </projection>
</resource>
