            <cfg:searchScript>
import groovy.sql.Sql
def sql = new Sql(connection)
def result = []

// Egresados: dedup por CODIGO con MAX para resolver filas duplicadas.
// La vista VW_PERSONA_EGRESADO puede tener múltiples filas por egresado
// si cursó más de un programa. Se toma la primera con MAX aggr.
def baseQuery = '''
SELECT * FROM (
  SELECT
    e.CODIGO,
    MAX(e.NOMBRE)        AS NOMBRE,
    MAX(e.PATERNO)       AS PATERNO,
    MAX(e.MATERNO)       AS MATERNO,
    MAX(e.CORREO_UPEU)   AS CORREO_UPEU,
    MAX(e.CELULAR)       AS CELULAR,
    MAX(e.NUM_DOCUMENTO) AS NUM_DOCUMENTO,
    MAX(e.FEC_NACIMIENTO) AS FEC_NACIMIENTO
  FROM DAVID.VW_PERSONA_EGRESADO e
  GROUP BY e.CODIGO
)
'''

def whereClause = ''
def params = []

if (query != null) {
    if (query.operation == 'EQUALS' &amp;&amp; !query.not &amp;&amp;
        (query.left == '__NAME__' || query.left == '__UID__')) {
        whereClause = ' WHERE CODIGO = ?'
        params &lt;&lt; (query.right as String)
    } else {
        throw new UnsupportedOperationException(
            'Egresados-v3 searchScript only supports EqualsFilter on __NAME__/__UID__; got: ' + query)
    }
}

def finalQuery = "SELECT * FROM (${baseQuery.trim()})${whereClause}".toString()
sql.eachRow(finalQuery, params) { row ->
    result &lt;&lt; [
        '__UID__'       : row.CODIGO as String,
        '__NAME__'      : row.CODIGO as String,
        'CODIGO'        : row.CODIGO as String,
        'NOMBRE'        : row.NOMBRE as String,
        'PATERNO'       : row.PATERNO as String,
        'MATERNO'       : row.MATERNO as String,
        'CORREO_UPEU'   : row.CORREO_UPEU as String,
        'CELULAR'       : row.CELULAR as String,
        'NUM_DOCUMENTO' : row.NUM_DOCUMENTO as String,
        'FEC_NACIMIENTO': row.FEC_NACIMIENTO?.toString()
    ]
}
return result
</cfg:searchScript>
