            </attribute>

            <attribute>
                <ref>ri:NUM_DOCUMENTO</ref>
                <!-- Correlador por DNI como URN SCHAC plano → extension/sb:taxId (indexado).
                     taxId marcado deprecated en schema pero funcional e indexado.
                     El correlador implícito <correlator/> compara el valor del shadow
                     contra sb:taxId del focus para encontrar match. -->
                <correlator/>
                <inbound>
                    <name>dni-to-taxId-urn</name>
                    <strength>strong</strength>
                    <expression>
                        <script>
                            <code>
def d = (input ?: '').toString().trim()
d ? 'urn:schac:personalUniqueID:pe:DNI:PE:' + d : null
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:taxId</path>
                    </target>
                    <evaluationPhases>
                        <include>beforeCorrelation</include>
                        <include>clockwork</include>
                    </evaluationPhases>
                </inbound>
            </attribute>

            <!-- ──────────────────────────────────────────────
