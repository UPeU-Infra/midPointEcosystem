<?xml version="1.0" encoding="UTF-8"?>
<!--
    ObjectCollection: personas-upeu
    OID: 00000000-0000-0000-0002-000000000100
    Propósito: Filtro canónico de todos los usuarios UPeU importados desde Oracle LAMB.
               Identifica usuarios por extension/sb:schacHomeOrganization = "upeu.edu.pe".
               Cubre todos los arquetipos (student, staff, faculty, alum, etc.) sin
               depender del archetype Person built-in de MidPoint.
    IIA: Oracle LAMB (schacHomeOrganization mapeado en resource LAMB inbound)
    Estándar: SCHAC 1.6.0 — schacHomeOrganization
    Scope: UPeU. Reutilizable en SciBack con cambio de valor del filtro.
    Creado: 2026-05-15
-->
<objectCollection oid="00000000-0000-0000-0002-000000000100"
                  xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
                  xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
                  xmlns:sb="urn:sciback:midpoint:person">
    <name>personas-upeu</name>
    <type>UserType</type>
    <filter>
        <q:equal>
            <q:path>extension/sb:schacHomeOrganization</q:path>
            <q:value>upeu.edu.pe</q:value>
        </q:equal>
    </filter>
</objectCollection>
