<?xml version="1.0" encoding="UTF-8"?>
<!--
  Archetype: Person (structural)
  OID: 00000000-0000-0000-0000-000000000702 (built-in Evolveum, PATCH over existing)

  Spec canonica: §3.1 Pilar 1 - Persona unica, §4.2 Archetype unico Person
  Regla: un unico archetype structural por UserType.
  Regla: NO codifica afiliacion. Afiliaciones = R-Affiliation-* roles (spec §3.2).

  Policy Rules (F5 - 2026-05-14):
    PR-RECORD-REJECTION  : audit log cuando el foco esta en draft (trazabilidad).
                           El script de rejectionReasons va en Bloque G del Object Template.
    PR-AUDIT-ACTIVE-GATE : audit log cuando el foco transita a active (trazabilidad).

  Diseno deliberado:
    - El enforcement real (lifecycleState=draft) lo hace el Bloque F del Object Template.
    - El script de rejectionReasons lo ejecuta el Bloque G del Object Template (mapping script).
      Razon: objectState en inducement evalua el estado del rol/archetype, no el foco.
      El template tiene acceso directo al foco y puede escribir en extension fields.
    - Las policy rules en inducement agregan TRAZABILIDAD en audit log (action: record).
    - Un inducement con solo policyRule/record NO induce privilegios (libro §8.4 compatible).

  F2 - Refactor de Archetypes UPeU 2026-05
  F5 - Policy Rules de trazabilidad UPeU 2026-05-14
-->
<archetype xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
           xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
           xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
           oid="00000000-0000-0000-0000-000000000702">
    <name>Person</name>
    <description>Toda persona fisica vinculada a UPeU. Unico archetype structural permitido para UserType. Las afiliaciones (student/faculty/staff/alum/affiliate) se expresan como R-Affiliation-* roles, NO como archetypes distintos. Spec §3.1 + §4.2. Policy rules de trazabilidad F5 en inducement (audit log). Script rejectionReasons en Bloque G del Object Template.</description>
    <archetypePolicy>
        <display>
            <label>Persona UPeU</label>
            <pluralLabel>Personas UPeU</pluralLabel>
            <icon>
                <cssClass>fa fa-user</cssClass>
                <color>#0072b5</color>
            </icon>
        </display>
        <conflictResolution>
            <action>recompute</action>
        </conflictResolution>
        <objectTemplateRef oid="855caaca-68c4-4f7f-8ff8-b4e35dd7d390" type="c:ObjectTemplateType"/>
    </archetypePolicy>

    <!-- ============================================================
         INDUCEMENT: POLICY RULE PR-RECORD-REJECTION
         Registra en audit log cuando un Person esta en estado draft/proposed.
         Action: solo record (trazabilidad en audit log MidPoint).

         El script que escribe rejectionReasons + rejectedAt en extension/sciback:
         esta en el Bloque G del Object Template (855caaca-68c4-4f7f-8ff8-b4e35dd7d390).
         Razon tecnica: objectState en inducement evalua el estado del archetype,
         no el foco. El mapping script en el template tiene acceso directo al foco
         y puede setear extension fields. MidPoint 4.9 verified.

         NO tiene target/construction: no induce privilegios (libro §8.4 compatible).
         ============================================================ -->
    <inducement>
        <policyRule>
            <name>PR-RECORD-REJECTION</name>
            <documentation>Registra en audit log cuando un Person esta en draft/proposed. El script de rejectionReasons va en Bloque G del Object Template. Spec §4.3 Pilar 4 - Import estricto.</documentation>
            <policyConstraints>
                <objectState>
                    <name>perfil-en-draft-o-proposed</name>
                    <filter>
                        <q:or>
                            <q:equal>
                                <q:path>lifecycleState</q:path>
                                <q:value>draft</q:value>
                            </q:equal>
                            <q:equal>
                                <q:path>lifecycleState</q:path>
                                <q:value>proposed</q:value>
                            </q:equal>
                        </q:or>
                    </filter>
                </objectState>
            </policyConstraints>
            <policyActions>
                <record/>
            </policyActions>
        </policyRule>
    </inducement>

    <!-- ============================================================
         INDUCEMENT: POLICY RULE PR-AUDIT-ACTIVE-GATE
         Registra en audit log la transicion hacia lifecycleState=active.
         El gate real es el Bloque F del Object Template.
         NO tiene target/construction: no induce privilegios.
         ============================================================ -->
    <inducement>
        <policyRule>
            <name>PR-AUDIT-ACTIVE-GATE</name>
            <documentation>Registra en audit log la transicion hacia active de cualquier Person. Informativo: confirma que el Bloque F del Object Template permitio la transicion. No duplica enforcement.</documentation>
            <policyConstraints>
                <transition>
                    <stateAfter>active</stateAfter>
                </transition>
            </policyConstraints>
            <policyActions>
                <record/>
            </policyActions>
        </policyRule>
    </inducement>

</archetype>
