<?xml version="1.0" encoding="UTF-8"?>
<!--
  UserTemplate-Alumni — Template per-archetype para egresados (archetype-user-alumni)
  OID: b668e431-b7cf-405d-bde3-74af5ba3290e
  Versión: 1.0 (2026-05-20)
  Schema: urn:sciback:midpoint:person (canónico) + urn:upeu:midpoint:local (LAMB)
  Aplica a: archetype-user-alumni (OID: 87552943-9600-493b-88ca-74b7d3ba93e4)
  Extiende: UserTemplate-Person-Base (OID: 855caaca-68c4-4f7f-8ff8-b4e35dd7d390)
  IIA: Oracle LAMB Egresados v3 (VW_PERSONA_EGRESADO via DAVID schema)

  Fuente autoritativa (inbounds verificados en egresados.xml):
    - personalNumber, givenName, familyName, emailAddress, telephoneNumber
    - taxId/identityDocuments (via J/J2 en base template)
    - birthDate, academicProgram/Code, studyLevel, studyModality
    - admissionPeriod (SEMESTRE de egreso), organizationalUnit (facultad)
    - primaryAffiliation=alum, affiliations

  Lo que el base template YA cubre (NO duplicar):
    - A: username desde personalNumber
    - B: fullName, emailAddress weak
    - C: schacHomeOrganization, eppn
    - D: R-Affiliation-Alumni, BR-Egresado (autoassign desde primaryAffiliation=alum)
    - D5: AuxAff-Alum
    - D6: org EP desde academicProgramCode
    - D7: structural archetype desde affiliations
    - F: lifecycle gate draft→active
    - G/H: rejection + ISO 24760 lifecycle
    - J/J2: identityDocuments + taxId cleanup

  Mappings propios de este template:
    - Q1: title fallback "Egresado" (weak) cuando LAMB no provee title
    - Q2: log.warn si admissionPeriod ausente para alumni activo (validación de calidad de datos)

  SciBack blueprint: overlay UPeU. Generalizable a cualquier universidad con egresados en IIA JDBC.
-->
<objectTemplate xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
                xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
                xmlns:sb="urn:sciback:midpoint:person"
                xmlns:upeu="urn:upeu:midpoint:local"
                oid="b668e431-b7cf-405d-bde3-74af5ba3290e">
    <name>UserTemplate-Alumni</name>
    <description>Template per-archetype para egresados UPeU. Extiende UserTemplate-Person-Base. Agrega title fallback y validación de admissionPeriod (período de egreso).</description>
    <lifecycleState>active</lifecycleState>

    <!-- Incluir el base template — toda la lógica A-P ya corre desde ahí -->
    <includeRef oid="855caaca-68c4-4f7f-8ff8-b4e35dd7d390" type="ObjectTemplateType"/>

    <!--
      BLOQUE Q1 — TITLE FALLBACK PARA EGRESADOS
      Asigna title="Egresado" cuando LAMB no provee un título de puesto.
      weak: no sobreescribe si ya tiene valor (e.g., egresado que también es trabajador).
      IIA: no aplica (valor literal canónico).
    -->
    <item>
        <ref>title</ref>
        <mapping>
            <name>Q1-alumni-title-fallback</name>
            <description>Asigna title="Egresado" como fallback canónico cuando no hay title de LAMB. weak: cede ante cualquier valor existente.</description>
            <lifecycleState>active</lifecycleState>
            <strength>weak</strength>
            <expression>
                <value>Egresado</value>
            </expression>
        </mapping>
    </item>

    <!--
      BLOQUE Q2 — VALIDACIÓN admissionPeriod PARA EGRESADOS
      Log.warn si un usuario alumni activo no tiene admissionPeriod (período de egreso).
      admissionPeriod = SEMESTRE desde Oracle LAMB Egresados (campo SEMESTRE → "ANIO-N").
      strength=weak: no modifica el valor, solo actúa como pasthrough con efecto de log.
      Patrón idéntico a D-student-warn-missing-program en base template.
    -->
    <item>
        <ref xmlns:sb="urn:sciback:midpoint:person">extension/sb:admissionPeriod</ref>
        <mapping>
            <name>Q2-alumni-warn-missing-admissionPeriod</name>
            <description>Advierte si alumni activo no tiene admissionPeriod (período de egreso desde LAMB). Calidad de datos crítica para certificados académicos.</description>
            <lifecycleState>active</lifecycleState>
            <strength>weak</strength>
            <source>
                <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:primaryAffiliation</path>
            </source>
            <source>
                <path xmlns:sb="urn:sciback:midpoint:person">extension/sb:admissionPeriod</path>
            </source>
            <expression>
                <script>
                    <code>def affil = primaryAffiliation != null ? basic.stringify(primaryAffiliation).trim().toLowerCase() : '';
if (affil == 'alum' &amp;&amp; (admissionPeriod == null || basic.stringify(admissionPeriod).trim() == '')) {
    log.warn("UPeU Alumni: admissionPeriod ausente en egresado {} — dato requerido para certificaciones", focus?.name)
};
return admissionPeriod</code>
                </script>
            </expression>
            <condition>
                <script>
                    <code>primaryAffiliation != null &amp;&amp; basic.stringify(primaryAffiliation).trim().toLowerCase() == 'alum'</code>
                </script>
            </condition>
        </mapping>
    </item>

</objectTemplate>
