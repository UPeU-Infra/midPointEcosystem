<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
        oid="e800335c-9ca1-4a2d-b4ca-e06f6db42693">
    <name>SciBack IGA — Schema canónico universitario Perú v1.2</name>
    <description>Schema de extensión canónico para universidades peruanas. Namespace: urn:sciback:midpoint:person. Alineado: eduPerson 202208, SCHAC 1.6.0, SCIM 2.0, ISO 24760, Ley 29733, Ley 30220, SUNEDU CBC. Reutilizable por cualquier universidad licenciada SUNEDU en plataforma SciBack IGA.</description>
    <lifecycleState>active</lifecycleState>
    <definition>
        <xsd:schema
            xmlns:xsd="http://www.w3.org/2001/XMLSchema"
            xmlns:a="http://prism.evolveum.com/xml/ns/public/annotation-3"
            xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
            xmlns:tns="urn:sciback:midpoint:person"
            targetNamespace="urn:sciback:midpoint:person"
            elementFormDefault="qualified">

            <xsd:import namespace="http://prism.evolveum.com/xml/ns/public/annotation-3"/>
            <xsd:import namespace="http://midpoint.evolveum.com/xml/ns/public/common/common-3"/>

            <!-- IdentityDocumentType — PrismContainer. Todos los campos xsd:string. -->
            <xsd:complexType name="IdentityDocumentType">
                <xsd:annotation>
                    <xsd:appinfo>
                        <a:container/>
                        <a:displayName>Documento de identidad</a:displayName>
                        <a:help>Documento oficial de identificación. Exactamente 1 con primary=true.</a:help>
                    </xsd:appinfo>
                </xsd:annotation>
                <xsd:sequence>
                    <xsd:element name="type" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Tipo de documento</a:displayName><a:help>DNI|CE|PASSPORT|PTP|CPP|CSR|ITIN</a:help><a:displayOrder>10</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="number" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Número de documento</a:displayName><a:displayOrder>20</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="countryOfIssue" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>País emisor</a:displayName><a:help>ISO 3166-1 alpha-3</a:help><a:displayOrder>30</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="primary" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Documento principal</a:displayName><a:help>true|false</a:help><a:displayOrder>40</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="issuedAt" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de emisión</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>50</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="expiresAt" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de vencimiento</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>60</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="verifiedBy" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Verificado por</a:displayName><a:help>RENIEC|MIGRACIONES|INSTITUTIONAL|SELF-DECLARED</a:help><a:displayOrder>70</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="verifiedAt" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de verificación</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>80</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                </xsd:sequence>
            </xsd:complexType>

            <!-- UserExtensionType — todos los tipos xsd:string -->
            <xsd:complexType name="UserExtensionType">
                <xsd:annotation>
                    <xsd:appinfo>
                        <a:extension ref="c:UserType"/>
                        <a:displayName>Datos de persona SciBack IGA</a:displayName>
                        <a:help>Extensión canónica v1.0. eduPerson 202208 + SCHAC 1.6.0 + SCIM 2.0 + ISO 24760 + Ley 29733 + Ley 30220 + SUNEDU CBC.</a:help>
                    </xsd:appinfo>
                </xsd:annotation>
                <xsd:sequence>

                    <!-- S1 — IDENTIFICADORES -->
                    <xsd:element name="identityDocuments" type="tns:IdentityDocumentType" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Documentos de identidad</a:displayName><a:displayOrder>100</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="institutionalCode" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Código institucional</a:displayName><a:indexed>true</a:indexed><a:displayOrder>110</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="externalSystemId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>ID sistema externo</a:displayName><a:indexed>true</a:indexed><a:displayOrder>130</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S2 — DEMOGRÁFICOS -->
                    <xsd:element name="birthDate" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de nacimiento</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>200</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="gender" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Género</a:displayName><a:help>ISO 5218: 0|1|2|9</a:help><a:displayOrder>210</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="nationality" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Nacionalidad</a:displayName><a:help>ISO 3166-1 alpha-3</a:help><a:displayOrder>220</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="preferredName" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Nombre preferido</a:displayName><a:displayOrder>230</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="displayPronouns" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Pronombres preferidos</a:displayName><a:displayOrder>240</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="disability" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Persona con discapacidad</a:displayName><a:help>true|false</a:help><a:displayOrder>250</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="maritalStatus" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Estado civil</a:displayName><a:displayOrder>260</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="religion" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Religión</a:displayName><a:displayOrder>270</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S3 — CONTACTO -->
                    <xsd:element name="personalEmail" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Correo personal</a:displayName><a:displayOrder>300</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="phoneNumber" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Teléfono</a:displayName><a:displayOrder>310</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="streetAddress" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Dirección</a:displayName><a:displayOrder>320</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="ubigeo" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Ubigeo</a:displayName><a:displayOrder>330</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S4 — AFILIACIÓN (COMPUTADOS) -->
                    <xsd:element name="affiliations" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Afiliaciones</a:displayName><a:displayOrder>400</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="primaryAffiliation" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Afiliación principal</a:displayName><a:indexed>true</a:indexed><a:displayOrder>410</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="scopedAffiliations" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Afiliaciones con ámbito</a:displayName><a:displayOrder>420</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- S4b — AFILIACIONES VIVAS POR IIA (PERSISTIDAS, single-source).
                         Opción 2 (runbook org-canonical-migration-2026-05-29, PM10): cada item es
                         alimentado por UN SOLO inbound strong desde su IIA (una IIA por atributo,
                         iga-canonical §1.3). Al ser single-source, el inbound strong MATERIALIZA el
                         valor en el focus sin caer en el zero-set multi-source que bloqueaba el
                         multivalor `affiliations` (no requiere metadata-provenance). El template
                         deriva liveAff = unión de estos items persistidos; J3 deriva primaryAffiliation
                         y Bloque L deriva lifecycleState a partir de ellos (NO del transitorio
                         `affiliations`, que se conserva solo como atributo eduPerson downstream). -->
                    <xsd:element name="liveAffiliationWorker" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Afiliación viva — empleo (IIA Trabajadores)</a:displayName><a:help>Token eduPerson (faculty|staff) presente SOLO mientras el contrato UPeU está vigente (ESTADO≠'I' en Oracle LAMB Trabajadores v3). IIA única: resource Trabajadores. Single-source: el inbound strong lo materializa/retira con la cuenta laboral. Ausente = sin empleo vigente. NO confundir con `affiliations` (multivalor eduPerson downstream).</a:help><a:indexed>true</a:indexed><a:displayOrder>421</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="liveAffiliationAlum" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Afiliación viva — egresado (IIA Egresados)</a:displayName><a:help>Token eduPerson (alum) presente mientras el shadow Egresados v3 está linked con AFILIACION=alum. IIA única: resource Egresados. Single-source: el inbound strong lo materializa/retira con la proyección Egresado. La condición de egresado es permanente (alum no caduca). Ausente = no es egresado.</a:help><a:indexed>true</a:indexed><a:displayOrder>422</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="liveAffiliationStudent" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Afiliación viva — estudiante (IIA Estudiantes)</a:displayName><a:help>Token eduPerson (student) presente SOLO mientras hay matrícula vigente (semestres 279/267 en Oracle LAMB Estudiantes v4). IIA única: resource Estudiantes. Single-source: el inbound strong lo materializa/retira con la proyección Estudiante. Ausente = sin matrícula vigente.</a:help><a:indexed>true</a:indexed><a:displayOrder>423</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- Campus por-IIA single-valued single-writer (mismo patrón que liveAffiliation*). Cada IIA escribe su propio slot → cero colisión strong/strong. Usados por el gate Koha multi-campus (vínculos VIVOS): elegible Koha-Lima si campusStudent=LIMA (matrícula vigente Lima) O campusWorker=LIMA (contrato 7124 vivo Lima). El EGRESO histórico NO cuenta (sin slot campusAlum en el gate). NO confundir con `locality` (lugar físico, IIA distinta, usado por LDAP/Entra/M365 — intacto). -->
                    <xsd:element name="campusStudent" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Campus — matrícula vigente (IIA Estudiantes)</a:displayName><a:help>Sede (LIMA|JULIACA|TARAPOTO|ISTAT) de la matrícula vigente. IIA única: resource Estudiantes. Single-source: el inbound strong lo materializa/retira con la proyección Estudiante (mismo origen que liveAffiliationStudent). Ausente = sin matrícula vigente. Entra al gate Koha multi-campus como vínculo VIVO de estudiante.</a:help><a:indexed>true</a:indexed><a:displayOrder>424</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="campusWorker" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Campus — contrato vivo (IIA Trabajadores)</a:displayName><a:help>Sede (LIMA|JULIACA|TARAPOTO|ISTAT) del contrato UPeU vigente (ID_ENTIDAD=7124, ESTADO≠'I'). IIA única: resource Trabajadores. Single-source: el inbound strong lo materializa/retira con la cuenta laboral (mismo origen que liveAffiliationWorker). Ausente = sin empleo vigente. Entra al gate Koha multi-campus como vínculo VIVO de trabajador.</a:help><a:indexed>true</a:indexed><a:displayOrder>425</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="entitlements" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Derechos (entitlements)</a:displayName><a:displayOrder>430</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="eppn" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>ePPN (eduPersonPrincipalName)</a:displayName><a:displayOrder>440</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="eduPersonUniqueId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>eduPersonUniqueId</a:displayName><a:indexed>true</a:indexed><a:displayOrder>450</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="schacHomeOrganization" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Organización (schacHomeOrganization)</a:displayName><a:displayOrder>460</a:displayOrder><a:indexed>true</a:indexed></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="schacExpiryDate" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de expiración (SCHAC)</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>470</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="terminationDateStudent" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de término — matrícula (IIA Estudiantes)</a:displayName><a:help>YYYY-MM-DD. Expiración derivada de la matrícula vigente (MAX FECHA_FIN del semestre activo en Oracle LAMB Estudiantes, columna DATE_EXPIRY). IIA única: resource Estudiantes. Single-source: inbound strong lo materializa/retira con la proyección Estudiante. NO confundir con `terminationDate` (IIA Trabajadores, FEC_TERMINO del contrato). Ambos atributos por-IIA single-valued single-writer evitan la colisión dual-strong en focos employee+student. El expiry efectivo a Koha/downstream = MAX de las fechas de afiliación viva.</a:help><a:displayOrder>475</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S5 — ACADÉMICO -->
                    <xsd:element name="academicProgram" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Programa académico</a:displayName><a:displayOrder>500</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="academicProgramCode" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Código de programa académico</a:displayName><a:indexed>true</a:indexed><a:displayOrder>510</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- academicProgramSuneduCode: código P-code SUNEDU del programa de estudio
                         (ej. P30, P31, P143). IIA: Oracle LAMB DAVID.ACAD_PROGRAMA_ESTUDIO.CODIGO_SUNEDU2
                         (vía searchScript Estudiantes, columna SUNEDU_CODE, vigencia-aware KEEP DENSE_RANK
                         LAST). Identificador oficial del programa en el Registro Nacional de Grados y
                         Títulos SUNEDU (Ley 30220). Single-value: corresponde al programa de la matrícula
                         vigente que termina más tarde. Destino: outbound koha-ils statistics2-outbound
                         (Bsort2) — el código se emite tal cual (separación: el resource Koha consume el
                         dato canónico SUNEDU sin transformación). NO confundir con academicProgramCode
                         (EP-XXX, código corto interno SciBack/VocBench). -->
                    <xsd:element name="academicProgramSuneduCode" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Código SUNEDU del programa (P-code)</a:displayName><a:help>Código oficial del programa en el Registro Nacional de Grados y Títulos SUNEDU (ej. P30, P31, P143). IIA: Oracle LAMB DAVID.ACAD_PROGRAMA_ESTUDIO.CODIGO_SUNEDU2. Single-value (programa de la matrícula vigente). Destino: Koha statistics_2/Bsort2.</a:help><a:indexed>true</a:indexed><a:displayOrder>515</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- facultyName: nombre crudo de la facultad a la que pertenece el programa de la
                         matrícula vigente. IIA: Oracle LAMB ELISEO.ORG_AREA.NOMBRE del nodo PADRE de la
                         escuela (oafac via ID_PARENT). NO es un código canónico universal — es el nombre
                         legible de la facultad. El mapeo facultad→código corto (FCS/FIA/FACIHED/...) es
                         específico de Koha (authorised_values Bsort1) y vive en el resource koha-ils
                         (statistics1-outbound switch), NO aquí. Single-value (facultad de la matrícula
                         vigente que termina más tarde, KEEP DENSE_RANK LAST). Ejemplos: 'Facultad de
                         Ciencias de la Salud', 'Facultad de Ingeniería y Arquitectura'. -->
                    <xsd:element name="facultyName" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Nombre de facultad</a:displayName><a:help>Nombre crudo de la facultad del programa de la matrícula vigente. IIA: Oracle LAMB ELISEO.ORG_AREA.NOMBRE (nodo padre de la escuela vía ID_PARENT). El código corto Koha (Bsort1) se deriva de este nombre en el resource koha-ils. Single-value.</a:help><a:indexed>true</a:indexed><a:displayOrder>517</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="studyLevel" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Nivel de estudios</a:displayName><a:displayOrder>520</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="studyModality" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Modalidad de estudio</a:displayName><a:displayOrder>530</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="studentCycle" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Ciclo académico</a:displayName><a:displayOrder>540</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="admissionPeriod" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Período de admisión</a:displayName><a:displayOrder>550</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- graduationYear: año del último egreso/graduación. Fuente IIA: Oracle LAMB
                         DAVID.VW_PERSONA_EGRESADO.ANIO. Tipado como xsd:int para permitir
                         aritmética en expresiones (validTo = graduationYear + N años) sin
                         conversiones en cada mapping (Semancik Cap. 6 §1.4: "use proper
                         types where arithmetic is required"). Driver de la policy de
                         deprovisioning temporal canónica (validTo en assignment de
                         AR-Koha-Patron-Alumni). NULL safe: usuarios sin dato → vigencia
                         indefinida (fail-open). -->
                    <xsd:element name="graduationYear" type="xsd:int" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Año de graduación</a:displayName>
                            <a:help>Año del último egreso/graduación efectiva. Fuente: Oracle LAMB DAVID.VW_PERSONA_EGRESADO.ANIO. Driver del cálculo de vigencia post-graduación (validTo). NULL → vigencia indefinida (fail-open).</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>551</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- graduationSemester: período "YYYY-N" (e.g. "2024-1", "2024-2").
                         Informativo. Para policy actual usamos solo graduationYear con
                         cierre el 31-Dic (decisión simplificadora: precisión por semestre
                         es over-engineering). Se conserva para reporting y futuras
                         políticas que requieran granularidad semestral. -->
                    <xsd:element name="graduationSemester" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Semestre de graduación</a:displayName>
                            <a:help>Período del último egreso en formato "YYYY-N" (e.g. 2024-1, 2024-2). Fuente: Oracle LAMB DAVID.VW_PERSONA_EGRESADO.SEMESTRE. Informativo / reporting.</a:help>
                            <a:displayOrder>552</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="academicProgramUri" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>URI canónica del programa académico</a:displayName><a:help>Identificador persistente del programa (urn:sciback:program:{institutionId}:{programCode}). Vinculado al OrgType academic-program. Para uso en eduPersonOrgUnitDN y SCHAC.</a:help><a:indexed>true</a:indexed><a:displayOrder>560</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="academicProgramRole" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Rol del usuario en el programa</a:displayName><a:help>Vocabulario controlado: student|faculty|coordinator|director|alum. Multivalor: una persona puede ser docente de un programa y coordinador de otro.</a:help><a:displayOrder>570</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S5b — GRADOS Y TÍTULOS CONFERIDOS (Secretaría General) -->
                    <!-- IIA: Secretaría General (Oracle LAMB DAVID.VW_PERSONA_GRADO). Grado/título
                         académico efectivamente conferido por la institución. Concepto canónico:
                         toda universidad confiere grados (Perú: Ley 30220 art. 44-45, registro SUNEDU).
                         NO confundir con studyLevel (nivel del programa que se cursa). -->
                    <xsd:element name="conferredDegree" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Grado/título conferido</a:displayName><a:help>Grado académico o título profesional más alto efectivamente conferido por la institución. Vocabulario controlado normalizado: BACHILLER | TITULO_PROFESIONAL | MAESTRIA | DOCTORADO | POSDOCTORADO. Single-value: una persona porta el grado más alto obtenido. IIA: Secretaría General. Para uso en SCHAC schacPersonalTitle y eduPerson.</a:help><a:indexed>true</a:indexed><a:displayOrder>580</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="conferredDegreeAbbrev" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Abreviatura del grado conferido</a:displayName><a:help>Abreviatura honorífica del grado/título conferido (Bach., Mg., Dr.). Mapea a SCHAC schacPersonalTitle. Puede ser nula para títulos profesionales sin abreviatura honorífica estándar.</a:help><a:displayOrder>585</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="schacPersonalTitle" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Título personal (schacPersonalTitle)</a:displayName><a:help>Atributo canónico SCHAC 1.6.0 schacPersonalTitle: tratamiento/título honorífico de la persona (Bach., Mg., Dr.). Valor DERIVADO por el object template desde conferredDegreeAbbrev — no se importa directamente desde ninguna IIA. Single-value. Destino de outbound hacia LDAP (schacPersonalTitle / personalTitle) y Keycloak. Puede ser nulo si la persona no tiene grado conferido con abreviatura honorífica estándar.</a:help><a:displayOrder>590</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S6 — LABORAL -->
                    <xsd:element name="employeeCategory" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Categoría ocupacional</a:displayName><a:displayOrder>600</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="employeeType" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Tipo de empleo</a:displayName><a:displayOrder>610</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="hireDate" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de ingreso</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>620</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="terminationDate" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha de término</a:displayName><a:help>YYYY-MM-DD</a:help><a:displayOrder>630</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="contractType" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Tipo de contrato</a:displayName><a:displayOrder>640</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S7 — INVESTIGACIÓN -->
                    <!-- orcid: ORCID iD canónico (https://orcid.org/0000-0000-0000-0000).
                         IIA futura: CTI Vitae / ORCID Public API. -->
                    <xsd:element name="orcid" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>ORCID iD</a:displayName>
                            <a:help>ORCID iD del investigador. Formato: 0000-0000-0000-0000 (sin prefijo URL). IIA futura: CTI Vitae portal / ORCID Public API. Persistente e inmutable.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>700</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- concytecId: código de registro RENACYT (ej: P0012345).
                         IIA: lista anual DGI (Excel Charmín) → sciback-research-projects M4. -->
                    <xsd:element name="concytecId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Código RENACYT</a:displayName>
                            <a:help>Código de registro del investigador en el padrón RENACYT/CONCYTEC (ej: P0012345). IIA: lista anual DGI / sciback-research-projects. Indexed para búsquedas de validación.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>710</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- ctiVitaeId: ID de perfil en el portal CTI Vitae de CONCYTEC.
                         Distinto de concytecId (código RENACYT): es el identificador interno
                         del perfil en el portal web CTI Vitae (ej: 161494).
                         IIA futura: sciback-research-projects CtiVitaeAdapter (M5). -->
                    <xsd:element name="ctiVitaeId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>ID CTI Vitae</a:displayName>
                            <a:help>Identificador del perfil en el portal CTI Vitae de CONCYTEC (ej: 161494). Distinto del código RENACYT (concytecId). Disponible en la columna F del Excel DGI anual. IIA futura: CtiVitaeAdapter en sciback-research-projects M5.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>715</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- renacytLevel: nivel de calificación en el padrón RENACYT 2022.
                         Vocabulario controlado alineado con Reglamento RENACYT Art. 11.
                         IIA: lista anual DGI / sciback-research-projects M4. -->
                    <xsd:element name="renacytLevel" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Nivel RENACYT</a:displayName>
                            <a:help>Nivel de calificación en el padrón RENACYT. Vocabulario controlado: DISTINGUIDO | NIVEL_I | NIVEL_II | NIVEL_III | NIVEL_IV | NIVEL_V | NIVEL_VI | NIVEL_VII. Alineado con Reglamento RENACYT 2022 (Res. Pres. Ejecutiva 045-2021-CONCYTEC-PE). IIA: lista anual DGI / sciback-research-projects M4.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>718</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- renacytStatus: estado de vigencia en el padrón RENACYT.
                         Determina si el investigador puede liderar proyectos, asesorar tesis, etc.
                         IIA: lista anual DGI / sciback-research-projects M4. -->
                    <xsd:element name="renacytStatus" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Estado RENACYT</a:displayName>
                            <a:help>Estado de vigencia en el padrón RENACYT. Vocabulario controlado: ACTIVO | ACTIVO_AFILIADO | NO_ACTIVO | EXCLUIDO. Solo ACTIVO y ACTIVO_AFILIADO habilitan liderar proyectos/asesorar tesis (Reglamento RENACYT Art. 11). IIA: lista anual DGI / sciback-research-projects M4.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>719</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <!-- researcherCategory: categoría institucional de investigador (uso interno).
                         Distinto de renacytLevel (padrón CONCYTEC). Para clasificaciones
                         propias de la universidad (ej: SENIOR, JUNIOR, FORMATIVO). -->
                    <xsd:element name="researcherCategory" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo>
                            <a:displayName>Categoría investigador (institucional)</a:displayName>
                            <a:help>Categoría de investigador según clasificación interna de la universidad. Distinto de renacytLevel (padrón CONCYTEC). Vocabulario libre por institución.</a:help>
                            <a:indexed>true</a:indexed>
                            <a:displayOrder>720</a:displayOrder>
                        </xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S8 — ORGANIZACIÓN / CAMPUS -->
                    <xsd:element name="homeCampus" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Campus sede</a:displayName><a:displayOrder>800</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S9 — GOVERNANCE / DRAFT METADATA -->
                    <xsd:element name="rejectionReasons" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>Razones de rechazo</a:displayName><a:displayOrder>900</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="rejectedAt" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha/hora de rechazo</a:displayName><a:help>ISO 8601 datetime</a:help><a:displayOrder>910</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="rejectionSource" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fuente del rechazo</a:displayName><a:displayOrder>920</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="expectedSourceForFix" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fuente esperada para corrección</a:displayName><a:displayOrder>930</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="lastReviewedAt" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Fecha/hora última revisión</a:displayName><a:help>ISO 8601 datetime</a:help><a:displayOrder>940</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="reviewerNotes" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Notas del revisor</a:displayName><a:displayOrder>950</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                    <!-- S10 — DEPRECADOS (compatibilidad v3.0 / urn:upeu:midpoint:person) -->
                    <xsd:element name="taxId" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] DNI/CE (taxId)</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9900</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="secondaryMail" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] Correo secundario</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9910</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="phoneNumberAlt" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] Teléfono alternativo</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9920</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="primaryAffiliationCode" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] Código afiliación principal</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9930</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="campus" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] Campus</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9940</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="institutionalIdCard" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] Carnet institucional</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9950</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="universityIdCard" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] Carnet universitario</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9960</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="primaryAffiliationName" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>[DEPRECADO] Nombre afiliación principal</a:displayName><a:deprecated>true</a:deprecated><a:displayOrder>9970</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>

                </xsd:sequence>
            </xsd:complexType>

            <!-- OrgExtensionType — extension de OrgType para programas academicos -->
            <xsd:complexType name="OrgExtensionType">
                <xsd:annotation>
                    <xsd:appinfo>
                        <a:extension ref="c:OrgType"/>
                        <a:displayName>Datos academicos de OrgType SciBack IGA</a:displayName>
                        <a:help>Extension del OrgType. Usada por archetype-org-academic-program para vincular un Org a su concepto SKOS canonico en VocBench.</a:help>
                    </xsd:appinfo>
                </xsd:annotation>
                <xsd:sequence>
                    <xsd:element name="academicProgramUri" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>URI canonica del programa academico (VocBench SKOS)</a:displayName><a:help>Identificador persistente del concepto SKOS en el Tesauro Institucional. Ej.: http://upeu.edu.pe/sys/programas/c_bbf436cf. Coincide con el valor que se mapea hacia extension/sciback:academicProgramUri en el User.</a:help><a:indexed>true</a:indexed><a:displayOrder>100</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="academicProgramCode" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Codigo corto del programa</a:displayName><a:help>Notation SKOS del programa (p. ej. EP-SIS, EP-ENF). Mismo valor que el atributo "identifier" del Org pero indexado para busquedas.</a:help><a:indexed>true</a:indexed><a:displayOrder>110</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="studyLevel" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>Nivel del programa</a:displayName><a:help>pregrado | maestria | doctorado | especializacion | segunda-especialidad</a:help><a:displayOrder>120</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                    <xsd:element name="iscedFCode" type="xsd:string" minOccurs="0" maxOccurs="1">
                        <xsd:annotation><xsd:appinfo><a:displayName>ISCED-F (campo de educacion)</a:displayName><a:help>ISCED-F 2013 (UNESCO). Ej.: 0613, 0221.</a:help><a:displayOrder>130</a:displayOrder></xsd:appinfo></xsd:annotation>
                    </xsd:element>
                </xsd:sequence>
            </xsd:complexType>

        </xsd:schema>
    </definition>
</schema>
