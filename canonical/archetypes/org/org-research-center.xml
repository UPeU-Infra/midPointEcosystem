<?xml version="1.0" encoding="UTF-8"?>
<!--
  Archetype: Research-Center (OrgType)  — CANÓNICO / reutilizable SciBack
  OID: 6b1d9a4e-2f53-4c8a-bf17-9d0c6e2a4b81 (nuevo, fijo)

  Tipifica los OrgType que representan una Unidad de Investigación e Innovación:
  la Dirección General de Investigación (DGI) y sus Centros de Investigación e
  Innovación (CII). Distinto de:
    - academic-unit  (soporte académico genérico: CRAI, Idiomas, Tutoría)
    - faculty        (estructura formal de carreras)
    - research-line  (línea de investigación, hija del centro)

  Mapeo canónico a estándares:
    - iga-canonical-standards §10.2 (OrgType archetypes) — agrupación organizacional.
    - CERIF / PerúCRIS v1.1: perucris.orgunit.tiposubunidad =
        https://catalogos.concytec.gob.pe/vocabulario/concytec_tipoSubunidad.xml#unidadDeInvestigacionOInnovacion
      (este es el valor que el outbound CRIS emite para DGI y los 7 Centros CII).

  El archetype SOLO tipifica el Org; no induce roles. Las afiliaciones de
  investigación persona↔centro las construye el inbound (assignment con
  relation org:default) y se proyectan a CRIS como relación CERIF
  isPersonOfOrgUnit (relationshipType id 5).

  Reutilizable: toda universidad peruana con RENACYT/SUNEDU tiene una DGI y
  Centros de Investigación. Overlay UPeU: identifier = ID_AREA (DGI=69) o
  CII-{ID_CENTRO_INVESTIGACION} (ESTHER.DGI_CENTRO_INVESTIGACION).
-->
<archetype xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
           oid="6b1d9a4e-2f53-4c8a-bf17-9d0c6e2a4b81">
    <name>archetype-org-research-center</name>
    <description>Unidad de Investigación e Innovación: Dirección General de Investigación (DGI) y Centros de Investigación e Innovación (CII). OrgType. Mapea a PerúCRIS perucris.orgunit.tiposubunidad #unidadDeInvestigacionOInnovacion. El archetype solo tipifica; las afiliaciones de investigación (persona->centro) se modelan como assignment con relation org:default y se proyectan a CRIS como relación CERIF isPersonOfOrgUnit (relationshipType 5). iga-canonical-standards §10.2.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <assignmentRelation>
            <holderType>OrgType</holderType>
        </assignmentRelation>
    </assignment>
    <archetypePolicy>
        <display>
            <label>Unidad de Investigación</label>
            <pluralLabel>Unidades de Investigación</pluralLabel>
            <icon>
                <cssClass>fa fa-flask</cssClass>
                <color>#16a085</color>
            </icon>
        </display>
    </archetypePolicy>
</archetype>
