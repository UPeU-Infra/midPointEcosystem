<archetype xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3" oid="455d90ab-b54a-4aa7-a402-a6b6ffc0c0d9">
    <name>archetype-org-institution</name>
    <description>Universidad o institución educativa raíz del árbol organizacional. Único nodo de este tipo por deployment. eduPersonOrgDN apunta a este nodo.</description>
    <lifecycleState>active</lifecycleState>
    <assignment>
        <assignmentRelation>
            <holderType>OrgType</holderType>
        </assignmentRelation>
    </assignment>
    <archetypePolicy>
        <display>
            <label>Institución</label>
            <pluralLabel>Instituciones</pluralLabel>
            <icon>
                <cssClass>fa fa-university</cssClass>
                <color>#1e3a5f</color>
            </icon>
        </display>
    </archetypePolicy>
    <!-- Contrato RIMS←IGA Entregable 2: proyecta el nodo OrgType a LDAP como OU
         (kind=generic intent=ou en ldapidentitycacheupeu). Inducement → aplica a los
         holders del archetype (los nodos institution). El DN/atributos se computan en el
         schemaHandling del resource. La institución raíz es el ancla bajo ou=org. -->
    <inducement>
        <construction>
            <resourceRef oid="7b4e1c2d-3f8a-4d6b-9e5c-0a1b2c3d4e5f" type="ResourceType"/>
            <kind>generic</kind>
            <intent>ou</intent>
        </construction>
    </inducement>
</archetype>