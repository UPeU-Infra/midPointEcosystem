<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
     Function Library: sb-document-normalizer
     OID: 1c7e4b2d-3f5a-4061-ac9d-8f7e6d5c4b31

     Propósito: ÚNICA fuente de verdad para canonicalizar el número de
     documento LAMB (extension/upeu:lambDocNum) y resolver el tipo de
     documento (extension/upeu:lambDocType) de forma type-aware.

     Por qué existe (FIX 2026-06-29, colisión lambDocNum):
       lambDocNum/lambDocType son single-valued. Tres resources Oracle
       (trabajadores=ELISEO, estudiantes/egresados=MOISES) escribían
       lambDocNum con strength=strong. Cuando dos fuentes clasifican el
       MISMO documento con distinto TIPO (ej. ELISEO ID_TIPODOCUMENTO=1
       'DNI' vs MOISES TIPO_DOC=4 'CE' para el mismo extranjero), la
       normalización type-aware produce dos strings distintos
       ("01253556" rama DNI vs "CE:001253556" rama CE) y MidPoint lanza
       SchemaException ("Strong mappings provided more than one value for
       single-valued item extension/lambDocNum"). 135 personas afectadas
       (CE con lambDocNum mal prefijado), 13/40 del lote EP-PSI-FCS.
       Ver docs/runbooks/lambDocNum-collision-fix-2026-06-29.md.

     Hallazgo de calidad de datos:
       ELISEO (planilla) etiqueta a extranjeros como DNI por defecto;
       MOISES (MDM de personas, vía academic) trae el tipo correcto (CE).
       => Para el TIPO de documento, MOISES > ELISEO. La función
       resolveDocClass implementa "no-DNI gana a DNI cuando el número
       coincide": un DNI de planilla es relleno por defecto, no una
       aserción positiva. iga-canonical-standards §1.3 (una sola
       representación por documento; el tipo es hecho legal/MDM, no de
       nómina).

     Clasificación canónica (idéntica al CANON_DOC previo, ahora central):
       DNI       (1, 24)            : strip ceros + zfill8.
       CE/visa   (4, 6, 31, 22, 23) : strip ceros + zfill9, prefijo 'CE:'.
       pasaporte (7, 9)             : 'PP:' + upper (alfanumérico).
       desconocido/vacío numérico   : rama genérica DNI (strip + zfill8).
       vacío / '0' / '000..0'       : null (ruido de correlación).

     El prefijo CE:/PP: es la CLAVE DE CORRELACIÓN type-aware (un CE
     12345678 no colapsa con un DNI 12345678). El Bloque J del template
     quita el prefijo y guarda el número limpio en identityDocuments.
     ============================================================ -->
<functionLibrary xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
                 xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
                 xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"
                 oid="1c7e4b2d-3f5a-4061-ac9d-8f7e6d5c4b31">
    <name>sb-document-normalizer</name>
    <description>Canonicaliza lambDocNum (type-aware, prefijo CE:/PP:) y resuelve la clase de documento (DNI/CE/PASS). Fuente unica de la forma canonica del documento para todos los resources Oracle de persona. FIX 2026-06-29 colision lambDocNum.</description>

    <!-- toCanonicalDocNumber(rawNum, docType) -> string type-aware (con prefijo) o null. -->
    <function>
        <name>toCanonicalDocNumber</name>
        <parameter>
            <name>rawNum</name>
            <type>xsd:string</type>
        </parameter>
        <parameter>
            <name>docType</name>
            <type>xsd:string</type>
        </parameter>
        <returnType>xsd:string</returnType>
        <script>
            <code>
def num = (rawNum ?: '').toString().trim()
def type = (docType ?: '').toString().trim()
if (!num) return null
def DNI = ['1','24'] as Set
def CE9 = ['4','6','31','22','23'] as Set
def PASS = ['7','9'] as Set
def strip = { it.replaceFirst(/^0+/, '') }
if (type in DNI) {
    if (num ==~ /\d+/) { def n = strip(num); if (!n) return null; return n.length() &lt;= 8 ? n.padLeft(8,'0') : n }
    return num
}
if (type in CE9) {
    if (num ==~ /\d+/) { def n = strip(num); if (!n) return null; def z = n.length() &lt;= 9 ? n.padLeft(9,'0') : n; return 'CE:'+z }
    return 'CE:'+num
}
if (type in PASS) { return 'PP:'+num.toUpperCase() }
if (num ==~ /\d+/) { def n = strip(num); if (!n) return null; return n.length() &lt;= 8 ? n.padLeft(8,'0') : n }
return num
            </code>
        </script>
    </function>

    <!-- resolveDocClass(docType) -> 'DNI' | 'CE' | 'PASS' | 'OTHER'. -->
    <function>
        <name>resolveDocClass</name>
        <parameter>
            <name>docType</name>
            <type>xsd:string</type>
        </parameter>
        <returnType>xsd:string</returnType>
        <script>
            <code>
def t = (docType ?: '').toString().trim()
if (t in (['1','24'] as Set)) return 'DNI'
if (t in (['4','6','31','22','23'] as Set)) return 'CE'
if (t in (['7','9'] as Set)) return 'PASS'
return 'OTHER'
            </code>
        </script>
    </function>
</functionLibrary>
